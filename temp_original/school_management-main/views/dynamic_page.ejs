<%- include('partials/header') %>

    <div class="container my-5 dynamic-content">
        <% if (sections && sections.length> 0) { %>
            <% sections.forEach(section=> { %>

                <% if (section.section_type==='hero' ) { %>
                    <div class="p-5 mb-4 bg-light rounded-3 text-center"
                        style="background-image: url('<%= section.content.image %>'); background-size: cover; background-position: center;">
                        <div class="py-5"
                            style="background: rgba(255,255,255,0.8); border-radius: 10px; display: inline-block; padding: 20px;">
                            <h1 class="display-5 fw-bold">
                                <%= section.content.heading %>
                            </h1>
                            <p class="col-md-8 fs-4 mx-auto">
                                <%= section.content.subheading %>
                            </p>
                            <% if (section.content.cta_text) { %>
                                <a href="<%= section.content.cta_link %>" class="btn btn-primary btn-lg">
                                    <%= section.content.cta_text %>
                                </a>
                                <% } %>
                        </div>
                    </div>

                    <% } else if (section.section_type==='features' ) { %>
                        <div class="row text-center mb-5">
                            <div class="col-12 mb-4">
                                <h2>
                                    <%= section.content.title %>
                                </h2>
                                <p class="text-muted">
                                    <%= section.content.description %>
                                </p>
                            </div>
                            <% if (section.content.items) { %>
                                <% section.content.items.forEach(item=> { %>
                                    <div class="col-md-4 mb-3">
                                        <div class="card h-100 p-3 shadow-sm">
                                            <div class="card-body">
                                                <i
                                                    class="<%= item.icon || 'fas fa-star' %> fa-2x text-primary mb-3"></i>
                                                <h5>
                                                    <%= item.title %>
                                                </h5>
                                                <p class="card-text text-muted">
                                                    <%= item.text %>
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                    <% }); %>
                                        <% } %>
                        </div>

                        <% } else if (section.section_type==='content' ) { %>
                            <div class="row mb-5">
                                <div class="col-12">
                                    <h2>
                                        <%= section.content.title %>
                                    </h2>
                                    <div class="content-body">
                                        <%- section.content.body %>
                                    </div>
                                </div>
                            </div>

                            <% } else if (section.section_type==='gallery' ) { %>
                                <div class="row mb-5">
                                    <div class="col-12 text-center mb-4">
                                        <h2>
                                            <%= section.content.title %>
                                        </h2>
                                    </div>
                                    <% if (section.content.images) { %>
                                        <% section.content.images.forEach(img=> { %>
                                            <div class="col-md-4 mb-3">
                                                <img src="<%= img %>" class="img-fluid rounded shadow-sm" alt="Gallery">
                                            </div>
                                            <% }); %>
                                                <% } %>
                                </div>
                                <% } %>

                                    <% }); %>
                                        <% } else { %>
                                            <div class="text-center py-5">
                                                <h3>Content Coming Soon</h3>
                                            </div>
                                            <% } %>
    </div>

    <%- include('partials/footer') %>

        <main class="dynamic-content">
            <% if (sections && sections.length> 0) { %>
                <% sections.forEach(section=> { %>

                    <!-- HERO SECTION -->
                    <% if (section.section_type==='hero' ) { %>
                        <header class="hero-section <%= section.css_classes %>"
                            style="background-image: url('<%= section.content.image || '/images/award.jpg' %>');">
                            <div class="hero-overlay"></div>
                            <div class="container hero-content text-start animate-up">
                                <h1 class="hero-title">
                                    <%= section.content.heading %>
                                </h1>
                                <p class="hero-lead">
                                    <%= section.content.subheading %>
                                </p>
                                <% if (section.content.cta_text) { %>
                                    <a href="<%= section.content.cta_link %>" class="btn btn-login btn-lg px-5">
                                        <%= section.content.cta_text %>
                                    </a>
                                    <% } %>
                            </div>
                        </header>

                        <!-- FEATURES SECTION -->
                        <% } else if (section.section_type==='features' ) { %>
                            <section class="<%= section.css_classes %> section-padding bg-white">
                                <div class="container">
                                    <div class="text-center mb-5">
                                        <h2 class="section-title">
                                            <%= section.content.title %>
                                        </h2>
                                        <p class="section-desc">
                                            <%= section.content.description %>
                                        </p>
                                    </div>
                                    <div class="row g-4 justify-content-center">
                                        <% if (section.content.items && section.content.items.length> 0) { %>
                                            <% section.content.items.forEach(item=> { %>
                                                <div class="col-lg-4 col-md-6">
                                                    <div class="card-feature">
                                                        <div class="icon-box">
                                                            <i class="<%= item.icon || 'fas fa-star' %>"></i>
                                                        </div>
                                                        <h4>
                                                            <%= item.title %>
                                                        </h4>
                                                        <p class="text-muted">
                                                            <%= item.text %>
                                                        </p>
                                                    </div>
                                                </div>
                                                <% }) %>
                                                    <% } %>
                                    </div>
                                </div>
                            </section>

                            <!-- RICH TEXT CONTENT -->
                            <% } else if (section.section_type==='content' ) { %>
                                <section class="<%= section.css_classes %> section-padding">
                                    <div class="container">
                                        <div class="row justify-content-center">
                                            <div class="col-lg-10">
                                                <h2 class="section-title mb-4">
                                                    <%= section.content.title %>
                                                </h2>
                                                <div class="lead text-dark">
                                                    <%- section.content.body %>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </section>

                                <!-- GALLERY -->
                                <% } else if (section.section_type==='gallery' ) { %>
                                    <section class="<%= section.css_classes %> section-padding bg-light">
                                        <div class="container">
                                            <div class="text-center mb-5">
                                                <h2 class="section-title">
                                                    <%= section.content.title %>
                                                </h2>
                                            </div>
                                            <div class="row g-4">
                                                <% if (section.content.images) { %>
                                                    <% section.content.images.forEach(img=> { %>
                                                        <div class="col-md-4 col-sm-6">
                                                            <div class="gallery-card h-100">
                                                                <img src="<%= img %>" alt="Gallery Image">
                                                            </div>
                                                        </div>
                                                        <% }) %>
                                                            <% } %>
                                            </div>
                                        </div>
                                    </section>

                                    <!-- STATS COUNTER -->
                                    <% } else if (section.section_type==='stats' ) { %>
                                        <section class="stats-section">
                                            <div class="container">
                                                <div class="row text-center g-4">
                                                    <% if (section.content.items) { %>
                                                        <% section.content.items.forEach(item=> { %>
                                                            <div class="col-md-3 col-6 stat-item">
                                                                <h3 class="counter"
                                                                    data-target="<%= item.number.replace(/[^0-9]/g, '') %>">
                                                                    0</h3>
                                                                <p class="text-white-50 mb-0">
                                                                    <%= item.label %>
                                                                </p>
                                                            </div>
                                                            <% }) %>
                                                                <% } %>
                                                </div>
                                            </div>
                                            <script>
                                                document.addEventListener('DOMContentLoaded', () => {
                                                    const counters = document.querySelectorAll('.counter');
                                                    const observer = new IntersectionObserver((entries) => {
                                                        entries.forEach(entry => {
                                                            if (entry.isIntersecting) {
                                                                const counter = entry.target;
                                                                const target = +counter.getAttribute('data-target');
                                                                const inc = target / 50;
                                                                let count = 0;
                                                                const update = () => {
                                                                    count += inc;
                                                                    if (count < target) {
                                                                        counter.innerText = Math.ceil(count);
                                                                        setTimeout(update, 30);
                                                                    } else {
                                                                        counter.innerText = target;
                                                                    }
                                                                };
                                                                update();
                                                                observer.unobserve(counter);
                                                            }
                                                        });
                                                    });
                                                    counters.forEach(c => observer.observe(c));
                                                });
                                            </script>
                                        </section>
                                        <% } %>

                                            <% }) %>
                                                <% } else { %>
                                                    <!-- Empty State -->
                                                    <div
                                                        class="d-flex align-items-center justify-content-center text-center section-padding">
                                                        <div>
                                                            <h1 class="display-4 fw-bold text-muted">Page Under
                                                                Construction
                                                            </h1>
                                                        </div>
                                                    </div>
                                                    <% } %>
        </main>

        <%- include('partials/frontend_footer') %>
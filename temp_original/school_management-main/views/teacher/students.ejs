<%- include('../partials/header') %>

    <div class="admin-layout animate-fade-in" style="margin-top: 80px;">
        <!-- Sidebar -->
        <aside class="sidebar glass" style="margin: 20px; border-radius: 24px;">
            <div style="margin-bottom: 3rem; text-align: center;">
                <div
                    style="width: 80px; height: 80px; background: var(--primary); color: white; border-radius: 20px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; border: 3px solid var(--accent);">
                    <i class="fas fa-chalkboard-teacher" style="font-size: 2rem;"></i>
                </div>
                <h3 style="color: var(--primary); font-weight: 800;">Instructor</h3>
                <p style="font-size: 0.8rem; color: var(--text-muted); font-weight: 600;">Faculty Portal</p>
            </div>
            <ul class="sidebar-nav">
                <li><a href="/teacher/dashboard"><i class="fas fa-home"></i> Home Overview</a></li>
                <li><a href="/teacher/attendance"><i class="fas fa-tasks"></i> Attendance</a></li>
                <li><a href="/teacher/exams"><i class="fas fa-clipboard-list"></i> Exam Results</a></li>
                <li><a href="/teacher/timetable"><i class="fas fa-calendar-alt"></i> My Timetable</a></li>
                <li><a href="/teacher/students" class="active"><i class="fas fa-user-friends"></i> Student Blocks</a>
                </li>
                <li><a href="/library"><i class="fas fa-book-reader"></i> Digital Library</a></li>
                <li style="margin-top: 2rem;"><a href="/logout" style="color: var(--danger);"><i
                            class="fas fa-sign-out-alt"></i> Sign Out</a></li>
            </ul>
        </aside>

        <main class="main-content">
            <header style="margin-bottom: 3rem; display: flex; justify-content: space-between; align-items: center;">
                <div>
                    <% if (viewMode==='blocks' ) { %>
                        <h2 style="font-size: 2rem; font-weight: 800; color: var(--primary);">My Assigned Blocks</h2>
                        <p style="color: var(--text-muted);">Select a class block to view students and profiles</p>
                        <% } else { %>
                            <h2 style="font-size: 2rem; font-weight: 800; color: var(--primary);">Members: <%=
                                    currentClass.class_name %>
                            </h2>
                            <p style="color: var(--text-muted);">Viewing students in block <%= currentClass.section %>
                            </p>
                            <% } %>
                </div>
                <% if (viewMode==='students' ) { %>
                    <a href="/teacher/students" class="btn"
                        style="background: var(--bg-main); border: 2px solid #ddd; font-weight: 700; color: var(--primary);">
                        <i class="fas fa-arrow-left"></i> Change Block
                    </a>
                    <% } %>
            </header>

            <% if (viewMode==='blocks' ) { %>
                <!-- Class Blocks Grid -->
                <div class="grid animate-slide-up"
                    style="grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2rem;">
                    <% if(classes.length===0) { %>
                        <div class="card" style="grid-column: 1/-1; text-align: center; padding: 4rem;">
                            <i class="fas fa-exclamation-circle"
                                style="font-size: 3rem; color: #cbd5e1; margin-bottom: 1rem;"></i>
                            <h3 style="color: var(--primary);">No Blocks Assigned</h3>
                            <p style="color: var(--text-muted);">Please contact Admin to assign classes in the
                                timetable.</p>
                        </div>
                        <% } %>
                            <% classes.forEach(cls=> { %>
                                <a href="/teacher/students?class_id=<%= cls.id %>" class="card hover-scale"
                                    style="padding: 2.5rem; text-decoration: none; text-align: center; border-radius: 20px; transition: all 0.3s ease; position: relative; border-bottom: 5px solid var(--accent);">
                                    <div
                                        style="width: 60px; height: 60px; background: rgba(59, 130, 246, 0.1); color: var(--accent); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.8rem; margin: 0 auto 1.5rem;">
                                        <i class="fas fa-users"></i>
                                    </div>
                                    <h3 style="font-weight: 800; color: var(--primary); margin-bottom: 0.5rem;">
                                        <%= cls.class_name %>
                                    </h3>
                                    <p
                                        style="color: var(--text-muted); font-weight: 700; font-size: 0.85rem; text-transform: uppercase;">
                                        Section: <%= cls.section %>
                                    </p>

                                    <div
                                        style="margin-top: 1rem; font-weight: 800; color: var(--accent); font-size: 0.85rem;">
                                        VIEW MEMBERS <i class="fas fa-arrow-right"></i>
                                    </div>
                                </a>
                                <% }); %>
                </div>
                <% } else { %>
                    <!-- Specific Student List (Member Block) -->
                    <div class="card animate-slide-up" style="overflow: hidden; padding: 0; border-radius: 20px;">
                        <div
                            style="padding: 1.2rem 2rem; background: #f8fafc; border-bottom: 1px solid #edf2f7; font-weight: 800; color: var(--primary);">
                            Class Member Enrollment
                        </div>
                        <table class="data-table" style="width: 100%; border-collapse: collapse;">
                            <thead>
                                <tr style="background: var(--bg-light); text-align: left;">
                                    <th
                                        style="padding: 1.2rem 2rem; color: var(--text-muted); font-size: 0.85rem; text-transform: uppercase;">
                                        Roll No</th>
                                    <th
                                        style="padding: 1.2rem; color: var(--text-muted); font-size: 0.85rem; text-transform: uppercase;">
                                        Full Name</th>
                                    <th
                                        style="padding: 1.2rem; color: var(--text-muted); font-size: 0.85rem; text-transform: uppercase;">
                                        Contact Info</th>
                                    <th
                                        style="padding: 1.2rem 2rem; color: var(--text-muted); font-size: 0.85rem; text-transform: uppercase;">
                                        Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if(students.length===0) { %>
                                    <tr>
                                        <td colspan="4"
                                            style="padding: 4rem; text-align: center; color: var(--text-muted);">
                                            <i class="fas fa-search"
                                                style="font-size: 2.5rem; opacity: 0.2; display: block; margin-bottom: 1rem;"></i>
                                            No students registered in this specific block.
                                        </td>
                                    </tr>
                                    <% } %>
                                        <% students.forEach(std=> { %>
                                            <tr
                                                style="border-bottom: 1px solid #f1f5f9; transition: var(--transition);">
                                                <td
                                                    style="padding: 1.2rem 2rem; font-weight: 900; color: var(--accent); font-size: 1.1rem;">
                                                    <%= std.roll_no %>
                                                </td>
                                                <td style="padding: 1.2rem;">
                                                    <div style="display: flex; align-items: center; gap: 12px;">
                                                        <div
                                                            style="width: 40px; height: 40px; background: #e2e8f0; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; color: var(--primary);">
                                                            <%= std.full_name.charAt(0) %>
                                                        </div>
                                                        <div style="font-weight: 700; color: var(--primary);">
                                                            <%= std.full_name %>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td
                                                    style="padding: 1.2rem; color: var(--text-muted); font-size: 0.9rem;">
                                                    <i class="fas fa-at"></i>
                                                    <%= std.email || 'No email' %>
                                                </td>
                                                <td style="padding: 1.2rem 2rem;">
                                                    <span
                                                        style="background: #f0fdf4; color: #15803d; padding: 4px 12px; border-radius: 50px; font-size: 0.75rem; font-weight: 800; border: 1px solid #bbf7d0;">
                                                        MEMBER
                                                    </span>
                                                </td>
                                            </tr>
                                            <% }); %>
                            </tbody>
                        </table>
                    </div>
                    <% } %>
        </main>
    </div>

    <style>
        .hover-scale {
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            background: white;
        }

        .hover-scale:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(59, 130, 246, 0.1);
            border-color: var(--accent);
        }
    </style>

    <%- include('../partials/footer') %>
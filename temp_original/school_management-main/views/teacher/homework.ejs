<%- include('../partials/header') %>

    <div class="admin-layout animate-fade-in" style="margin-top: 80px;">
        <%- include('../partials/sidebar_teacher', { active: 'homework' }) %>

            <main class="main-content">
                <header
                    style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 3rem;">
                    <div>
                        <h2 style="font-size: 2rem; font-weight: 800; color: var(--primary);">Homework Management</h2>
                        <p style="color: var(--text-muted);">Create and track assignments for your classes</p>
                    </div>
                    <button class="btn-primary"
                        onclick="document.getElementById('addHomeworkModal').style.display='flex'"
                        style="padding: 12px 25px; border-radius: 50px; display: flex; align-items: center; gap: 10px;">
                        <i class="fas fa-plus"></i> Create Assignment
                    </button>
                </header>

                <% if (success) { %>
                    <div class="alert alert-success"
                        style="background: #ecfdf5; color: #059669; padding: 1rem; border-radius: 12px; margin-bottom: 2rem;">
                        <i class="fas fa-check-circle"></i>
                        <%= success %>
                    </div>
                    <% } %>

                        <% if (error) { %>
                            <div class="alert alert-danger"
                                style="background: #fef2f2; color: #dc2626; padding: 1rem; border-radius: 12px; margin-bottom: 2rem;">
                                <i class="fas fa-exclamation-circle"></i>
                                <%= error %>
                            </div>
                            <% } %>

                                <div class="grid"
                                    style="grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 2rem;">
                                    <% if (homework.length===0) { %>
                                        <div class="card"
                                            style="grid-column: 1/-1; padding: 4rem; text-align: center; color: var(--text-muted);">
                                            <i class="fas fa-book-open"
                                                style="font-size: 3rem; margin-bottom: 1rem; opacity: 0.3;"></i>
                                            <p>No homework created yet. Click "Create Assignment" to start.</p>
                                        </div>
                                        <% } %>

                                            <% homework.forEach(hw=> { %>
                                                <div class="card animate-slide-up"
                                                    style="padding: 2rem; border-radius: 24px; position: relative; overflow: hidden;">
                                                    <div style="position: absolute; top: 0; right: 0; padding: 1rem;">
                                                        <span class="badge"
                                                            style="background: #eff6ff; color: #3b82f6; font-size: 0.75rem;">
                                                            <%= hw.class_name %> - <%= hw.section %>
                                                        </span>
                                                    </div>

                                                    <h3
                                                        style="font-weight: 800; color: var(--primary); margin-bottom: 0.5rem;">
                                                        <%= hw.title %>
                                                    </h3>
                                                    <p
                                                        style="font-size: 0.9rem; color: var(--text-muted); margin-bottom: 1.5rem; line-height: 1.5;">
                                                        <%= hw.description.substring(0, 100) %>
                                                            <%= hw.description.length> 100 ? '...' : '' %>
                                                    </p>

                                                    <div
                                                        style="display: flex; flex-direction: column; gap: 10px; margin-bottom: 1.5rem;">
                                                        <div
                                                            style="display: flex; align-items: center; gap: 10px; font-size: 0.85rem;">
                                                            <i class="far fa-calendar-alt" style="color: #6366f1;"></i>
                                                            <span style="font-weight: 600;">Due:</span>
                                                            <%= new Date(hw.due_date).toLocaleDateString('en-GB') %>
                                                        </div>
                                                        <div
                                                            style="display: flex; align-items: center; gap: 10px; font-size: 0.85rem;">
                                                            <i class="fas fa-star" style="color: #f59e0b;"></i>
                                                            <span style="font-weight: 600;">Marks:</span>
                                                            <%= hw.total_marks %>
                                                        </div>
                                                        <div
                                                            style="display: flex; align-items: center; gap: 10px; font-size: 0.85rem;">
                                                            <i class="fas fa-user-check" style="color: #10b981;"></i>
                                                            <span style="font-weight: 600;">Submissions:</span>
                                                            <%= hw.total_submissions %>
                                                        </div>
                                                    </div>

                                                    <div style="display: flex; gap: 10px; width: 100%;">
                                                        <a href="/teacher/homework/submissions/<%= hw.id %>" class="btn"
                                                            style="flex: 2; padding: 10px; background: var(--primary); color: white; border-radius: 12px; text-decoration: none; text-align: center; font-weight: 700;">
                                                            Grade Submissions
                                                        </a>
                                                        <a href="/teacher/homework/delete/<%= hw.id %>" class="btn"
                                                            style="flex: 1; padding: 10px; background: #fee2e2; color: #ef4444; border-radius: 12px; text-decoration: none; text-align: center;"
                                                            onclick="return confirm('Delete this homework?')">
                                                            <i class="fas fa-trash"></i>
                                                        </a>
                                                    </div>
                                                </div>
                                                <% }) %>
                                </div>
            </main>
    </div>

    <!-- Add Homework Modal -->
    <div id="addHomeworkModal" class="modal"
        style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); backdrop-filter: blur(8px); z-index: 9999; align-items: center; justify-content: center;">
        <div class="glass animate-slide-up"
            style="width: 100%; max-width: 550px; padding: 2.5rem; border-radius: 24px; background: white;">
            <h3 style="margin-bottom: 1.5rem; color: var(--primary); font-weight: 800;">Create New Assignment</h3>

            <form action="/teacher/homework/add" method="POST" enctype="multipart/form-data">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                    <div class="form-group">
                        <label
                            style="font-weight: 700; margin-bottom: 0.5rem; display: block; font-size: 0.9rem;">Target
                            Class</label>
                        <select name="class_id" required
                            style="width: 100%; padding: 12px; border-radius: 12px; border: 1px solid #e2e8f0; background: #f8fafc;">
                            <% classes.forEach(cls=> { %>
                                <option value="<%= cls.id %>">
                                    <%= cls.class_name %> - Sec <%= cls.section %>
                                </option>
                                <% }) %>
                        </select>
                    </div>
                    <div class="form-group">
                        <label
                            style="font-weight: 700; margin-bottom: 0.5rem; display: block; font-size: 0.9rem;">Subject</label>
                        <input type="text" name="subject" value="<%= teacherData.subject %>" required
                            style="width: 100%; padding: 12px; border-radius: 12px; border: 1px solid #e2e8f0; background: #f8fafc;">
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label
                        style="font-weight: 700; margin-bottom: 0.5rem; display: block; font-size: 0.9rem;">Assignment
                        Title</label>
                    <input type="text" name="title" placeholder="e.g. Algebra Exercise 4.2" required
                        style="width: 100%; padding: 12px; border-radius: 12px; border: 1px solid #e2e8f0; background: #f8fafc;">
                </div>

                <div class="form-group mb-3">
                    <label
                        style="font-weight: 700; margin-bottom: 0.5rem; display: block; font-size: 0.9rem;">Description
                        & Instructions</label>
                    <textarea name="description" rows="3" placeholder="Explain what students need to do..."
                        style="width: 100%; padding: 12px; border-radius: 12px; border: 1px solid #e2e8f0; background: #f8fafc; resize: none;"></textarea>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem;">
                    <div class="form-group">
                        <label style="font-weight: 700; margin-bottom: 0.5rem; display: block; font-size: 0.9rem;">Due
                            Date</label>
                        <input type="date" name="due_date" required
                            style="width: 100%; padding: 12px; border-radius: 12px; border: 1px solid #e2e8f0; background: #f8fafc;">
                    </div>
                    <div class="form-group">
                        <label style="font-weight: 700; margin-bottom: 0.5rem; display: block; font-size: 0.9rem;">Total
                            Marks</label>
                        <input type="number" name="total_marks" value="10" required
                            style="width: 100%; padding: 12px; border-radius: 12px; border: 1px solid #e2e8f0; background: #f8fafc;">
                    </div>
                </div>

                <div class="form-group mb-4">
                    <label style="font-weight: 700; margin-bottom: 0.5rem; display: block; font-size: 0.9rem;">Upload
                        Material (Optional)</label>
                    <input type="file" name="attachment" style="width: 100%; padding: 8px; font-size: 0.85rem;">
                </div>

                <div style="display: flex; gap: 10px; justify-content: flex-end;">
                    <button type="button" onclick="document.getElementById('addHomeworkModal').style.display='none'"
                        class="btn"
                        style="background: transparent; color: var(--text-muted); font-weight: 700;">Cancel</button>
                    <button type="submit" class="btn-primary" style="padding: 12px 30px; border-radius: 12px;">Publish
                        Homework</button>
                </div>
            </form>
        </div>
    </div>

    <%- include('../partials/footer') %>
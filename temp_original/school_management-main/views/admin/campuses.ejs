<%- include('../partials/header') %>

    <div class="admin-layout animate-fade-in" style="margin-top: 80px;">
        <!-- Sidebar -->
        <!-- Sidebar -->
        <%- include('../partials/sidebar', { active: 'campuses' }) %>

            <!-- Main Content -->
            <main class="main-content">
                <header
                    style="margin-bottom: 3rem; display: flex; justify-content: space-between; align-items: center;">
                    <div>
                        <h2 style="font-size: 2rem; font-weight: 800; color: var(--primary);">Campus Management</h2>
                        <p style="color: var(--text-muted);">Configure and manage multiple school campuses.</p>
                    </div>
                    <% if (isSuperAdmin) { %>
                        <button onclick="document.getElementById('addCampusModal').style.display='flex'" class="btn">
                            <i class="fas fa-plus"></i> Add New Campus
                        </button>
                        <% } %>
                </header>

                <div class="grid" style="grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem;">
                    <% campuses.forEach(campus=> { %>
                        <div class="card glass hover-scale" style="position: relative;">
                            <div
                                style="display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 1rem;">
                                <div
                                    style="width: 50px; height: 50px; background: #e0e7ff; color: #4338ca; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem;">
                                    <i class="fas fa-building"></i>
                                </div>
                                <span
                                    style="font-size: 0.8rem; font-weight: 700; background: #f1f5f9; padding: 4px 10px; border-radius: 50px; color: var(--text-muted);">
                                    Code: <%= campus.campus_code %>
                                </span>
                            </div>

                            <h3 style="margin: 0 0 0.5rem 0; font-size: 1.25rem;">
                                <%= campus.campus_name %>
                            </h3>

                            <div style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 1.5rem;">
                                <p style="margin: 5px 0;"><i class="fas fa-map-marker-alt" style="width: 20px;"></i>
                                    <%= campus.city %>
                                </p>
                                <p style="margin: 5px 0;"><i class="fas fa-phone" style="width: 20px;"></i>
                                    <%= campus.contact_phone || 'N/A' %>
                                </p>
                            </div>

                            <div style="border-top: 1px solid #eee; padding-top: 1rem; display: flex; gap: 10px;">
                                <button class="btn btn-sm"
                                    style="background: transparent; border: 1px solid #e2e8f0; color: var(--text-main); flex: 1;">
                                    Edit
                                </button>
                                <% if(isSuperAdmin && campus.id !==1) { %>
                                    <a href="/admin/campuses/delete/<%= campus.id %>" class="btn btn-sm"
                                        style="background: #fee2e2; color: #dc2626; border: none;"
                                        onclick="return confirm('Are you sure? This will delete all data associated with this campus!')">
                                        Delete
                                    </a>
                                    <% } %>
                            </div>
                        </div>
                        <% }) %>
                </div>
            </main>
    </div>

    <!-- Add Campus Modal -->
    <div id="addCampusModal" class="modal glass"
        style="display: none; position: fixed; inset: 0; z-index: 1000; align-items: center; justify-content: center; background: rgba(0,0,0,0.5);">
        <form action="/admin/campuses/add" method="POST" class="card"
            style="width: 100%; max-width: 500px; animation: slideUp 0.3s ease;">
            <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
            <h3 style="margin-top: 0;">Add New Campus</h3>

            <div class="form-group" style="margin-bottom: 1rem;">
                <label>Campus Name</label>
                <input type="text" name="campus_name" required placeholder="e.g. North Campus" class="form-control"
                    style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #ddd;">
            </div>

            <div class="form-group" style="margin-bottom: 1rem;">
                <label>Campus Code (Short ID)</label>
                <input type="text" name="campus_code" required placeholder="e.g. NORTH" class="form-control"
                    style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #ddd; text-transform: uppercase;">
                <small style="color: var(--text-muted);">Used for login (e.g. NORTH)</small>
            </div>

            <div class="form-group" style="margin-bottom: 1rem;">
                <label>Admin Password</label>
                <input type="password" name="admin_password" required placeholder="Default Admin Password"
                    class="form-control"
                    style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #ddd;">
                <small style="color: var(--text-muted);">Sets the password for the default 'admin' user.</small>
            </div>

            <div class="form-group" style="margin-bottom: 1rem;">
                <label>City / Location</label>
                <input type="text" name="city" required placeholder="e.g. Lahore" class="form-control"
                    style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #ddd;">
            </div>

            <div class="form-group" style="margin-bottom: 1.5rem;">
                <label>Address</label>
                <input type="text" name="address" placeholder="Full Address" class="form-control"
                    style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid #ddd;">
            </div>

            <div style="display: flex; gap: 10px; justify-content: flex-end;">
                <button type="button" onclick="document.getElementById('addCampusModal').style.display='none'"
                    class="btn" style="background: #f1f5f9; color: var(--text-main);">Cancel</button>
                <button type="submit" class="btn">Create Campus</button>
            </div>
        </form>
    </div>

    <script>
        // Close modal on outside click
        window.onclick = function (event) {
            if (event.target == document.getElementById('addCampusModal')) {
                document.getElementById('addCampusModal').style.display = "none";
            }
        }
    </script>
    </body>

    </html>
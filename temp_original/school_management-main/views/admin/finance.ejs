<%- include('../partials/header') %>

    <div class="admin-layout animate-fade-in" style="margin-top: 80px;">
        <!-- Sidebar -->
        <%- include('../partials/sidebar', { active: 'finance' }) %>

            <!-- Main Content -->
            <main class="main-content">
                <header
                    style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 3rem;">
                    <div>
                        <h2 style="font-size: 2rem; font-weight: 800; color: var(--primary);">Financial Ledger</h2>
                        <p style="color: var(--text-muted);">Track income, expenses, and audit logs.</p>
                    </div>
                    <button class="btn-primary" onclick="document.getElementById('addTransModal').style.display='flex'"
                        style="padding: 12px 25px; border-radius: 50px; display: flex; align-items: center; gap: 10px;">
                        <i class="fas fa-plus"></i> Add Transaction
                    </button>
                </header>

                <% let totalIncome=0; let totalExpense=0; ledger.forEach(item=> {
                    if(item.transaction_type === 'income') totalIncome += Number(item.amount);
                    else totalExpense += Number(item.amount);
                    });
                    let balance = totalIncome - totalExpense;
                    %>

                    <!-- Stats -->
                    <div class="stat-group animate-slide-up" style="margin-bottom: 2rem;">
                        <div class="stat-card card">
                            <div class="stat-icon" style="background: rgba(16, 185, 129, 0.1); color: var(--success);">
                                <i class="fas fa-arrow-up"></i>
                            </div>
                            <div>
                                <p
                                    style="color: var(--text-muted); font-size: 0.9rem; font-weight: 600; text-transform: uppercase;">
                                    Total Income</p>
                                <h3 style="font-size: 2rem; font-weight: 800; color: var(--primary);">Rs. <%=
                                        totalIncome.toLocaleString() %>
                                </h3>
                            </div>
                        </div>
                        <div class="stat-card card">
                            <div class="stat-icon" style="background: rgba(239, 68, 68, 0.1); color: var(--danger);">
                                <i class="fas fa-arrow-down"></i>
                            </div>
                            <div>
                                <p
                                    style="color: var(--text-muted); font-size: 0.9rem; font-weight: 600; text-transform: uppercase;">
                                    Total Expenses</p>
                                <h3 style="font-size: 2rem; font-weight: 800; color: var(--primary);">Rs. <%=
                                        totalExpense.toLocaleString() %>
                                </h3>
                            </div>
                        </div>
                        <div class="stat-card card">
                            <div class="stat-icon" style="background: rgba(59, 130, 246, 0.1); color: var(--accent);">
                                <i class="fas fa-wallet"></i>
                            </div>
                            <div>
                                <p
                                    style="color: var(--text-muted); font-size: 0.9rem; font-weight: 600; text-transform: uppercase;">
                                    Net Balance</p>
                                <h3 style="font-size: 2rem; font-weight: 800; color: var(--primary);">Rs. <%=
                                        balance.toLocaleString() %>
                                </h3>
                            </div>
                        </div>
                    </div>

                    <!-- Ledger Table -->
                    <div class="card animate-slide-up" style="padding: 0; overflow: hidden; animation-delay: 0.2s;">
                        <div
                            style="padding: 1.5rem; border-bottom: 1px solid rgba(0,0,0,0.05); background: var(--glass-bg);">
                            <h3 style="font-weight: 700; color: var(--primary);">Recent Transactions</h3>
                        </div>
                        <div style="overflow-x: auto;">
                            <table style="width: 100%; border-collapse: collapse;">
                                <thead>
                                    <tr
                                        style="background: rgba(0,0,0,0.02); text-align: left; border-bottom: 2px solid rgba(0,0,0,0.05);">
                                        <th style="padding: 1rem 1.5rem; color: var(--text-muted); font-weight: 600;">
                                            Date
                                        </th>
                                        <th style="padding: 1rem 1.5rem; color: var(--text-muted); font-weight: 600;">
                                            Description</th>
                                        <th style="padding: 1rem 1.5rem; color: var(--text-muted); font-weight: 600;">
                                            Type
                                        </th>
                                        <th
                                            style="padding: 1rem 1.5rem; color: var(--text-muted); font-weight: 600; text-align: right;">
                                            Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% ledger.forEach(item=> { %>
                                        <tr style="border-bottom: 1px solid rgba(0,0,0,0.05); transition: all 0.2s;">
                                            <td style="padding: 1rem 1.5rem; font-weight: 500;">
                                                <%= new Date(item.created_at).toLocaleDateString() %>
                                                    <span style="font-size: 0.8em; color: var(--text-muted);">
                                                        <%= new Date(item.created_at).toLocaleTimeString() %>
                                                    </span>
                                            </td>
                                            <td style="padding: 1rem 1.5rem; color: var(--text-main);">
                                                <%= item.description %>
                                            </td>
                                            <td style="padding: 1rem 1.5rem;">
                                                <span
                                                    style="padding: 5px 12px; border-radius: 20px; font-size: 0.85rem; font-weight: 600; 
                                    background: <%= item.transaction_type === 'income' ? 'var(--light-success)' : 'var(--light-danger)' %>; 
                                    color: <%= item.transaction_type === 'income' ? 'var(--success)' : 'var(--danger)' %>;">
                                                    <%= item.transaction_type.charAt(0).toUpperCase() +
                                                        item.transaction_type.slice(1) %>
                                                </span>
                                            </td>
                                            <td
                                                style="padding: 1rem 1.5rem; text-align: right; font-weight: 700; color: var(--primary);">
                                                <%= item.transaction_type==='income' ? '+' : '-' %> Rs. <%=
                                                        Number(item.amount).toLocaleString() %>
                                            </td>
                                        </tr>
                                        <% }); %>
                                            <% if (ledger.length===0) { %>
                                                <tr>
                                                    <td colspan="4"
                                                        style="text-align: center; padding: 2rem; color: var(--text-muted);">
                                                        No transactions recorded yet.</td>
                                                </tr>
                                                <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
            </main>
    </div>

    <!-- Add Transaction Modal -->
    <div id="addTransModal" class="modal"
        style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; align-items: center; justify-content: center;">
        <div class="glass"
            style="width: 100%; max-width: 500px; padding: 2rem; border-radius: 24px; animation: slideUp 0.3s ease;">
            <h3 style="margin-bottom: 1.5rem; color: var(--primary);">Record Transaction</h3>
            <form action="/admin/finance/add" method="POST">
                <div class="form-group mb-3">
                    <label>Description</label>
                    <input type="text" name="description" required class="form-control"
                        placeholder="e.g. Laboratory Equipment Purchase">
                </div>
                <div class="form-group mb-3">
                    <label>Amount (Rs.)</label>
                    <input type="number" name="amount" required class="form-control" placeholder="0.00">
                </div>
                <div class="form-group mb-4">
                    <label>Transaction Type</label>
                    <select name="transaction_type" class="form-control">
                        <option value="expense">Expense (Debit)</option>
                        <option value="income">Income (Credit)</option>
                    </select>
                </div>
                <div style="display: flex; gap: 10px; justify-content: flex-end;">
                    <button type="button" onclick="document.getElementById('addTransModal').style.display='none'"
                        class="btn" style="background: transparent; color: var(--text-muted);">Cancel</button>
                    <button type="submit" class="btn-primary">Record</button>
                </div>
            </form>
        </div>
    </div>

    <%- include('../partials/footer') %>
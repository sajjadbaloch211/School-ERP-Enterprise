<%- include('../partials/header') %>

    <div class="admin-layout animate-fade-in" style="margin-top: 80px;">
        <!-- Sidebar -->
        <!-- Sidebar -->
        <%- include('../partials/sidebar', { active: 'classes' }) %>

            <!-- Main Content -->
            <main class="main-content">
                <header
                    style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 3rem;">
                    <div>
                        <h2 style="font-size: 2rem; font-weight: 800; color: var(--primary);">Class Management</h2>
                        <p style="color: var(--text-muted);">Define school grades and sections</p>
                    </div>
                    <button class="btn btn-primary" onclick="document.getElementById('addModal').style.display='block'">
                        <i class="fas fa-layer-group"></i> Create New Class
                    </button>
                </header>

                <div class="grid animate-slide-up"
                    style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));">
                    <% classes.forEach(cls=> { %>
                        <div class="card"
                            style="position: relative; padding: 2rem; border-radius: 24px; display: flex; flex-direction: column; align-items: center; text-align: center;">
                            <div class="icon-box"
                                style="margin: 0 0 1.5rem; width: 70px; height: 70px; font-size: 1.8rem; background: #f1f5f9; color: var(--primary);">
                                <i class="fas fa-chalkboard"></i>
                            </div>
                            <h3 style="font-weight: 800; color: var(--primary); margin-bottom: 0.5rem;">
                                <%= cls.class_name %>
                            </h3>
                            <% if (typeof isSuperAdmin !=='undefined' && isSuperAdmin && cls.campus_name) { %>
                                <div style="margin-bottom: 0.5rem;">
                                    <span
                                        style="background: #e0f2fe; color: var(--primary); padding: 4px 10px; border-radius: 8px; font-size: 0.8rem; font-weight: 600;">
                                        <i class="fas fa-building"></i>
                                        <%= cls.campus_name %>
                                    </span>
                                </div>
                                <% } %>
                                    <p
                                        style="padding: 5px 15px; background: #eff6ff; color: #3b82f6; border-radius: 50px; font-weight: 700; font-size: 0.85rem; display: inline-block;">
                                        Section <%= cls.section %>
                                    </p>

                                    <div
                                        style="margin-top: 15px; background: #f8fafc; padding: 10px; border-radius: 12px; width: 100%;">
                                        <p style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 4px;">
                                            Class Teacher</p>
                                        <p style="font-weight: 700; color: var(--primary);">
                                            <i class="fas fa-user-graduate"
                                                style="margin-right: 5px; color: var(--accent);"></i>
                                            <%= cls.teacher_name || 'Not Assigned' %>
                                        </p>
                                    </div>

                                    <p
                                        style="margin-top: 10px; font-weight: 800; color: var(--accent); font-size: 1rem;">
                                        Fee: RS <%= cls.monthly_fee || 0 %>
                                    </p>
                                    <div
                                        style="margin-top: 2rem; display: flex; flex-direction: column; gap: 10px; width: 100%;">
                                        <div style="display: flex; gap: 10px;">
                                            <button onclick="openEditModal('<%= cls.id %>', '<%= cls.monthly_fee %>')"
                                                class="btn"
                                                style="flex: 1; padding: 10px; font-size: 0.85rem; background: rgba(59, 130, 246, 0.1); color: var(--primary); border: none; cursor: pointer;">
                                                <i class="fas fa-edit"></i> Fee
                                            </button>
                                            <button
                                                onclick="openAssignModal('<%= cls.id %>', '<%= cls.class_teacher_id %>')"
                                                class="btn"
                                                style="flex: 1; padding: 10px; font-size: 0.85rem; background: rgba(16, 185, 129, 0.1); color: #10b981; border: none; cursor: pointer;">
                                                <i class="fas fa-user-plus"></i> Teacher
                                            </button>
                                        </div>
                                        <a href="/admin/classes/delete/<%= cls.id %>" class="btn"
                                            style="padding: 10px; font-size: 0.85rem; background: #fff1f2; color: #e11d48;"
                                            onclick="return confirm('Delete this class? Error if students are assigned.')">
                                            <i class="fas fa-trash"></i> Delete
                                        </a>
                                    </div>
                        </div>
                        <% }) %>
                </div>
            </main>
    </div>

    <!-- Modern Add Modal -->
    <div id="addModal" class="modal glass"
        style="display: none; position: fixed; inset: 0; z-index: 2000; background: rgba(15, 23, 42, 0.4); backdrop-filter: blur(8px); flex-items: center; justify-content: center;">
        <div class="animate-slide-up"
            style="background: white; width: 100%; max-width: 450px; margin: 80px auto; border-radius: 24px; padding: 3rem; position: relative; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);">
            <button onclick="document.getElementById('addModal').style.display='none'"
                style="position: absolute; right: 2rem; top: 2rem; background: #f8fafc; border: none; width: 40px; height: 40px; border-radius: 50%; cursor: pointer;"><i
                    class="fas fa-times"></i></button>
            <h2 style="font-weight: 800; color: var(--primary); margin-bottom: 0.5rem;">New Class</h2>
            <p style="color: var(--text-muted); margin-bottom: 2.5rem;">Create a new grade and section entry.</p>

            <form action="/admin/classes/add" method="POST">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                <div style="margin-bottom: 1.5rem;">
                    <label style="display: block; font-weight: 700; margin-bottom: 8px; font-size: 0.9rem;">Class
                        Name</label>
                    <input type="text" name="class_name" placeholder="e.g. Grade 10" required
                        style="width: 100%; padding: 12px 16px; border-radius: 12px; border: 1px solid #e2e8f0; background: #f8fafc;">
                </div>
                <div style="margin-bottom: 1.5rem;">
                    <label
                        style="display: block; font-weight: 700; margin-bottom: 8px; font-size: 0.9rem;">Section</label>
                    <input type="text" name="section" placeholder="e.g. A" required
                        style="width: 100%; padding: 12px 16px; border-radius: 12px; border: 1px solid #e2e8f0; background: #f8fafc;">
                </div>
                <div style="margin-bottom: 2rem;">
                    <label style="display: block; font-weight: 700; margin-bottom: 8px; font-size: 0.9rem;">Monthly Fee
                        (RS)</label>
                    <input type="number" name="monthly_fee" placeholder="e.g. 2500" required
                        style="width: 100%; padding: 12px 16px; border-radius: 12px; border: 1px solid #e2e8f0; background: #f8fafc;">
                </div>
                <button type="submit" class="btn btn-primary" style="width: 100%; padding: 15px;">Establish
                    Class</button>
            </form>
        </div>
    </div>

    <!-- Edit Fee Modal -->
    <div id="editModal" class="modal glass"
        style="display: none; position: fixed; inset: 0; z-index: 2000; background: rgba(15, 23, 42, 0.4); backdrop-filter: blur(8px); align-items: center; justify-content: center;">
        <div class="animate-slide-up"
            style="background: white; width: 100%; max-width: 400px; margin: 100px auto; border-radius: 20px; padding: 2.5rem; position: relative;">
            <h3 style="font-weight: 800; color: var(--primary); margin-bottom: 1.5rem;">Update Class Fee</h3>
            <form action="/admin/classes/update-fee" method="POST">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                <input type="hidden" name="class_id" id="edit_class_id">
                <div style="margin-bottom: 2rem;">
                    <label style="display: block; font-weight: 700; margin-bottom: 8px; font-size: 0.9rem;">New Monthly
                        Fee (RS)</label>
                    <input type="number" name="monthly_fee" id="edit_monthly_fee" required
                        style="width: 100%; padding: 12px 16px; border-radius: 12px; border: 1px solid #e2e8f0; background: #f8fafc;">
                </div>
                <div style="display: flex; gap: 10px;">
                    <button type="button" onclick="document.getElementById('editModal').style.display='none'"
                        class="btn" style="flex: 1; background: #f1f5f9; color: var(--primary);">Cancel</button>
                    <button type="submit" class="btn btn-primary" style="flex: 1;">Update Now</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Assign Teacher Modal -->
    <div id="assignModal" class="modal glass"
        style="display: none; position: fixed; inset: 0; z-index: 2000; background: rgba(15, 23, 42, 0.4); backdrop-filter: blur(8px); align-items: center; justify-content: center;">
        <div class="animate-slide-up"
            style="background: white; width: 100%; max-width: 400px; margin: 100px auto; border-radius: 20px; padding: 2.5rem; position: relative;">
            <h3 style="font-weight: 800; color: var(--primary); margin-bottom: 1.5rem;">Assign Class Teacher</h3>
            <form action="/admin/classes/assign-teacher" method="POST">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                <input type="hidden" name="class_id" id="assign_class_id">
                <div style="margin-bottom: 2rem;">
                    <label style="display: block; font-weight: 700; margin-bottom: 8px; font-size: 0.9rem;">Select
                        Teacher</label>
                    <select name="teacher_id" id="assign_teacher_id"
                        style="width: 100%; padding: 12px 16px; border-radius: 12px; border: 1px solid #e2e8f0; background: #f8fafc;">
                        <option value="">-- No Teacher Assigned --</option>
                        <% teachers.forEach(t=> { %>
                            <option value="<%= t.id %>">
                                <%= t.full_name %>
                            </option>
                            <% }) %>
                    </select>
                </div>
                <div style="display: flex; gap: 10px;">
                    <button type="button" onclick="document.getElementById('assignModal').style.display='none'"
                        class="btn" style="flex: 1; background: #f1f5f9; color: var(--primary);">Cancel</button>
                    <button type="submit" class="btn btn-primary"
                        style="flex: 1; background: #10b981; border: none;">Assign Now</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function openEditModal(id, currentFee) {
            document.getElementById('edit_class_id').value = id;
            document.getElementById('edit_monthly_fee').value = currentFee;
            document.getElementById('editModal').style.display = 'flex';
        }

        function openAssignModal(classId, currentTeacherId) {
            document.getElementById('assign_class_id').value = classId;
            document.getElementById('assign_teacher_id').value = currentTeacherId || "";
            document.getElementById('assignModal').style.display = 'flex';
        }

        window.onclick = function (event) {
            let addModal = document.getElementById('addModal');
            let editModal = document.getElementById('editModal');
            let assignModal = document.getElementById('assignModal');
            if (event.target == addModal) addModal.style.display = "none";
            if (event.target == editModal) editModal.style.display = "none";
            if (event.target == assignModal) assignModal.style.display = "none";
        }
    </script>
    </body>

    </html>
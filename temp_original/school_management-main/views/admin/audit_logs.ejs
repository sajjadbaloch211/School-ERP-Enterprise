<%- include('../partials/header') %>

    <div class="admin-layout animate-fade-in" style="margin-top: 80px;">
        <!-- Sidebar -->
        <!-- Sidebar -->
        <%- include('../partials/sidebar', { active: 'audit-logs' }) %>

            <!-- Main Content -->
            <main class="main-content">
                <header style="margin-bottom: 3rem;">
                    <h2 style="font-size: 2rem; font-weight: 800; color: var(--primary);">Security Monitoring</h2>
                    <p style="color: var(--text-muted);">Real-time tracking of user logins, locations, and potential
                        threats.</p>
                </header>

                <!-- Stats Grid -->
                <div class="grid"
                    style="grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem; margin-bottom: 3rem;">
                    <div class="card" style="display: flex; align-items: center; gap: 20px;">
                        <div
                            style="width: 60px; height: 60px; background: #e0f2fe; color: #0284c7; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">
                            <i class="fas fa-history"></i>
                        </div>
                        <div>
                            <h3 style="font-size: 2rem; margin: 0; color: var(--primary);">
                                <%= totalCount %>
                            </h3>
                            <p style="color: var(--text-muted); margin: 0;">Total Events</p>
                        </div>
                    </div>

                    <div class="card" style="display: flex; align-items: center; gap: 20px;">
                        <div
                            style="width: 60px; height: 60px; background: #fee2e2; color: #dc2626; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">
                            <i class="fas fa-exclamation-triangle"></i>
                        </div>
                        <div>
                            <h3 style="font-size: 2rem; margin: 0; color: var(--primary);">
                                <%= logs.filter(l=> l.risk_level === 'High' || l.risk_level === 'Medium').length %>
                            </h3>
                            <p style="color: var(--text-muted); margin: 0;">High Risk Alerts</p>
                        </div>
                    </div>

                    <div class="card" style="display: flex; align-items: center; gap: 20px;">
                        <div
                            style="width: 60px; height: 60px; background: #dcfce7; color: #16a34a; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">
                            <i class="fas fa-globe-americas"></i>
                        </div>
                        <div>
                            <% const uniqueIPs=[...new Set(logs.map(item=> item.ip_address))]; %>
                                <h3 style="font-size: 2rem; margin: 0; color: var(--primary);">
                                    <%= uniqueIPs.length %>
                                </h3>
                                <p style="color: var(--text-muted); margin: 0;">Unique IP Sources</p>
                        </div>
                    </div>
                </div>

                <!-- Audit Table -->
                <div class="card" style="padding: 0; overflow: hidden;">
                    <div
                        style="padding: 1.5rem; background: #f8fafc; border-bottom: 1px solid #e2e8f0; display: flex; justify-content: space-between; align-items: center;">
                        <h4 style="margin: 0; font-weight: 800; color: var(--primary);">System Audit Logs</h4>
                        <input type="text" id="logSearch" placeholder="Search logs..."
                            style="padding: 8px 15px; border-radius: 50px; border: 1px solid #cbd5e1; font-size: 0.9rem;"
                            onkeyup="filterTable()">
                    </div>

                    <div style="overflow-x: auto;">
                        <table style="width: 100%; border-collapse: collapse;">
                            <thead>
                                <tr
                                    style="background: #f1f5f9; color: var(--text-muted); text-align: left; font-size: 0.85rem; text-transform: uppercase;">
                                    <th style="padding: 1rem 1.5rem;">Time</th>
                                    <th style="padding: 1rem 1.5rem;">User / ID</th>
                                    <th style="padding: 1rem 1.5rem;">Action</th>
                                    <th style="padding: 1rem 1.5rem;">IP & Location</th>
                                    <th style="padding: 1rem 1.5rem;">Device</th>
                                    <th style="padding: 1rem 1.5rem;">Risk</th>
                                    <th style="padding: 1rem 1.5rem;">Action</th>
                                </tr>
                            </thead>
                            <tbody id="logTableBody">
                                <% logs.forEach(log=> { %>
                                    <tr style="border-bottom: 1px solid #e2e8f0;">
                                        <td
                                            style="padding: 1rem 1.5rem; font-family: monospace; font-weight: 600; color: var(--text-main);">
                                            <%= new Date(log.created_at).toLocaleString() %>
                                        </td>
                                        <td style="padding: 1rem 1.5rem;">
                                            <div style="font-weight: 700; color: var(--primary);">
                                                <%= log.user_id ? 'ID: ' + log.user_id : 'Unknown' %>
                                            </div>
                                            <div style="font-size: 0.8rem; color: var(--text-muted);">
                                                <%= log.role %>
                                            </div>
                                        </td>
                                        <td style="padding: 1rem 1.5rem;">
                                            <span style="font-weight: 600; padding: 4px 10px; border-radius: 6px; font-size: 0.8rem;
                                        background: <%= log.action.includes('FAIL') ? '#fef2f2' : '#ecfdf5' %>;
                                        color: <%= log.action.includes('FAIL') ? '#dc2626' : '#16a34a' %>;">
                                                <%= log.action %>
                                            </span>
                                        </td>
                                        <td style="padding: 1rem 1.5rem;">
                                            <div style="font-weight: 600;">
                                                <%= log.ip_address %>
                                            </div>
                                            <div style="font-size: 0.8rem; color: var(--text-muted);">
                                                <%= log.city %>, <%= log.country %>
                                            </div>
                                        </td>
                                        <td style="padding: 1rem 1.5rem;">
                                            <div style="font-size: 0.9rem;">
                                                <%= log.device %>
                                            </div>
                                            <div style="font-size: 0.75rem; color: var(--text-muted);">
                                                <%= log.os %>
                                            </div>
                                        </td>
                                        <td style="padding: 1rem 1.5rem;">
                                            <span style="
                                        padding: 4px 12px; border-radius: 50px; font-weight: 800; font-size: 0.75rem;
                                        background: <%= log.risk_level === 'High' ? '#ef4444' : (log.risk_level === 'Medium' ? '#f59e0b' : '#10b981') %>;
                                        color: white;">
                                                <%= log.risk_level %>
                                            </span>
                                        </td>
                                        <td style="padding: 1rem 1.5rem;">
                                            <% if(log.latitude && log.longitude) { %>
                                                <button
                                                    onclick="viewMap(<%= log.latitude %>, <%= log.longitude %>, '<%= log.ip_address %>')"
                                                    class="btn" style="padding: 5px 10px; font-size: 0.8rem;">
                                                    <i class="fas fa-map-marker-alt"></i> Map
                                                </button>
                                                <% } else { %>
                                                    <span style="color: var(--text-muted); font-size: 0.8rem;">-</span>
                                                    <% } %>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </main>
    </div>

    <!-- Map Modal -->
    <div id="mapModal" class="modal glass"
        style="display: none; position: fixed; inset: 0; z-index: 2000; background: rgba(0,0,0,0.6); align-items: center; justify-content: center;">
        <div
            style="background: white; width: 90%; max-width: 800px; height: 500px; border-radius: 24px; overflow: hidden; position: relative;">
            <button onclick="document.getElementById('mapModal').style.display='none'"
                style="position: absolute; right: 20px; top: 20px; z-index: 1000; background: white; border: none; padding: 10px; border-radius: 50%; cursor: pointer;">
                <i class="fas fa-times"></i>
            </button>
            <div id="mapContainer" style="width: 100%; height: 100%;"></div>
        </div>
    </div>

    <!-- Leaflet CSS/JS (For Maps) -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.7.1/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.7.1/dist/leaflet.js"></script>

    <script>
        let map = null;

        function viewMap(lat, lng, ip) {
            document.getElementById('mapModal').style.display = 'flex';

            if (map) {
                map.remove(); // Reset map
            }

            setTimeout(() => {
                map = L.map('mapContainer').setView([lat, lng], 13);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    attribution: '&copy; OpenStreetMap contributors'
                }).addTo(map);

                L.marker([lat, lng]).addTo(map)
                    .bindPopup(`<b>IP: ${ip}</b><br>Detected Location`).openPopup();
            }, 100);
        }

        function filterTable() {
            const input = document.getElementById('logSearch');
            const filter = input.value.toLowerCase();
            const tbody = document.getElementById('logTableBody');
            const rows = tbody.getElementsByTagName('tr');

            for (let i = 0; i < rows.length; i++) {
                const row = rows[i];
                const text = row.textContent.toLowerCase();
                row.style.display = text.includes(filter) ? "" : "none";
            }
        }

        // Close modal on outside click
        window.onclick = function (event) {
            if (event.target == document.getElementById('mapModal')) {
                document.getElementById('mapModal').style.display = "none";
            }
        }
    </script>
<%- include('partials/header') %>

    <div class="container my-5">
        <div class="row">
            <div class="col-12 text-center mb-5">
                <h1 class="display-4 fw-bold">Admission Process</h1>
                <p class="lead text-muted">Join our community of learners.</p>
            </div>
        </div>

        <div class="row">
            <div class="col-md-8 mx-auto">
                <div class="card mb-4 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">1. Online Inquiry / Visit</h5>
                        <p class="card-text">Fill out our online inquiry form or visit the school campus to collect the
                            prospectus and admission form.</p>
                    </div>
                </div>
                <div class="card mb-4 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">2. Assessment Test</h5>
                        <p class="card-text">Candidates (Grade 3 onwards) will undergo a basic competency test in
                            Mathematics, English, and General Science.</p>
                    </div>
                </div>
                <div class="card mb-4 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title fw-bold">3. Interview</h5>
                        <p class="card-text">A formal interactive session with the Principal and parents to discuss
                            educational goals.</p>
                    </div>
                </div>
                <div class="card mb-4 shadow-sm border-success">
                    <div class="card-body">
                        <h5 class="card-title fw-bold text-success">4. Documentation & Fee</h5>
                        <p class="card-text">Complete the admission file with required documents and deposit the
                            admission fee.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card bg-light border-0 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title fw-bold mb-3">Required Documents</h5>
                        <ul class="list-unstyled">
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i> Birth Certificate (Copy)
                            </li>
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i> School Leaving Certificate
                            </li>
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i> 4 Recent Photos</li>
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i> CNIC Copy of Parents</li>
                            <li class="mb-2"><i class="fas fa-check text-success me-2"></i> Previous Report Card</li>
                        </ul>
                        <div class="d-grid mt-4">
                            <a href="/contact" class="btn btn-primary">Contact Us</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>

        <header class="hero-section"
            style="min-height: 50vh; background-image: url('/images/classroom_girls.jpg'); align-items: center;">
            <div class="hero-overlay"></div>
            <div class="container hero-content text-center animate-up">
                <h1 class="display-3 fw-bold">Admission <span class="text-accent">Process</span></h1>
                <p class="lead text-white-50 mx-auto" style="max-width: 600px;">
                    Join our community of learners. Follow these simple steps to apply.
                </p>
            </div>
        </header>

        <section class="section-padding bg-light">
            <div class="container">
                <div class="row justify-content-center g-5">
                    <div class="col-lg-8">
                        <!-- Timeline Steps -->
                        <div class="d-flex gap-4 mb-5 animate-up">
                            <div class="flex-shrink-0">
                                <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center border border-4 border-white shadow"
                                    style="width: 60px; height: 60px; font-size: 1.5rem; font-weight: bold;">1</div>
                            </div>
                            <div class="bg-white p-4 rounded-4 shadow-sm flex-grow-1 border">
                                <h4 class="fw-bold mb-2">Online Inquiry / Visit</h4>
                                <p class="text-muted mb-0">Fill out our online inquiry form or visit the school campus
                                    to
                                    collect the prospectus and admission form. Our admission office is open Mon-Sat, 9AM
                                    to
                                    2PM.</p>
                            </div>
                        </div>

                        <div class="d-flex gap-4 mb-5 animate-up delay-100">
                            <div class="flex-shrink-0">
                                <div class="rounded-circle bg-white text-primary d-flex align-items-center justify-content-center border border-4 border-primary shadow"
                                    style="width: 60px; height: 60px; font-size: 1.5rem; font-weight: bold;">2</div>
                            </div>
                            <div class="bg-white p-4 rounded-4 shadow-sm flex-grow-1 border">
                                <h4 class="fw-bold mb-2">Assessment Test</h4>
                                <p class="text-muted mb-0">Candidates (Grade 3 onwards) will undergo a basic competency
                                    test
                                    in Mathematics, English, and General Science. This helps us understand the student's
                                    current standing.</p>
                            </div>
                        </div>

                        <div class="d-flex gap-4 mb-5 animate-up delay-200">
                            <div class="flex-shrink-0">
                                <div class="rounded-circle bg-white text-primary d-flex align-items-center justify-content-center border border-4 border-primary shadow"
                                    style="width: 60px; height: 60px; font-size: 1.5rem; font-weight: bold;">3</div>
                            </div>
                            <div class="bg-white p-4 rounded-4 shadow-sm flex-grow-1 border">
                                <h4 class="fw-bold mb-2">Interview</h4>
                                <p class="text-muted mb-0">A formal interactive session with the Principal and parents
                                    to
                                    discuss educational goals and school policies.</p>
                            </div>
                        </div>

                        <div class="d-flex gap-4 animate-up delay-300">
                            <div class="flex-shrink-0">
                                <div class="rounded-circle bg-success text-white d-flex align-items-center justify-content-center border border-4 border-white shadow"
                                    style="width: 60px; height: 60px; font-size: 1.5rem; font-weight: bold;"><i
                                        class="fas fa-check"></i></div>
                            </div>
                            <div class="bg-white p-4 rounded-4 shadow-sm flex-grow-1 border">
                                <h4 class="fw-bold mb-2">Documentation & Fee</h4>
                                <p class="text-muted mb-0">Upon selection, complete the admission file with required
                                    documents and deposit the admission fee to confirm the seat.</p>
                            </div>
                        </div>

                    </div>

                    <!-- Sidebar -->
                    <div class="col-lg-4">
                        <div class="card border-0 shadow-lg rounded-4 p-4 sticky-top animate-up delay-200"
                            style="top: 100px;">
                            <h4 class="fw-bold mb-4 text-primary">Required Documents</h4>
                            <ul class="list-unstyled">
                                <li class="mb-3 d-flex gap-2">
                                    <i class="fas fa-check-circle text-success mt-1"></i>
                                    <span class="text-muted">Birth Certificate (Copy)</span>
                                </li>
                                <li class="mb-3 d-flex gap-2">
                                    <i class="fas fa-check-circle text-success mt-1"></i>
                                    <span class="text-muted">Previous School Leaving Certificate</span>
                                </li>
                                <li class="mb-3 d-flex gap-2">
                                    <i class="fas fa-check-circle text-success mt-1"></i>
                                    <span class="text-muted">4 Recent Passport Size Photos</span>
                                </li>
                                <li class="mb-3 d-flex gap-2">
                                    <i class="fas fa-check-circle text-success mt-1"></i>
                                    <span class="text-muted">CNIC Copy of Parents/Guardian</span>
                                </li>
                                <li class="mb-3 d-flex gap-2">
                                    <i class="fas fa-check-circle text-success mt-1"></i>
                                    <span class="text-muted">Previous Report Card</span>
                                </li>
                            </ul>
                            <hr>
                            <div class="text-center mt-3">
                                <p class="small text-muted mb-3">Ready to apply?</p>
                                <a href="/contact" class="btn btn-login w-100">Contact Us Now</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <%- include('partials/frontend_footer') %>
<footer class="footer">
    <div class="container">
        <div class="row g-5">
            <!-- School Info -->
            <div class="col-lg-4 col-md-6">
                <div class="d-flex align-items-center gap-3 mb-4">
                    <img src="<%= (typeof settings !== 'undefined' && settings.site_logo) ? settings.site_logo : '/images/waqar.png' %>"
                        alt="Logo" style="height: 50px; background: white; padding: 5px; border-radius: 8px;">
                    <h5 class="text-white mb-0 fw-bold">
                        <%= (typeof settings !=='undefined' && settings.site_name) ? settings.site_name
                            : 'Waqar Public Higher Secondary School' %>
                    </h5>
                </div>
                <p class="text-white-50 mb-4">
                    Providing quality education and nurturing future leaders since 1995. We are committed to academic
                    excellence and character building.
                </p>
                <div class="d-flex gap-2">
                    <a href="<%= (typeof settings !== 'undefined' && settings.social_facebook) ? settings.social_facebook : '#' %>"
                        class="social-icon"><i class="fab fa-facebook-f"></i></a>
                    <a href="<%= (typeof settings !== 'undefined' && settings.social_twitter) ? settings.social_twitter : '#' %>"
                        class="social-icon"><i class="fab fa-twitter"></i></a>
                    <a href="<%= (typeof settings !== 'undefined' && settings.social_instagram) ? settings.social_instagram : '#' %>"
                        class="social-icon"><i class="fab fa-instagram"></i></a>
                </div>
            </div>

            <!-- Quick Links -->
            <div class="col-lg-2 col-md-6">
                <h5 class="footer-heading">Quick Links</h5>
                <ul class="list-unstyled">
                    <% if (typeof footerMenu !=='undefined' && footerMenu && footerMenu.length> 0) { %>
                        <% footerMenu.forEach(item=> { %>
                            <li><a href="<%= item.url %>" class="footer-link">
                                    <%= item.label %>
                                </a></li>
                            <% }); %>
                                <% } else { %>
                                    <li><a href="/" class="footer-link">Home</a></li>
                                    <li><a href="/about" class="footer-link">About Us</a></li>
                                    <li><a href="/admissions" class="footer-link">Admissions</a></li>
                                    <li><a href="/gallery" class="footer-link">Gallery</a></li>
                                    <li><a href="/contact" class="footer-link">Contact</a></li>
                                    <% } %>
                </ul>
            </div>

            <!-- Contact Info -->
            <div class="col-lg-3 col-md-6">
                <h5 class="footer-heading">Contact Us</h5>
                <ul class="list-unstyled text-white-50">
                    <li class="mb-3 d-flex gap-3">
                        <i class="fas fa-map-marker-alt mt-1 text-primary"></i>
                        <span>
                            <%= (typeof settings !=='undefined' && settings.school_address) ? settings.school_address
                                : "Main Road, Khairpur Mir's, Sindh, Pakistan" %>
                        </span>
                    </li>
                    <li class="mb-3 d-flex gap-3">
                        <i class="fas fa-phone-alt mt-1 text-primary"></i>
                        <span>
                            <%= (typeof settings !=='undefined' && settings.school_phone) ? settings.school_phone
                                : "+92 123 4567890" %>
                        </span>
                    </li>
                    <li class="mb-3 d-flex gap-3">
                        <i class="fas fa-envelope mt-1 text-primary"></i>
                        <span>
                            <%= (typeof settings !=='undefined' && settings.school_email) ? settings.school_email
                                : "info@waqar.edu.pk" %>
                        </span>
                    </li>
                </ul>
            </div>

            <!-- Newsletter (Optional) -->
            <div class="col-lg-3 col-md-6">
                <h5 class="footer-heading">Stay Updated</h5>
                <p class="text-white-50 mb-3">Subscribe to our newsletter for latest updates.</p>
                <form class="position-relative">
                    <input type="email" class="form-control rounded-pill py-2 ps-4 pe-5" placeholder="Enter your email"
                        style="background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); color: white;">
                    <button type="button"
                        class="btn btn-primary rounded-circle position-absolute end-0 top-0 m-1 d-flex align-items-center justify-content-center"
                        style="width: 38px; height: 38px;">
                        <i class="fas fa-paper-plane text-white" style="font-size: 0.8rem;"></i>
                    </button>
                </form>
            </div>
        </div>

        <div class="border-top border-secondary border-opacity-25 mt-5 pt-4 text-center">
            <p class="mb-0 text-white-50 small">
                &copy; <%= new Date().getFullYear() %>
                    <%= (typeof settings !=='undefined' && settings.site_name) ? settings.site_name
                        : 'Waqar Public Higher Secondary School' %>. All Rights Reserved.
            </p>
        </div>
    </div>
</footer>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<!-- Navbar Scroll Effect -->
<script>
    window.addEventListener('scroll', function () {
        if (window.scrollY > 50) {
            document.getElementById('mainNav').classList.add('scrolled');
        } else {
            document.getElementById('mainNav').classList.remove('scrolled');
        }
    });
</script>
</body>

</html>
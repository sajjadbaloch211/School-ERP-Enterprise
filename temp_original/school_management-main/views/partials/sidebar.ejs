        <li><a href="/admin/fees" class="<%= typeof active !== 'undefined' && active === 'fees' ? 'active' : '' %>"><i
                    class="fas fa-file-invoice-dollar"></i> Fees</a></li>
        <li><a href="/admin/payroll"

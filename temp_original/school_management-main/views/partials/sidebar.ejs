                    class="fas fa-bullhorn"></i> Notices</a></li>
        <li><a href="/admin/email" class="<%= typeof active !== 'undefined' && active === 'email' ? 'active' : '' %>"><i
                    class="fas fa-envelope"></i> Email</a></li>
        <li><a href="/admin/library"

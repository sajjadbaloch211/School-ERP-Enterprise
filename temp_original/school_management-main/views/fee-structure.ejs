                    <div class="card-header bg-primary text-white py-3">
                        <h4 class="my-0 fw-normal">Higher Secondary</h4>
                    </div>
                    <div class="card-body">
                        <h1 class="card-title pricing-card-title">Rs. 3,500 <small class="text-muted">/ mo</small></h1>
                        <ul class="list-unstyled mt-3 mb-4">
                            <li>Grade 11 - 12</li>
                            <li>Pre-Medical / Pre-Engr</li>
                            <li>Career Counseling</li>
                            <li>College Prep</li>
                        </ul>
                        <a href="/admissions" class="w-100 btn btn-lg btn-outline-primary">Apply Now</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mt-4">
            <div class="col-12 text-center text-muted">
                <p class="small">* Additional Annual Charges apply. Admission Fee is one-time only.</p>
            </div>
        </div>
    </div>

    <%- include('partials/footer') %>


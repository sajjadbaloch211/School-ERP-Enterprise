                    <div class="card-header bg-primary text-white py-3">
                        <h4 class="my-0 fw-normal">Primary Wing</h4>
                    </div>
                    <div class="card-body">
                        <h1 class="card-title pricing-card-title">Rs. 1,500 <small class="text-muted">/ mo</small></h1>
                        <ul class="list-unstyled mt-3 mb-4">
                            <li>Grade 1 - 5</li>
                            <li>Qualified Teachers</li>
                            <li>Activity Based Learning</li>
                            <li>Sports & Arts</li>
                        </ul>
                        <a href="/admissions" class="w-100 btn btn-lg btn-outline-primary">Apply Now</a>
                    </div>
                </div>
            </div>

            <!-- Secondary -->
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-lg border-primary text-center">
                    <div class="card-header bg-dark text-white py-3">
                        <h4 class="my-0 fw-normal">Secondary Wing</h4>
                    </div>
                    <div class="card-body">
                        <h1 class="card-title pricing-card-title">Rs. 2,500 <small class="text-muted">/ mo</small></h1>
                        <ul class="list-unstyled mt-3 mb-4">
                            <li>Grade 6 - 10</li>
                            <li>Science Labs Access</li>
                            <li>Computer Education</li>
                            <li>Exam Preparation</li>
                        </ul>
                        <a href="/admissions" class="w-100 btn btn-lg btn-primary">Apply Now</a>
                    </div>
                </div>
            </div>

            <!-- Higher Secondary -->
            <div class="col-md-4 mb-4">

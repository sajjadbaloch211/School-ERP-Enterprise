<%- include('partials/frontend_header', {isHomepage: true}) %>

<!-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
     HERO SECTION вЂ” Full Screen Cinematic
в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ -->
<section class="hero-wphss" id="home"
    <% if(typeof settings !== 'undefined' && settings.hero_image) { %>
        style="background-image: url('<%= settings.hero_image %>'); background-size: cover; background-position: center;"
    <% } %>
>
    <!-- Geometric decorative circles -->
    <div class="hero-shape-1"></div>
    <div class="hero-shape-2"></div>
    <div class="hero-shape-3"></div>

    <div class="hero-content-wrap">
        <div class="container">
            <div class="hero-inner">

                <!-- Welcome badge -->
                <div class="hero-badge-pill">
                    <span class="dot"></span>
                    <%= (typeof settings !=='undefined' && settings.hero_badge) ? settings.hero_badge : 'Welcome to WPHSS' %>
                </div>

                <!-- Main heading -->
                <h1 class="hero-title">
                    <% const heroTitle = (typeof settings !=='undefined' && settings.hero_title) ? settings.hero_title : 'Excellence in Education'; %>
                    <%= heroTitle %>
                </h1>

                <!-- Subheading -->
                <p class="hero-sub">
                    <%= (typeof settings !=='undefined' && settings.hero_desc) ? settings.hero_desc : "Empowering students since 1995 through holistic, values-driven learning. Shaping tomorrow's leaders with discipline, excellence, and innovation." %>
                </p>

                <!-- CTA Buttons -->
                <div class="hero-ctas">
                    <% if(typeof user !=='undefined' && user) { %>
                        <a href="/<%= user.role %>/dashboard" class="btn-primary-wphss">
                            <i class="fas fa-th-large"></i> Go to Dashboard
                        </a>
                    <% } else { %>
                        <a href="/login" class="btn-primary-wphss">
                            <i class="fas fa-lock"></i> Login Portal
                        </a>
                        <a href="/admissions" class="btn-outline-white">
                            <i class="fas fa-graduation-cap"></i> Apply Now
                        </a>
                    <% } %>
                </div>

                <!-- Floating stats bar -->
                <div class="hero-stats-bar">
                    <div class="hero-stat-item">
                        <span class="hero-stat-num">2000+</span>
                        <span class="hero-stat-label">Students</span>
                    </div>
                    <div class="hero-stat-item">
                        <span class="hero-stat-num">150+</span>
                        <span class="hero-stat-label">Faculty</span>
                    </div>
                    <div class="hero-stat-item">
                        <span class="hero-stat-num">98%</span>
                        <span class="hero-stat-label">Pass Rate</span>
                    </div>
                    <div class="hero-stat-item">
                        <span class="hero-stat-num">25+</span>
                        <span class="hero-stat-label">Years</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
     NOTICE TICKER
в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ -->
<% if (typeof notices !=='undefined' && notices && notices.length > 0) { %>
<div class="notice-ticker">
    <div class="container">
        <div class="ticker-inner">
            <span class="ticker-label"><i class="fas fa-bullhorn" style="margin-right:6px"></i>News</span>
            <div class="ticker-content">
                <div class="ticker-track">
                    <% notices.forEach(notice => { %>
                        <span><i class="fas fa-circle" style="font-size:0.4rem;vertical-align:middle"></i> <strong><%= notice.title %>:</strong> <%= notice.content.substring(0,80) %>...</span>
                    <% }); %>
                    <%# duplicate for seamless loop %>
                    <% notices.forEach(notice => { %>
                        <span><i class="fas fa-circle" style="font-size:0.4rem;vertical-align:middle"></i> <strong><%= notice.title %>:</strong> <%= notice.content.substring(0,80) %>...</span>
                    <% }); %>
                </div>
            </div>
        </div>
    </div>
</div>
<% } %>

<!-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
     STATS / HIGHLIGHTS BAR
в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ -->
<section class="stats-section" id="highlights">
    <div class="container">
        <div class="stats-grid">
            <div class="stat-card reveal">
                <div class="stat-icon"><i class="fas fa-user-graduate"></i></div>
                <span class="stat-num counter" data-target="2000">0</span>+
                <span class="stat-label">Students Enrolled</span>
            </div>
            <div class="stat-card reveal delay-100">
                <div class="stat-icon"><i class="fas fa-chalkboard-teacher"></i></div>
                <span class="stat-num counter" data-target="150">0</span>+
                <span class="stat-label">Expert Faculty</span>
            </div>
            <div class="stat-card reveal delay-200">
                <div class="stat-icon"><i class="fas fa-trophy"></i></div>
                <span class="stat-num counter" data-target="98">0</span>%
                <span class="stat-label">Pass Rate</span>
            </div>
            <div class="stat-card reveal delay-300">
                <div class="stat-icon"><i class="fas fa-calendar-alt"></i></div>
                <span class="stat-num counter" data-target="25">0</span>+
                <span class="stat-label">Years of Legacy</span>
            </div>
        </div>
    </div>
</section>

<!-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
     ABOUT SECTION вЂ” Split Layout
в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ -->
<section class="about-section" id="about">
    <div class="container">
        <div class="row align-items-center g-5">

            <!-- Left: Image with Gold Frame -->
            <div class="col-lg-5 reveal-left">
                <div class="about-image-wrap">
                    <div class="about-image-frame">
                        <img src="/images/waqar.png"
                             alt="WPHSS School Building"
                             style="width:100%;height:420px;object-fit:contain;background:linear-gradient(135deg,#f0f4ff,#e8ecf8);padding:40px;">
                    </div>
                    <div class="about-years-badge">
                        <span class="num">25+</span>
                        <span class="lbl">Years of<br>Excellence</span>
                    </div>
                </div>
            </div>

            <!-- Right: Text Content -->
            <div class="col-lg-7 reveal-right">
                <span class="overline">Our Story</span>
                <h2 class="section-heading">
                    Shaping Minds,<br>Building <span style="color:var(--gold)">Futures</span>
                </h2>
                <span class="gold-line"></span>

                <p style="margin-bottom:16px;">
                    <%= (typeof settings !=='undefined' && settings.about_text1) ? settings.about_text1 : 'W.P. Higher Secondary School has been a cornerstone of academic excellence in the region since 1995. Founded with a vision to provide world-class education accessible to all, we have grown into an institution recognized for discipline, results, and character.' %>
                </p>
                <p style="margin-bottom:16px;">
                    <%= (typeof settings !=='undefined' && settings.about_text2) ? settings.about_text2 : 'Our faculty comprises highly qualified professionals who bring passion and expertise to every classroom. We believe education goes beyond textbooks вЂ” it is about nurturing curiosity, resilience, and a lifelong love of learning.' %>
                </p>
                <p style="margin-bottom:28px;">
                    <%= (typeof settings !=='undefined' && settings.about_text3) ? settings.about_text3 : 'From matriculation to higher secondary level, we offer a rigorous curriculum aligned with national standards while incorporating modern pedagogical approaches that prepare students for university and beyond.' %>
                </p>

                <!-- Feature pills -->
                <div class="feature-pills">
                    <span class="feature-pill"><i class="fas fa-shield-alt"></i> Discipline First</span>
                    <span class="feature-pill"><i class="fas fa-star"></i> Academic Excellence</span>
                    <span class="feature-pill"><i class="fas fa-lightbulb"></i> Innovation</span>
                    <span class="feature-pill"><i class="fas fa-heart"></i> Values-Driven</span>
                </div>

                <div style="margin-top:36px;">
                    <a href="/about" class="btn-primary-wphss">
                        <i class="fas fa-arrow-right"></i> Learn More About Us
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
     ACADEMICS / DEPARTMENTS SECTION
в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ -->
<section class="academics-section" id="academics">
    <div class="dot-bg"></div>
    <div class="container" style="position:relative;z-index:1;">
        <div class="text-center reveal" style="margin-bottom:52px;">
            <span class="overline">What We Offer</span>
            <h2 class="section-heading">Our Academic <span style="color:var(--gold)">Departments</span></h2>
            <span class="gold-line center"></span>
            <p class="section-desc mx-auto">A well-rounded curriculum spanning sciences, humanities, and commerce вЂ” designed to unlock every student's potential.</p>
        </div>

        <div class="dept-grid">
            <div class="dept-card reveal delay-100">
                <div class="dept-icon"><i class="fas fa-flask"></i></div>
                <h4>Sciences</h4>
                <p>Physics, Chemistry, Biology & Mathematics taught by expert faculty with modern lab facilities.</p>
            </div>
            <div class="dept-card reveal delay-200">
                <div class="dept-icon"><i class="fas fa-calculator"></i></div>
                <h4>Commerce</h4>
                <p>Accounting, Economics, and Business Studies preparing students for careers in finance and management.</p>
            </div>
            <div class="dept-card reveal delay-300">
                <div class="dept-icon"><i class="fas fa-book-open"></i></div>
                <h4>Humanities</h4>
                <p>Urdu, English, History, and Islamic Studies fostering critical thinking and cultural understanding.</p>
            </div>
            <div class="dept-card reveal delay-100">
                <div class="dept-icon"><i class="fas fa-laptop-code"></i></div>
                <h4>Computer Science</h4>
                <p>Programming, IT fundamentals, and digital literacy for the modern technological landscape.</p>
            </div>
            <div class="dept-card reveal delay-200">
                <div class="dept-icon"><i class="fas fa-running"></i></div>
                <h4>Sports & PE</h4>
                <p>Cricket, football, athletics, and physical education to build a healthy, disciplined generation.</p>
            </div>
            <div class="dept-card reveal delay-300">
                <div class="dept-icon"><i class="fas fa-palette"></i></div>
                <h4>Arts & Culture</h4>
                <p>Fine arts, Nasheeds, debates, and drama fostering creativity and self-expression.</p>
            </div>
        </div>
    </div>
</section>

<!-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
     ADMISSIONS вЂ” TIMELINE SECTION
в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ -->
<section class="admissions-section" id="admissions">
    <div class="container">
        <div class="text-center reveal" style="margin-bottom:8px;">
            <span class="overline">Join Our Family</span>
            <h2 class="section-heading">Admission <span style="color:var(--gold)">Process</span></h2>
            <span class="gold-line center"></span>
            <p class="section-desc mx-auto">Simple, transparent, and merit-based. Follow these steps to secure your seat at WPHSS.</p>
        </div>

        <div class="timeline-steps">
            <div class="timeline-step reveal delay-100">
                <div class="step-circle">1</div>
                <div class="step-title">Online Apply</div>
                <div class="step-desc">Fill out the admission form online or visit the office</div>
            </div>
            <div class="timeline-step reveal delay-200">
                <div class="step-circle">2</div>
                <div class="step-title">Documents</div>
                <div class="step-desc">Submit result cards, B-form & passport photos</div>
            </div>
            <div class="timeline-step reveal delay-300">
                <div class="step-circle">3</div>
                <div class="step-title">Entry Test</div>
                <div class="step-desc">Appear for the merit assessment test</div>
            </div>
            <div class="timeline-step reveal delay-400">
                <div class="step-circle">4</div>
                <div class="step-title">Merit List</div>
                <div class="step-desc">Check announced merit list on website & notice board</div>
            </div>
            <div class="timeline-step reveal delay-500">
                <div class="step-circle">5</div>
                <div class="step-title">Enrollment</div>
                <div class="step-desc">Complete fee payment and receive your school ID</div>
            </div>
        </div>

        <div class="text-center reveal">
            <a href="/admissions" class="btn-gold" style="font-size:1rem;padding:16px 44px;">
                <i class="fas fa-graduation-cap"></i> Start Your Application
            </a>
        </div>
    </div>
</section>

<!-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
     FEE STRUCTURE вЂ” PRICING CARDS
в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ -->
<section class="fees-section" id="fees">
    <div class="container">
        <div class="text-center reveal" style="margin-bottom:8px;">
            <span class="overline">Transparent Pricing</span>
            <h2 class="section-heading">Fee <span style="color:var(--gold)">Structure</span></h2>
            <span class="gold-line center"></span>
            <p class="section-desc mx-auto">Affordable, class-wise monthly fees. No hidden charges. Financial assistance available for deserving students.</p>
        </div>

        <div class="fee-cards-grid">
            <div class="fee-card reveal delay-100">
                <div class="fee-icon"><i class="fas fa-seedling"></i></div>
                <h3>Primary</h3>
                <span class="fee-amount">Rs. 800</span>
                <span class="fee-label">/ per month</span>
                <hr class="fee-divider">
                <ul class="fee-features">
                    <li><i class="fas fa-check"></i> Classes 1 вЂ“ 5</li>
                    <li><i class="fas fa-check"></i> Core subjects included</li>
                    <li><i class="fas fa-check"></i> Library access</li>
                </ul>
            </div>

            <div class="fee-card reveal delay-200">
                <div class="fee-icon"><i class="fas fa-book"></i></div>
                <h3>Middle</h3>
                <span class="fee-amount">Rs. 1,200</span>
                <span class="fee-label">/ per month</span>
                <hr class="fee-divider">
                <ul class="fee-features">
                    <li><i class="fas fa-check"></i> Classes 6 вЂ“ 8</li>
                    <li><i class="fas fa-check"></i> Lab sessions</li>
                    <li><i class="fas fa-check"></i> Extra-curricular</li>
                </ul>
            </div>

            <div class="fee-card featured reveal delay-300">
                <div class="fee-featured-badge">Most Popular</div>
                <div class="fee-icon"><i class="fas fa-graduation-cap"></i></div>
                <h3>Secondary</h3>
                <span class="fee-amount">Rs. 1,800</span>
                <span class="fee-label">/ per month</span>
                <hr class="fee-divider">
                <ul class="fee-features">
                    <li><i class="fas fa-check"></i> Classes 9 вЂ“ 10 (Matric)</li>
                    <li><i class="fas fa-check"></i> Science & Commerce</li>
                    <li><i class="fas fa-check"></i> Full lab access</li>
                    <li><i class="fas fa-check"></i> Exam prep support</li>
                </ul>
            </div>

            <div class="fee-card reveal delay-400">
                <div class="fee-icon"><i class="fas fa-university"></i></div>
                <h3>Higher Sec.</h3>
                <span class="fee-amount">Rs. 2,500</span>
                <span class="fee-label">/ per month</span>
                <hr class="fee-divider">
                <ul class="fee-features">
                    <li><i class="fas fa-check"></i> Classes 11 вЂ“ 12 (FSc/FA)</li>
                    <li><i class="fas fa-check"></i> University prep</li>
                    <li><i class="fas fa-check"></i> Career counselling</li>
                </ul>
            </div>
        </div>

        <div class="text-center reveal" style="margin-top:40px;">
            <a href="/fee-structure" class="btn-outline-gold" style="font-size:0.92rem;">
                <i class="fas fa-file-alt"></i> View Detailed Fee Structure
            </a>
        </div>
    </div>
</section>

<!-- в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
     GALLERY вЂ” MASONRY GRID
в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ -->
<section class="gallery-section" id="gallery">
    <div class="container">
        <div class="text-center reveal" style="margin-bottom:8px;">

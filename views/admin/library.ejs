<%- include('../partials/header') %>

    <div class="admin-layout animate-fade-in" style="margin-top: 80px;">
        <!-- Sidebar -->
        <!-- Sidebar -->
        <%- include('../partials/sidebar', { active: 'library' }) %>

            <!-- Main Content -->
            <main class="main-content">
                <header
                    style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 3rem;">
                    <div>
                        <h2 style="font-size: 2rem; font-weight: 800; color: var(--primary);">Digital Library</h2>
                        <p style="color: var(--text-muted);">Manage e-books and study materials</p>
                    </div>
                    <!-- Changed to Link -->
                    <a href="/admin/library/add" class="btn-primary"
                        style="text-decoration: none; padding: 12px 25px; border-radius: 50px; display: flex; align-items: center; gap: 10px;">
                        <i class="fas fa-cloud-upload-alt"></i> Upload Resource
                    </a>
                </header>

                <!-- Stats -->
                <div class="stat-group animate-slide-up" style="margin-bottom: 2rem;">
                    <div class="stat-card card">
                        <div class="stat-icon" style="background: rgba(59, 130, 246, 0.1); color: var(--accent);">
                            <i class="fas fa-book"></i>
                        </div>
                        <div>
                            <p
                                style="color: var(--text-muted); font-size: 0.9rem; font-weight: 600; text-transform: uppercase;">
                                Total Books</p>
                            <h3 style="font-size: 2rem; font-weight: 800; color: var(--primary);">
                                <%= books.length %>
                            </h3>
                        </div>
                    </div>
                </div>

                <!-- Books Grid -->
                <div class="grid animate-slide-up"
                    style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem;">
                    <% books.forEach(book=> { %>
                        <div class="card"
                            style="padding: 1.5rem; position: relative; border-radius: 16px; transition: var(--transition);">
                            <div
                                style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem;">
                                <% let icon='fa-file-alt' ; let color='#64748b' ; if(book.file_type==='pdf' ) {
                                    icon='fa-file-pdf' ; color='#ef4444' ; } else if(book.file_type==='word' ) {
                                    icon='fa-file-word' ; color='#3b82f6' ; } else if(book.file_type==='image' ) {
                                    icon='fa-file-image' ; color='#10b981' ; } else if(book.file_type==='video' ) {
                                    icon='fa-file-video' ; color='#8b5cf6' ; } else if(book.file_type==='archive' ) {
                                    icon='fa-file-archive' ; color='#f59e0b' ; } %>
                                    <div
                                        style="width: 50px; height: 50px; border-radius: 12px; background: <%= color %>15; color: <%= color %>; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">
                                        <i class="fas <%= icon %>"></i>
                                    </div>
                                    <a href="/admin/library/delete/<%= book.id %>"
                                        onclick="return confirm('Delete this book?')"
                                        style="color: var(--danger); background: rgba(239,68,68,0.1); padding: 8px; border-radius: 8px;">
                                        <i class="fas fa-trash"></i>
                                    </a>
                            </div>
                            <h4 style="font-weight: 700; color: var(--primary); margin-bottom: 0.25rem;">
                                <%= book.title %>
                            </h4>
                            <p style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 0.5rem;">
                                <i class="fas fa-tag"></i>
                                <%= book.subject %>
                            </p>
                            <% if (typeof isSuperAdmin !=='undefined' && isSuperAdmin && book.campus_name) { %>
                                <div style="margin-bottom: 1rem;">
                                    <span
                                        style="font-size: 0.75rem; font-weight: 700; color: #6366f1; background: #e0e7ff; padding: 4px 10px; border-radius: 50px; border: 1px solid #c7d2fe;">
                                        <i class="fas fa-building"></i>
                                        <%= book.campus_name %>
                                    </span>
                                </div>
                                <% } %>
                                    <div style="margin-bottom: 1rem; display: flex; flex-wrap: wrap; gap: 5px;">
                                        <span
                                            style="font-size: 0.75rem; font-weight: 700; color: #3b82f6; background: #eff6ff; padding: 4px 10px; border-radius: 50px; border: 1px solid #dbeafe;">
                                            <i class="fas fa-users"></i> Target: <%= book.target_grade || 'General' %>
                                        </span>
                                        <span
                                            style="font-size: 0.75rem; font-weight: 700; color: #10b981; background: #ecfdf5; padding: 4px 10px; border-radius: 50px; border: 1px solid #d1fae5;">
                                            <i class="fas fa-eye"></i> For: <%= String(book.visibility || 'both'
                                                ).toUpperCase() %>
                                        </span>
                                    </div>

                                    <div style="display: flex; gap: 8px; margin-top: 1rem;">
                                        <a href="<%= book.file_path %>" target="_blank" class="btn"
                                            style="flex: 1; text-align: center; background: #f8fafc; color: var(--primary); font-weight: 600; padding: 8px; border: 1px solid #e2e8f0; font-size: 0.8rem; text-decoration: none; border-radius: 8px;">
                                            <i class="fas fa-eye"></i> View
                                        </a>
                                        <a href="<%= book.file_path %>" download="<%= book.title %>" class="btn"
                                            style="flex: 1; text-align: center; background: var(--accent); color: white; font-weight: 600; padding: 8px; border: none; font-size: 0.8rem; text-decoration: none; border-radius: 8px;">
                                            <i class="fas fa-download"></i> Download
                                        </a>
                                    </div>
                        </div>
                        <% }); %>
                            <% if (books.length===0) { %>
                                <div
                                    style="grid-column: 1/-1; text-align: center; padding: 3rem; color: var(--text-muted);">
                                    <i class="fas fa-book-open" style="font-size: 3rem; opacity: 0.5;"></i>
                                    <p style="margin-top: 1rem;">No books found in the library.</p>
                                </div>
                                <% } %>
                </div>

            </main>
    </div>

    <!-- No Modal Needed Anymore -->

    <%- include('../partials/footer') %>
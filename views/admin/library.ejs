<%- include('../partials/header') %>

  <!-- ════════════════════════════════════════════════════════════
       ADMIN LAYOUT
       ════════════════════════════════════════════════════════════ -->
  <div class="adm-layout">

    <!-- Sidebar -->
    <%- include('../partials/sidebar', { active: 'library' }) %>

    <!-- ══ MAIN CONTENT ══════════════════════════════════════════ -->
    <main class="adm-main" role="main" aria-label="Digital Library Management">

      <!-- ── Page Header ── -->
      <div class="adm-page-header">
        <div>
          <h1 class="adm-page-title">Digital Library</h1>
          <p class="adm-page-subtitle">Manage e-books, study materials, and academic resources.</p>
        </div>
        <div>
          <a href="/admin/library/add" class="adm-btn adm-btn-primary" style="text-decoration: none;">
            <i class="fas fa-cloud-upload-alt" aria-hidden="true"></i> Upload Resource
          </a>
        </div>
      </div>

      <!-- ── KPI Cards ── -->
      <div style="margin-bottom: 2rem;">
        <article class="adm-kpi-card" style="border-left-color: var(--adm-indigo); max-width: 320px;">
          <div class="adm-kpi-icon" style="background: var(--adm-indigo-bg); color: var(--adm-indigo);">
            <i class="fas fa-book-open" aria-hidden="true"></i>
          </div>
          <div class="adm-kpi-content">
            <h3 class="adm-kpi-title">Total Resources</h3>
            <div class="adm-kpi-value" data-target="<%= books.length %>">
              <%= books.length %>
            </div>
          </div>
        </article>
      </div>

      <!-- ── Books Grid ── -->
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem;">
        
        <% if (books.length === 0) { %>
          <div style="grid-column: 1 / -1; padding: 4.5rem; text-align: center; color: var(--adm-text-muted); background: var(--adm-bg-surface); border-radius: var(--adm-r-lg); border: 1px dashed var(--adm-border);">
            <i class="fas fa-books" style="font-size: 3rem; opacity: 0.25; display: block; margin-bottom: 1rem;" aria-hidden="true"></i>
            <h3 style="color: var(--adm-text-primary); font-weight: 700; margin-bottom: 0.5rem;">Library Empty</h3>
            <p>Click "Upload Resource" to add your first study material.</p>
          </div>
        <% } %>

        <% books.forEach(book => { %>
          <article class="adm-card" style="padding: 1.5rem; display: flex; flex-direction: column;">
            
            <!-- Header Icon & Delete -->
            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem;">
              
              <% 
                let icon = 'fa-file-alt'; 
                let iconBg = 'var(--adm-bg-elevated)';
                let iconColor = 'var(--adm-text-muted)';
                
                if (book.file_type === 'pdf') { icon = 'fa-file-pdf'; iconBg = 'var(--adm-red-bg)'; iconColor = 'var(--adm-red)'; } 
                else if (book.file_type === 'word') { icon = 'fa-file-word'; iconBg = 'var(--adm-blue-bg)'; iconColor = 'var(--adm-blue)'; } 
                else if (book.file_type === 'image') { icon = 'fa-file-image'; iconBg = 'var(--adm-green-bg)'; iconColor = 'var(--adm-green)'; } 
                else if (book.file_type === 'video') { icon = 'fa-file-video'; iconBg = 'var(--adm-indigo-bg)'; iconColor = 'var(--adm-indigo)'; } 
                else if (book.file_type === 'archive') { icon = 'fa-file-archive'; iconBg = 'var(--adm-amber-bg)'; iconColor = 'var(--adm-amber)'; } 
              %>
              
              <div class="adm-avatar" style="width: 48px; height: 48px; border-radius: var(--adm-r-md); background: <%= iconBg %>; color: <%= iconColor %>; font-size: 1.5rem;">
                <i class="fas <%= icon %>" aria-hidden="true"></i>
              </div>
              
              <a href="/admin/library/delete/<%= book.id %>" onclick="return confirm('Permanently delete this resource from the library?')" class="adm-btn adm-btn-ghost adm-btn-danger" style="padding: 0.5rem; margin: -0.5rem;" aria-label="Delete Resource">
                <i class="fas fa-trash-alt" aria-hidden="true"></i>
              </a>
            </div>

            <!-- Title & Subject -->
            <h3 style="font-size: 1.15rem; font-weight: 800; color: var(--adm-text-primary); margin-bottom: 0.25rem;">
              <%= book.title %>
            </h3>
            <p style="color: var(--adm-text-muted); font-size: 0.9rem; margin-bottom: 1rem; font-weight: 600;">
              <i class="fas fa-tag" aria-hidden="true" style="margin-right: 0.25rem;"></i> <%= book.subject %>
            </p>

            <!-- Metadata Badges -->
            <div style="margin-bottom: 1.5rem; display: flex; flex-wrap: wrap; gap: 0.5rem; flex-grow: 1;">
              
              <% if (typeof isSuperAdmin !== 'undefined' && isSuperAdmin && book.campus_name) { %>
                <span class="adm-badge adm-badge-blue" style="font-size: 0.7rem;">
                  <i class="fas fa-building" aria-hidden="true" style="margin-right: 0.25rem;"></i> <%= book.campus_name %>
                </span>
              <% } %>
              
              <span class="adm-badge adm-badge-amber" style="font-size: 0.7rem;">
                <i class="fas fa-users" aria-hidden="true" style="margin-right: 0.25rem;"></i> Grade: <%= book.target_grade || 'General' %>
              </span>
              
              <span class="adm-badge adm-badge-green" style="font-size: 0.7rem;">
                <i class="fas fa-eye" aria-hidden="true" style="margin-right: 0.25rem;"></i> For: <%= String(book.visibility || 'both').toUpperCase() %>
              </span>
            </div>

            <!-- Action Buttons -->
            <div style="display: flex; gap: 0.75rem; border-top: 1px solid var(--adm-border); padding-top: 1rem;">
              <a href="<%= book.file_path %>" target="_blank" class="adm-btn adm-btn-ghost" style="flex: 1; justify-content: center; background: var(--adm-bg-elevated); border: 1px solid var(--adm-border); text-decoration: none;">
                <i class="fas fa-external-link-alt" aria-hidden="true"></i> View
              </a>
              <a href="<%= book.file_path %>" download="<%= book.title %>" class="adm-btn adm-btn-primary" style="flex: 1; justify-content: center; text-decoration: none;">
                <i class="fas fa-download" aria-hidden="true"></i> DL
              </a>
            </div>

          </article>
        <% }); %>

      </div>
    </main>
  </div>

<%- include('../partials/footer') %>
<%- include('../partials/header') %>

  <!-- ════════════════════════════════════════════════════════════
       ADMIN LAYOUT
       ════════════════════════════════════════════════════════════ -->
  <div class="adm-layout">

    <!-- Sidebar -->
    <%- include('../partials/sidebar', { active: 'teachers' }) %>

    <!-- ══ MAIN CONTENT ══════════════════════════════════════════ -->
    <main class="adm-main" role="main" aria-label="Faculty management">

      <!-- ── Page Header ── -->
      <div class="adm-page-header">
        <div>
          <h1 class="adm-page-title">Faculty Management</h1>
          <p class="adm-page-subtitle">Manage your expert teaching staff and academic specialties</p>
        </div>

        <button class="adm-btn adm-btn-primary" onclick="window.openModal('addModal')" type="button">
          <i class="fas fa-user-plus" aria-hidden="true"></i> Recruit New Teacher
        </button>
      </div>

      <!-- ── Faculty Table Card ── -->
      <div class="adm-card">

        <!-- Table Control Header -->
        <div class="adm-card-header">
          <div>
            <h2 class="adm-card-title">Active Faculty Members</h2>
            <p class="adm-card-subtitle">Overview of current teachers, subject expertises, and credentials</p>
          </div>

          <div style="display: flex; gap: 0.75rem; align-items: center;">
            <!-- Live filter input -->
            <div style="position: relative; width: 260px;">
              <i class="fas fa-search adm-topbar-search-icon" aria-hidden="true"></i>
              <input 
                type="text" 
                id="teacherSearch" 
                placeholder="Filter faculty..." 
                aria-label="Filter teachers in table"
                style="width: 100%; padding: 0.5rem 1rem 0.5rem 2.25rem; border-radius: var(--adm-r-full); border: 1px solid var(--adm-border); background: var(--adm-bg-canvas); color: var(--adm-text-primary); font-family: inherit; font-size: 0.8rem;"
                onkeyup="filterTable('teacherSearch', 'teacherTableBody')"
              >
            </div>

            <span class="adm-badge adm-badge-blue">
              <%= teachers.length %> Members
            </span>
          </div>
        </div>

        <!-- Table Wrap -->
        <div class="adm-table-wrap">
          <table class="adm-table">
            <thead>
              <tr>
                <th scope="col">Teacher Name</th>
                <% if (typeof isSuperAdmin !== 'undefined' && isSuperAdmin) { %>
                  <th scope="col">Campus</th>
                <% } %>
                <th scope="col">Subject Expertise</th>
                <th scope="col">Contact Info</th>
                <th scope="col">Salary</th>
                <th scope="col">Credentials</th>
                <th scope="col" style="text-align:right;">Actions</th>
              </tr>
            </thead>
            <tbody id="teacherTableBody">
              <% teachers.forEach(teacher => { %>
                <tr>
                  <td>
                    <div style="display: flex; align-items: center; gap: 0.65rem;">
                      <div class="adm-avatar" aria-hidden="true" style="width: 32px; height: 32px; font-size: 0.75rem; border-radius: var(--adm-r-sm); background: linear-gradient(135deg, var(--adm-amber) 0%, var(--adm-indigo) 100%);">
                        <%= teacher.full_name.charAt(0) %>
                      </div>
                      <div>
                        <span style="font-weight: 600; color: var(--adm-text-primary); display:block; line-height:1.2;"><%= teacher.full_name %></span>
                        <span style="font-size: 0.72rem; color: var(--adm-text-muted);">@<%= teacher.username %></span>
                      </div>
                    </div>
                  </td>
                  <% if (typeof isSuperAdmin !== 'undefined' && isSuperAdmin) { %>
                    <td>
                      <span class="adm-badge adm-badge-blue"><%= teacher.campus_name || '-' %></span>
                    </td>
                  <% } %>
                  <td>
                    <span class="adm-badge adm-badge-green"><%= teacher.subject %></span>
                  </td>
                  <td>
                    <div style="font-size: 0.8rem; display:flex; flex-direction:column; gap:0.15rem;">
                      <span style="color: var(--adm-text-secondary);"><i class="fas fa-envelope" style="width: 16px; color: var(--adm-text-muted);" aria-hidden="true"></i> <%= teacher.email %></span>
                      <span style="color: var(--adm-text-secondary);"><i class="fas fa-phone" style="width: 16px; color: var(--adm-text-muted);" aria-hidden="true"></i> <%= teacher.phone %></span>
                    </div>
                  </td>
                  <td style="font-weight: 700; color: var(--adm-text-primary);">
                    Rs. <%= teacher.salary ? Number(teacher.salary).toLocaleString() : '0' %>
                  </td>
                  <td>
                    <button 
                      class="adm-btn adm-btn-ghost" 
                      style="min-height: 28px; padding: 0.2rem 0.65rem; font-size: 0.75rem;" 
                      onclick="openCredsModal('<%= teacher.user_id %>', '<%= teacher.username %>')"
                      type="button"
                    >
                      <i class="fas fa-key" aria-hidden="true"></i> Reset
                    </button>
                  </td>
                  <td style="text-align:right;">
                    <a 
                      href="/admin/teachers/delete/<%= teacher.id %>" 
                      class="adm-btn adm-btn-ghost" 
                      style="min-height:30px; width:30px; padding:0; display:inline-flex; align-items:center; justify-content:center; border-color:transparent; color: var(--adm-red); background: var(--adm-red-bg);"
                      onclick="return confirm('Remove this teacher from faculty?')"
                      aria-label="Delete <%= teacher.full_name %>"
                    >
                      <i class="fas fa-trash" aria-hidden="true"></i>
                    </a>
                  </td>
                </tr>
              <% }) %>

              <% if (teachers.length === 0) { %>
                <tr>
                  <td colspan="<%= typeof isSuperAdmin !== 'undefined' && isSuperAdmin ? 7 : 6 %>" style="padding: 4.5rem; text-align: center; color: var(--adm-text-muted);">
                    <i class="fas fa-user-slash" style="font-size: 2.5rem; opacity: 0.25; display: block; margin-bottom: 1rem;" aria-hidden="true"></i>
                    No faculty members found.
                  </td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

    </main>
  </div>

  <!-- ════════════════════════════════════════════════════════════
       ADD MODAL (Recruit Faculty)
       ════════════════════════════════════════════════════════════ -->
  <div id="addModal" class="adm-modal-overlay" role="dialog" aria-modal="true" aria-labelledby="addModalTitle">
    <div class="adm-modal-container">
      <button class="adm-modal-close-btn" onclick="window.closeModal('addModal')" aria-label="Close modal" type="button">
        <i class="fas fa-times" aria-hidden="true"></i>
      </button>

      <h2 id="addModalTitle" style="font-weight: 700; font-size:1.35rem; margin-bottom: 0.25rem;">Recruit Faculty Member</h2>
      <p style="color: var(--adm-text-muted); font-size: 0.85rem; margin-bottom: 1.75rem;">Enter personal and professional details for the new teacher.</p>

      <form action="/admin/teachers/add" method="POST" class="adm-form-grid">
        <!-- CSRF Protection -->
        <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <% } %>

        <div class="adm-form-group adm-form-group-full">
          <label class="adm-label" for="add_full_name">Full Name</label>
          <input type="text" name="full_name" id="add_full_name" class="adm-input" required autocomplete="name">
        </div>

        <div class="adm-form-group">
          <label class="adm-label" for="add_username">Username</label>
          <input type="text" name="username" id="add_username" class="adm-input" required autocomplete="username">
        </div>

        <div class="adm-form-group">
          <label class="adm-label" for="add_password">Password</label>
          <input type="password" name="password" id="add_password" class="adm-input" required autocomplete="new-password">
        </div>

        <div class="adm-form-group">
          <label class="adm-label" for="add_subject">Subject Expertise</label>
          <input type="text" name="subject" id="add_subject" class="adm-input" placeholder="e.g. Mathematics" required>
        </div>

        <div class="adm-form-group">
          <label class="adm-label" for="add_salary">Basic Salary (Rs)</label>
          <input type="number" name="salary" id="add_salary" max="1000000" class="adm-input" placeholder="Optional">
          <small style="color: var(--adm-text-muted); font-size: 0.7rem; display: block; margin-top: 2px;">
            Maximum salary: Rs. 1,000,000
          </small>
        </div>

        <div class="adm-form-group">
          <label class="adm-label" for="add_phone">Phone Number</label>
          <input type="text" name="phone" id="add_phone" class="adm-input" placeholder="e.g. 0300-1234567" autocomplete="tel">
        </div>

        <div class="adm-form-group">
          <label class="adm-label" for="add_email">Email Address</label>
          <input type="email" name="email" id="add_email" class="adm-input" autocomplete="email">
        </div>

        <div class="adm-form-group adm-form-group-full" style="margin-top: 0.5rem;">
          <button type="submit" class="adm-btn adm-btn-primary" style="width: 100%; min-height:44px; justify-content:center;">
            Register Faculty Member
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- ════════════════════════════════════════════════════════════
       CREDENTIALS MODAL (Reset Password)
       ════════════════════════════════════════════════════════════ -->
  <div id="credsModal" class="adm-modal-overlay" role="dialog" aria-modal="true" aria-labelledby="credsModalTitle">
    <div class="adm-modal-container adm-modal-container-sm">
      <button class="adm-modal-close-btn" onclick="window.closeModal('credsModal')" aria-label="Close modal" type="button">
        <i class="fas fa-times" aria-hidden="true"></i>
      </button>

      <div style="text-align: center; margin-bottom: 1.5rem;">
        <div style="width: 54px; height: 54px; background: var(--adm-indigo-bg); color: var(--adm-indigo); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.35rem; margin: 0 auto 0.75rem;">
          <i class="fas fa-key" aria-hidden="true"></i>
        </div>
        <h2 id="credsModalTitle" style="font-weight: 700; font-size:1.25rem;">Manage Credentials</h2>
        <p style="color: var(--adm-text-muted); font-size: 0.85rem; margin-top:0.25rem;">
          Reset password for <span id="credsUsername" style="font-weight: 700; color: var(--adm-text-primary);"></span>
        </p>
      </div>

      <form action="/admin/users/reset-password" method="POST">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <input type="hidden" name="user_id" id="credsUserId">
        <input type="hidden" name="return_url" id="credsReturnUrl" value="/admin/teachers">

        <div class="adm-form-group" style="margin-bottom: 1.5rem;">
          <label class="adm-label" for="reset_new_password">New Password</label>
          <input type="text" name="new_password" id="reset_new_password" required placeholder="Enter new password" class="adm-input" style="font-family:'JetBrains Mono', monospace; font-weight: 600;">
        </div>

        <button type="submit" class="adm-btn adm-btn-primary" style="width: 100%; min-height:42px; justify-content:center;">
          Update Password
        </button>
      </form>
    </div>
  </div>

  <!-- Table Filter Script -->
  <script>
    function openCredsModal(userId, username) {
      window.openModal('credsModal');
      document.getElementById('credsUserId').value = userId;
      document.getElementById('credsUsername').innerText = '@' + username;
      document.getElementById('credsReturnUrl').value = window.location.href;
    }

    // Filter table content locally
    function filterTable(inputId, tableId) {
      const input = document.getElementById(inputId);
      if (!input) return;
      const filter = input.value.toLowerCase();
      const tbody = document.getElementById(tableId);
      if (!tbody) return;
      const rows = tbody.getElementsByTagName('tr');

      for (let i = 0; i < rows.length; i++) {
        const row = rows[i];
        const text = row.textContent.toLowerCase();
        row.style.display = text.includes(filter) ? "" : "none";
      }
    }
  </script>

<%- include('../partials/footer') %>
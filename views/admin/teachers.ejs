<%- include('../partials/header') %>

    <div class="admin-layout animate-fade-in" style="margin-top: 80px;">
        <!-- Sidebar -->
        <!-- Sidebar -->
        <%- include('../partials/sidebar', { active: 'teachers' }) %>

            <!-- Main Content -->
            <main class="main-content">
                <header
                    style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 3rem;">
                    <div>
                        <h2 style="font-size: 2rem; font-weight: 800; color: var(--primary);">Faculty Management</h2>
                        <p style="color: var(--text-muted);">Manage your expert teaching staff</p>
                    </div>
                    <button class="btn btn-primary" onclick="document.getElementById('addModal').style.display='flex'">
                        <i class="fas fa-user-plus"></i> Recruit New Teacher
                    </button>
                </header>

                <div class="card animate-slide-up" style="padding: 0; overflow: hidden; border-radius: 24px;">
                    <div
                        style="padding: 1.5rem 2rem; background: #f8fafc; border-bottom: 1px solid #edf2f7; display: flex; justify-content: space-between; align-items: center;">
                        <h4 style="font-weight: 800; color: var(--primary);">Active Faculty Members</h4>
                    </div>
                    <div style="overflow-x: auto;">
                        <table style="width: 100%; border-collapse: collapse; text-align: left;">
                            <thead>
                                <tr style="background: #f8fafc;">
                                    <th
                                        style="padding: 1.2rem 2rem; color: var(--text-muted); font-weight: 600; font-size: 0.85rem; text-transform: uppercase;">
                                        Teacher Name</th>
                                    <% if (typeof isSuperAdmin !=='undefined' && isSuperAdmin) { %>
                                        <th
                                            style="padding: 1.2rem 2rem; color: var(--text-muted); font-weight: 600; font-size: 0.85rem; text-transform: uppercase;">
                                            Campus</th>
                                        <% } %>
                                            <th
                                                style="padding: 1.2rem 2rem; color: var(--text-muted); font-weight: 600; font-size: 0.85rem; text-transform: uppercase;">
                                                Subject Expertise</th>
                                            <th
                                                style="padding: 1.2rem 2rem; color: var(--text-muted); font-weight: 600; font-size: 0.85rem; text-transform: uppercase;">
                                                Contact Info</th>

                                            <th
                                                style="padding: 1.2rem 2rem; color: var(--text-muted); font-weight: 600; font-size: 0.85rem; text-transform: uppercase;">
                                                Salary</th>
                                            <th
                                                style="padding: 1.2rem 2rem; color: var(--text-muted); font-weight: 600; font-size: 0.85rem; text-transform: uppercase;">
                                                Credentials</th>
                                            <th
                                                style="padding: 1.2rem 2rem; color: var(--text-muted); font-weight: 600; font-size: 0.85rem; text-transform: uppercase;">
                                                Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% teachers.forEach(teacher=> { %>
                                    <tr style="border-bottom: 1px solid #f1f5f9; transition: var(--transition);"
                                        onmouseover="this.style.background='#f8fafc'"
                                        onmouseout="this.style.background='white'">
                                        <td style="padding: 1.2rem 2rem;">
                                            <div style="display: flex; align-items: center; gap: 12px;">
                                                <div
                                                    style="width: 40px; height: 40px; border-radius: 12px; background: #fef3c7; display: flex; align-items: center; justify-content: center; font-weight: 800; color: #d97706;">
                                                    <%= teacher.full_name.charAt(0) %>
                                                </div>
                                                <div>
                                                    <p style="font-weight: 700; color: var(--primary); margin: 0;">
                                                        <%= teacher.full_name %>
                                                    </p>
                                                    <p style="font-size: 0.8rem; color: var(--text-muted); margin: 0;">@
                                                        <%= teacher.username %>
                                                    </p>
                                                </div>
                                            </div>
                                        </td>
                                        <% if (typeof isSuperAdmin !=='undefined' && isSuperAdmin) { %>
                                            <td style="padding: 1.2rem 2rem;">
                                                <span class="badge badge-sm badge-info"
                                                    style="background: #e0f2fe; color: var(--primary); padding: 4px 10px; border-radius: 8px; font-weight: 600; font-size: 0.8rem;">
                                                    <%= teacher.campus_name || '-' %>
                                                </span>
                                            </td>
                                            <% } %>

                                                <td style="padding: 1.2rem 2rem;">
                                                    <span
                                                        style="padding: 6px 12px; background: #ecfdf5; color: #10b981; border-radius: 8px; font-weight: 700; font-size: 0.85rem;">
                                                        <%= teacher.subject %>
                                                    </span>
                                                </td>
                                                <td style="padding: 1.2rem 2rem;">
                                                    <p style="font-size: 0.9rem; color: var(--text-main); margin: 0;"><i
                                                            class="fas fa-envelope"
                                                            style="width: 20px; color: var(--text-muted);"></i>
                                                        <%= teacher.email %>
                                                    </p>
                                                    <p style="font-size: 0.9rem; color: var(--text-main); margin: 0;"><i
                                                            class="fas fa-phone"
                                                            style="width: 20px; color: var(--text-muted);"></i>
                                                        <%= teacher.phone %>
                                                    </p>
                                                </td>
                                                <td style="padding: 1.2rem 2rem; font-weight: 700;">
                                                    Rs. <%= teacher.salary %>
                                                </td>
                                                <td style="padding: 1.2rem 2rem;">
                                                    <button
                                                        onclick="openCredsModal('<%= teacher.user_id %>', '<%= teacher.username %>')"
                                                        class="btn"
                                                        style="background: #e0f2fe; color: var(--primary); padding: 6px 12px; border-radius: 8px; font-weight: 700; font-size: 0.8rem; border: none; cursor: pointer;">
                                                        <i class="fas fa-key"></i> Reset
                                                    </button>
                                                </td>
                                                <td style="padding: 1.2rem 2rem;">
                                                    <a href="/admin/teachers/delete/<%= teacher.id %>"
                                                        style="color: var(--danger); background: #fef2f2; width: 35px; height: 35px; border-radius: 10px; display: inline-flex; align-items: center; justify-content: center; text-decoration: none; transition: var(--transition);"
                                                        onclick="return confirm('Remove this teacher from faculty?')">
                                                        <i class="fas fa-trash"></i>
                                                    </a>
                                                </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </main>
    </div>

    <!-- Modern Add Modal -->
    <div id="addModal" class="modal glass"
        style="display: none; position: fixed; inset: 0; z-index: 2000; background: rgba(15, 23, 42, 0.4); backdrop-filter: blur(8px); align-items: center; justify-content: center; overflow-y: auto; padding: 2rem 1rem;">
        <div class="animate-slide-up"
            style="background: white; width: 100%; max-width: 600px; margin: auto; border-radius: 24px; padding: 2.5rem; position: relative; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);">
            <button onclick="document.getElementById('addModal').style.display='none'"
                style="position: absolute; right: 2rem; top: 2rem; background: #f8fafc; border: none; width: 40px; height: 40px; border-radius: 50%; cursor: pointer;"><i
                    class="fas fa-times"></i></button>
            <h2 style="font-weight: 800; color: var(--primary); margin-bottom: 0.5rem;">Recruit Faculty Member</h2>
            <p style="color: var(--text-muted); margin-bottom: 2.5rem;">Enter personal and professional details for the
                new teacher.</p>

            <form action="/admin/teachers/add" method="POST"
                style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                <div style="grid-column: span 2;">
                    <label style="display: block; font-weight: 700; margin-bottom: 8px; font-size: 0.9rem;">Full
                        Name</label>
                    <input type="text" name="full_name" required
                        style="width: 100%; padding: 12px 16px; border-radius: 12px; border: 1px solid #e2e8f0; background: #f8fafc;">
                </div>
                <div>
                    <label
                        style="display: block; font-weight: 700; margin-bottom: 8px; font-size: 0.9rem;">Username</label>
                    <input type="text" name="username" required
                        style="width: 100%; padding: 12px 16px; border-radius: 12px; border: 1px solid #e2e8f0; background: #f8fafc;">
                </div>
                <div>
                    <label
                        style="display: block; font-weight: 700; margin-bottom: 8px; font-size: 0.9rem;">Password</label>
                    <input type="password" name="password" required
                        style="width: 100%; padding: 12px 16px; border-radius: 12px; border: 1px solid #e2e8f0; background: #f8fafc;">
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; grid-column: span 2;">
                    <div>
                        <label
                            style="display: block; font-weight: 700; margin-bottom: 8px; font-size: 0.9rem;">Subject</label>
                        <input type="text" name="subject" required
                            style="width: 100%; padding: 12px 16px; border-radius: 12px; border: 1px solid #e2e8f0; background: #f8fafc;"
                            placeholder="e.g. Mathematics">
                    </div>
                    <div>
                        <label style="display: block; font-weight: 700; margin-bottom: 8px; font-size: 0.9rem;">Basic
                            Salary (Rs)</label>
                        <input type="number" name="salary" max="1000000" placeholder="Optional"
                            style="width: 100%; padding: 12px 16px; border-radius: 12px; border: 1px solid #e2e8f0; background: #f8fafc;">
                        <small style="color: var(--text-muted); font-size: 0.75rem; display: block; margin-top: 4px;">
                            Maximum salary: Rs. 1,000,000
                        </small>
                    </div>
                </div>

                <div>
                    <label style="display: block; font-weight: 700; margin-bottom: 8px; font-size: 0.9rem;">Phone
                        Number</label>
                    <input type="text" name="phone"
                        style="width: 100%; padding: 12px 16px; border-radius: 12px; border: 1px solid #e2e8f0; background: #f8fafc;"
                        placeholder="e.g. 0300-1234567">
                </div>
                <div style="grid-column: span 2;">
                    <label style="display: block; font-weight: 700; margin-bottom: 8px; font-size: 0.9rem;">Email
                        Address</label>
                    <input type="email" name="email"
                        style="width: 100%; padding: 12px 16px; border-radius: 12px; border: 1px solid #e2e8f0; background: #f8fafc;">
                </div>
                <div style="grid-column: span 2;">
                    <button type="submit" class="btn btn-primary" style="width: 100%; padding: 15px;">Register Faculty
                        Member</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        window.onclick = function (event) {
            let modal = document.getElementById('addModal');
            if (event.target == modal) {
                modal.style.display = "none";
            }
        }
    </script>
    <!-- Credentials Modal -->
    <div id="credsModal" class="modal glass"
        style="display: none; position: fixed; inset: 0; z-index: 2000; background: rgba(15, 23, 42, 0.4); backdrop-filter: blur(8px); align-items: center; justify-content: center; overflow-y: auto; padding: 2rem 1rem;">
        <div class="animate-slide-up"
            style="background: white; width: 100%; max-width: 400px; margin: auto; border-radius: 24px; padding: 2.5rem; position: relative; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);">
            <button onclick="document.getElementById('credsModal').style.display='none'"
                style="position: absolute; right: 1.5rem; top: 1.5rem; background: #f8fafc; border: none; width: 35px; height: 35px; border-radius: 50%; cursor: pointer;"><i
                    class="fas fa-times"></i></button>

            <div style="text-align: center; margin-bottom: 2rem;">
                <div
                    style="width: 60px; height: 60px; background: #e0f2fe; color: var(--primary); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; margin: 0 auto 1rem;">
                    <i class="fas fa-key"></i>
                </div>
                <h3 style="font-weight: 800; color: var(--primary);">Manage Credentials</h3>
                <p style="color: var(--text-muted); font-size: 0.9rem;">Reset password for <span id="credsUsername"
                        style="font-weight: 700; color: var(--text-main);"></span></p>
            </div>

            <form action="/admin/users/reset-password" method="POST">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                <input type="hidden" name="user_id" id="credsUserId">
                <input type="hidden" name="return_url" value="/admin/teachers">

                <div style="margin-bottom: 1.5rem;">
                    <label style="display: block; font-weight: 700; margin-bottom: 8px; font-size: 0.9rem;">New
                        Password</label>
                    <input type="text" name="new_password" required placeholder="Enter new password"
                        style="width: 100%; padding: 12px 16px; border-radius: 12px; border: 1px solid #e2e8f0; background: #f8fafc; font-weight: 600;">
                </div>

                <button type="submit" class="btn btn-primary" style="width: 100%; padding: 12px;">Update
                    Password</button>
            </form>
        </div>
    </div>

    <script>
        function openCredsModal(userId, username) {
            document.getElementById('credsModal').style.display = 'flex';
            document.getElementById('credsUserId').value = userId;
            document.getElementById('credsUsername').innerText = '@' + username;
        }
    </script>
    </body>

    </html>
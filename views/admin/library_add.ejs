<%- include('../partials/header') %>

  <!-- ════════════════════════════════════════════════════════════
       ADMIN LAYOUT
       ════════════════════════════════════════════════════════════ -->
  <div class="adm-layout">

    <!-- Sidebar -->
    <%- include('../partials/sidebar', { active: 'library' }) %>

    <!-- ══ MAIN CONTENT ══════════════════════════════════════════ -->
    <main class="adm-main" role="main" aria-label="Upload Library Resource">

      <div style="max-width: 650px; margin: 0 auto; width: 100%;">
        
        <div class="adm-page-header" style="margin-bottom: 2rem;">
          <h1 class="adm-page-title">Upload New Resource</h1>
        </div>

        <article class="adm-card" style="padding: 2.5rem;">
          
          <form action="/admin/library/add" method="POST" enctype="multipart/form-data">
            <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
            
            <!-- Title -->
            <div class="adm-form-group">
              <label for="titleInput" class="adm-label">Resource Title <span style="color: var(--adm-red);">*</span></label>
              <input type="text" name="title" id="titleInput" required class="adm-input" placeholder="e.g. Mathematics Formula Sheet">
            </div>

            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1.5rem;">
              <!-- Target Grade -->
              <div class="adm-form-group">
                <label for="gradeInput" class="adm-label">For Grade / Class <span style="color: var(--adm-red);">*</span></label>
                <select name="target_grade" id="gradeInput" required class="adm-input">
                  <option value="General">General / All Classes</option>
                  <% classes.forEach(cls => { %>
                    <option value="<%= cls.class_name %> - <%= cls.section %>">
                      <%= cls.class_name %> - <%= cls.section %>
                    </option>
                  <% }) %>
                </select>
              </div>

              <!-- Subject -->
              <div class="adm-form-group">
                <label for="subjectInput" class="adm-label">Subject / Category <span style="color: var(--adm-red);">*</span></label>
                <input type="text" name="subject" id="subjectInput" required class="adm-input" placeholder="e.g. Mathematics">
              </div>
            </div>

            <!-- Visibility -->
            <div class="adm-form-group">
              <label for="visibilityInput" class="adm-label">Visibility (Who can see this?) <span style="color: var(--adm-red);">*</span></label>
              <select name="visibility" id="visibilityInput" required class="adm-input">
                <option value="both">Both (Students & Teachers)</option>
                <option value="student">Students Only</option>
                <option value="teacher">Teachers Only</option>
              </select>
            </div>

            <!-- File Upload -->
            <div class="adm-form-group" style="margin-bottom: 2.5rem;">
              <label for="fileInput" class="adm-label">Select File <span style="color: var(--adm-red);">*</span></label>
              
              <div style="border: 2px dashed var(--adm-border); padding: 3rem 2rem; text-align: center; border-radius: var(--adm-r-lg); background: var(--adm-bg-elevated); transition: all 0.2s ease; cursor: pointer; position: relative;" onmouseover="this.style.borderColor='var(--adm-indigo)'; this.style.background='var(--adm-indigo-bg)';" onmouseout="this.style.borderColor='var(--adm-border)'; this.style.background='var(--adm-bg-elevated)';">
                
                <i class="fas fa-cloud-upload-alt" aria-hidden="true" style="font-size: 2.5rem; color: var(--adm-indigo); margin-bottom: 1rem;"></i>
                <p style="font-weight: 700; color: var(--adm-text-primary); margin-bottom: 0.5rem;">Drag and drop or click to browse</p>
                <p style="color: var(--adm-text-muted); font-size: 0.85rem; margin-bottom: 1.5rem;">Supported Formats: PDF, Word, JPEG, PNG</p>
                
                <input type="file" name="book_file" id="fileInput" required accept=".pdf,.doc,.docx,.jpg,.jpeg,.png" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; opacity: 0; cursor: pointer;">
              </div>
            </div>

            <!-- Submit -->
            <div style="display: flex; gap: 1rem; justify-content: flex-end;">
              <a href="/admin/library" class="adm-btn adm-btn-ghost" style="text-decoration: none;">Cancel</a>
              <button type="submit" class="adm-btn adm-btn-primary">
                <i class="fas fa-cloud-upload-alt" aria-hidden="true"></i> Upload Resource
              </button>
            </div>

          </form>
        </article>

      </div>
    </main>
  </div>

<%- include('../partials/footer') %>
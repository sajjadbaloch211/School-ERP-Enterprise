<%- include('../partials/header') %>

  <!-- ════════════════════════════════════════════════════════════
       ADMIN LAYOUT
       ════════════════════════════════════════════════════════════ -->
  <div class="adm-layout">

    <!-- Sidebar -->
    <%- include('../partials/sidebar', { active: 'students' }) %>

    <!-- ══ MAIN CONTENT ══════════════════════════════════════════ -->
    <main class="adm-main" role="main" aria-label="Students portal">

      <!-- Success/Error Messages -->
      <script>
        (function() {
          const urlParams = new URLSearchParams(window.location.search);
          const successMsg = urlParams.get('success');
          const errorMsg = urlParams.get('error');
          const errorsMsg = urlParams.get('errors');

          // Display success message
          if (successMsg) {
            const banner = document.createElement('div');
            banner.className = 'adm-banner adm-banner-success';
            banner.setAttribute('role', 'alert');
            banner.setAttribute('aria-live', 'polite');
            banner.innerHTML = `
              <i class="fas fa-check-circle adm-banner-icon" aria-hidden="true"></i>
              <div class="adm-banner-content">
                <div class="adm-banner-body">${decodeURIComponent(successMsg)}</div>
              </div>
              <button class="adm-banner-close" aria-label="Dismiss notification" type="button">
                <i class="fas fa-times" aria-hidden="true"></i>
              </button>
            `;
            document.currentScript.parentElement.appendChild(banner);
            setTimeout(() => {
              banner.style.transition = 'opacity 0.25s, transform 0.25s';
              banner.style.opacity = '0';
              banner.style.transform = 'translateY(-8px)';
              setTimeout(() => banner.remove(), 260);
            }, 6000);
          }

          // Display error message
          if (errorMsg) {
            const banner = document.createElement('div');
            banner.className = 'adm-banner adm-banner-danger';
            banner.setAttribute('role', 'alert');
            banner.setAttribute('aria-live', 'assertive');
            banner.innerHTML = `
              <i class="fas fa-exclamation-triangle adm-banner-icon" aria-hidden="true"></i>
              <div class="adm-banner-content">
                <div class="adm-banner-body">${decodeURIComponent(errorMsg)}</div>
              </div>
              <button class="adm-banner-close" aria-label="Dismiss notification" type="button">
                <i class="fas fa-times" aria-hidden="true"></i>
              </button>
            `;
            document.currentScript.parentElement.appendChild(banner);
          }

          // Display detailed errors
          if (errorsMsg) {
            const banner = document.createElement('div');
            banner.className = 'adm-banner adm-banner-warning';
            banner.setAttribute('role', 'alert');
            banner.setAttribute('aria-live', 'polite');
            const errorsList = decodeURIComponent(errorsMsg).split(' | ');
            banner.innerHTML = `
              <i class="fas fa-info-circle adm-banner-icon" aria-hidden="true"></i>
              <div class="adm-banner-content">
                <div class="adm-banner-title">Import Errors:</div>
                <div class="adm-banner-body">
                  <ul style="margin: 0.5rem 0 0 0; padding-left: 1.25rem;">
                    ${errorsList.map(err => `<li>${err}</li>`).join('')}
                  </ul>
                </div>
              </div>
              <button class="adm-banner-close" aria-label="Dismiss notification" type="button">
                <i class="fas fa-times" aria-hidden="true"></i>
              </button>
            `;
            document.currentScript.parentElement.appendChild(banner);
          }
        })();
      </script>

      <!-- ── Page Header ── -->
      <div class="adm-page-header">
        <div>
          <% if (viewMode === 'classes') { %>
            <h1 class="adm-page-title">Class Blocks</h1>
            <p class="adm-page-subtitle">Select a class block to view enrolled students</p>
          <% } else { %>
            <h1 class="adm-page-title">
              <%= currentClass.class_name %> <span style="font-weight:400; opacity:0.65;"><%= currentClass.section %></span>
            </h1>
            <p class="adm-page-subtitle">
              <% if (currentClass.class_name === 'Search Results') { %>
                Found <%= students.length %> matches across all classes
              <% } else { %>
                Viewing class members in this specific block
              <% } %>
            </p>
          <% } %>
        </div>

        <div style="display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap;">
          <% if (viewMode === 'students') { %>
            <a href="/admin/students" class="adm-btn adm-btn-ghost" aria-label="Back to class blocks">
              <i class="fas fa-arrow-left" aria-hidden="true"></i> Back to Blocks
            </a>
          <% } %>

          <button class="adm-btn adm-btn-ghost" onclick="window.openModal('importModal')" type="button">
            <i class="fas fa-file-import" aria-hidden="true"></i> Import CSV
          </button>

          <button class="adm-btn adm-btn-primary" onclick="window.openModal('addModal')" type="button">
            <i class="fas fa-plus" aria-hidden="true"></i> Add Student
          </button>
        </div>
      </div>

      <!-- ── Global Search (Redirects to Search View Mode) ── -->
      <% if (viewMode === 'classes') { %>
        <div style="max-width: 480px; margin-bottom: 2rem;">
          <form action="/admin/students" method="GET" style="position: relative;" role="search">
            <i class="fas fa-search adm-topbar-search-icon" aria-hidden="true"></i>
            <input 
              type="search" 
              name="search" 
              placeholder="Global Search (Name or ID)..." 
              aria-label="Global search students"
              style="width:100%; padding: 0.75rem 1rem 0.75rem 2.5rem; border-radius: var(--adm-r-full); border: 1px solid var(--adm-border); background: var(--adm-bg-surface); color: var(--adm-text-primary); font-family: inherit; font-size: 0.875rem;"
            >
          </form>
        </div>
      <% } %>

      <!-- ══════════════════════════════════════════════════════════
           VIEW MODE: CLASSES GRID
           ══════════════════════════════════════════════════════════ -->
      <% if (viewMode === 'classes') { %>
        <div class="adm-class-grid">
          <% classes.forEach(cls => { %>
            <a href="/admin/students?class_id=<%= cls.id %>" class="adm-class-card" aria-label="View <%= cls.class_name %> section <%= cls.section %>">
              <div class="adm-class-icon">
                <i class="fas fa-school" aria-hidden="true"></i>
              </div>
              <h2 class="adm-class-title"><%= cls.class_name %></h2>
              <span class="adm-class-section">Section: <%= cls.section %></span>
              
              <% if (typeof isSuperAdmin !== 'undefined' && isSuperAdmin && cls.campus_name) { %>
                <span class="adm-badge adm-badge-blue" style="margin-top:0.5rem;"><%= cls.campus_name %></span>
              <% } %>

              <div class="adm-class-footer">
                <span class="adm-class-students-count"><%= cls.student_count %> Students</span>
                <span class="adm-class-link-label">
                  Open Block <i class="fas fa-chevron-right" style="font-size:0.65rem;" aria-hidden="true"></i>
                </span>
              </div>
            </a>
          <% }) %>
        </div>

      <!-- ══════════════════════════════════════════════════════════
           VIEW MODE: STUDENTS TABLE LIST
           ══════════════════════════════════════════════════════════ -->
      <% } else { %>
        <div class="adm-card">
          
          <!-- Table Control Header -->
          <div class="adm-card-header">
            <div>
              <h2 class="adm-card-title">Class Member List</h2>
              <p class="adm-card-subtitle">Manage block enrollments and security details</p>
            </div>
            
            <div style="display: flex; gap: 0.75rem; align-items: center;">
              <!-- Inline Filter Search -->
              <div style="position: relative; width: 260px;">
                <i class="fas fa-search adm-topbar-search-icon" aria-hidden="true"></i>
                <input 
                  type="text" 
                  id="studentSearch" 
                  placeholder="Filter members..." 
                  aria-label="Filter students in table"
                  style="width: 100%; padding: 0.5rem 1rem 0.5rem 2.25rem; border-radius: var(--adm-r-full); border: 1px solid var(--adm-border); background: var(--adm-bg-canvas); color: var(--adm-text-primary); font-family: inherit; font-size: 0.8rem;"
                  onkeyup="filterTable('studentSearch', 'studentTableBody')"
                >
              </div>
              
              <span class="adm-badge adm-badge-blue">
                <%= students.length %> Enrolled
              </span>
            </div>
          </div>

          <!-- Table Container -->
          <div class="adm-table-wrap">
            <table class="adm-table">
              <thead>
                <tr>
                  <th scope="col">Roll No</th>
                  <% if (typeof isSuperAdmin !== 'undefined' && isSuperAdmin) { %>
                    <th scope="col">Campus</th>
                  <% } %>
                  <th scope="col">Student Name</th>
                  <th scope="col">Father Name</th>
                  <th scope="col">User ID</th>
                  <th scope="col">Status</th>
                  <th scope="col">Credentials</th>
                  <th scope="col" style="text-align:right;">Actions</th>
                </tr>
              </thead>
              <tbody id="studentTableBody">
                <% students.forEach(student => { %>
                  <tr>
                    <td style="font-weight: 700; color: var(--adm-indigo);"><%= student.roll_no %></td>
                    <% if (typeof isSuperAdmin !== 'undefined' && isSuperAdmin) { %>
                      <td>
                        <span class="adm-badge adm-badge-blue"><%= student.campus_name || '-' %></span>
                      </td>
                    <% } %>
                    <td>
                      <div style="display: flex; align-items: center; gap: 0.65rem;">
                        <div class="adm-avatar" aria-hidden="true" style="width: 32px; height: 32px; font-size: 0.75rem; border-radius: var(--adm-r-sm);">
                          <%= student.full_name.charAt(0) %>
                        </div>
                        <span style="font-weight: 600; color: var(--adm-text-primary);"><%= student.full_name %></span>
                      </div>
                    </td>
                    <td><%= student.father_name || 'N/A' %></td>
                    <td>
                      <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.8rem; background: var(--adm-bg-canvas); padding: 0.2rem 0.5rem; border-radius: var(--adm-r-xs); color: var(--adm-text-secondary);">
                        @<%= student.username %>
                      </span>
                    </td>
                    <td>
                      <span class="adm-badge adm-badge-green">Active</span>
                    </td>
                    <td>
                      <button 
                        class="adm-btn adm-btn-ghost" 
                        style="min-height: 28px; padding: 0.2rem 0.65rem; font-size: 0.75rem;" 
                        onclick="openCredsModal('<%= student.user_id %>', '<%= student.username %>')"
                        type="button"
                      >
                        <i class="fas fa-key" aria-hidden="true"></i> Reset
                      </button>
                    </td>
                    <td style="text-align:right;">
                      <a 
                        href="/admin/students/delete/<%= student.id %>" 
                        class="adm-btn adm-btn-ghost" 
                        style="min-height:30px; width:30px; padding:0; display:inline-flex; align-items:center; justify-content:center; border-color:transparent; color: var(--adm-red); background: var(--adm-red-bg);"
                        onclick="return confirm('Remove student from this block?')"
                        aria-label="Delete <%= student.full_name %>"
                      >
                        <i class="fas fa-trash" aria-hidden="true"></i>
                      </a>
                    </td>
                  </tr>
                <% }) %>

                <% if (students.length === 0) { %>
                  <tr>
                    <td colspan="<%= typeof isSuperAdmin !== 'undefined' && isSuperAdmin ? 8 : 7 %>" style="padding: 4.5rem; text-align: center; color: var(--adm-text-muted);">
                      <i class="fas fa-user-slash" style="font-size: 2.5rem; opacity: 0.25; display: block; margin-bottom: 1rem;" aria-hidden="true"></i>
                      This block is currently empty.
                    </td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      <% } %>

    </main>
  </div>

  <!-- ════════════════════════════════════════════════════════════
       ADD MODAL (Register Student)
       ════════════════════════════════════════════════════════════ -->
  <div id="addModal" class="adm-modal-overlay" role="dialog" aria-modal="true" aria-labelledby="addModalTitle">
    <div class="adm-modal-container">
      <button class="adm-modal-close-btn" onclick="window.closeModal('addModal')" aria-label="Close modal" type="button">
        <i class="fas fa-times" aria-hidden="true"></i>
      </button>

      <h2 id="addModalTitle" style="font-weight: 700; font-size:1.35rem; margin-bottom: 0.25rem;">Register New Student</h2>
      <p style="color: var(--adm-text-muted); font-size: 0.85rem; margin-bottom: 1.75rem;">The student will be automatically added to the selected block.</p>

      <form action="/admin/students/add" method="POST" class="adm-form-grid">
        <!-- CSRF Protection -->
        <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <% } %>

        <div class="adm-form-group adm-form-group-full">
          <label class="adm-label" for="add_full_name">Full Name</label>
          <input type="text" name="full_name" id="add_full_name" class="adm-input" required autocomplete="name">
        </div>

        <div class="adm-form-group">
          <label class="adm-label" for="add_username">Username</label>
          <input type="text" name="username" id="add_username" class="adm-input" required autocomplete="username">
        </div>

        <div class="adm-form-group">
          <label class="adm-label" for="add_password">Password</label>
          <input type="password" name="password" id="add_password" class="adm-input" required autocomplete="new-password">
        </div>

        <div class="adm-form-group">
          <label class="adm-label" for="add_roll_no">Roll No</label>
          <input type="text" name="roll_no" id="add_roll_no" class="adm-input" required>
        </div>

        <div class="adm-form-group">
          <label class="adm-label" for="add_class_id">Assign to Block</label>
          <select name="class_id" id="add_class_id" class="adm-select" required>
            <% classes.forEach(cls => { %>
              <option value="<%= cls.id %>" <%= (typeof selectedClass !== 'undefined' && selectedClass == cls.id) ? 'selected' : '' %>>
                <%= cls.class_name %> - <%= cls.section %>
              </option>
            <% }) %>
          </select>
        </div>

        <div class="adm-form-group adm-form-group-full">
          <label class="adm-label" for="add_father_name">Father's Name</label>
          <input type="text" name="father_name" id="add_father_name" class="adm-input" required>
        </div>

        <div class="adm-form-group">
          <label class="adm-label" for="add_phone">Contact Number</label>
          <input type="tel" name="phone" id="add_phone" placeholder="03XX-XXXXXXX" class="adm-input" autocomplete="tel">
        </div>

        <div class="adm-form-group">
          <label class="adm-label" for="add_email">Email Address</label>
          <input type="email" name="email" id="add_email" class="adm-input" autocomplete="email">
        </div>

        <div class="adm-form-group adm-form-group-full">
          <label class="adm-label" for="add_address">Home Address</label>
          <textarea name="address" id="add_address" rows="2" class="adm-textarea"></textarea>
        </div>

        <div class="adm-form-group adm-form-group-full" style="margin-top: 0.5rem;">
          <button type="submit" class="adm-btn adm-btn-primary" style="width: 100%; min-height:44px; justify-content:center;">
            Securely Register Student
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- ════════════════════════════════════════════════════════════
       IMPORT MODAL (Bulk CSV)
       ════════════════════════════════════════════════════════════ -->
  <div id="importModal" class="adm-modal-overlay" role="dialog" aria-modal="true" aria-labelledby="importModalTitle">
    <div class="adm-modal-container" style="max-width: 500px;">
      <button class="adm-modal-close-btn" onclick="window.closeModal('importModal')" aria-label="Close modal" type="button">
        <i class="fas fa-times" aria-hidden="true"></i>
      </button>

      <h2 id="importModalTitle" style="font-weight: 700; font-size:1.35rem; margin-bottom: 0.25rem;">Bulk Student Import</h2>
      <p style="color: var(--adm-text-muted); font-size: 0.85rem; margin-bottom: 1.5rem;">Upload a CSV file to add multiple students at once.</p>

      <!-- CSV Info Banner -->
      <div class="adm-banner adm-banner-warning" style="margin-bottom: 1.5rem; border-radius: var(--adm-r-sm); padding: 1rem 1.125rem;">
        <i class="fas fa-info-circle adm-banner-icon" aria-hidden="true" style="font-size:1.1rem; color:var(--adm-amber);"></i>
        <div class="adm-banner-content">
          <div class="adm-banner-title" style="font-size:0.85rem; color:var(--adm-text-primary);">CSV Requirements:</div>
          <div class="adm-banner-body" style="font-size:0.78rem;">
            <ol style="margin: 0.25rem 0 0 0; padding-left: 1rem; line-height: 1.5;">
              <li>Required headers: <code>full_name, username, password, class_name, section</code></li>
              <li>Optional headers: <code>roll_no, father_name, phone, email</code></li>
              <li>Usernames must be unique across the entire school system</li>
              <li>Class names &amp; sections must already match existing records</li>
            </ol>
            <a href="/admin/students/import/template" class="adm-class-link-label" style="display:inline-flex; margin-top:0.75rem; color:var(--adm-indigo); font-weight:700;">
              <i class="fas fa-download" style="font-size:0.75rem;" aria-hidden="true"></i> Download Template CSV
            </a>
          </div>
        </div>
      </div>

      <form action="/admin/students/import/csv" method="POST" enctype="multipart/form-data">
        <!-- CSRF Protection -->
        <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <% } %>

        <div class="adm-form-group" style="margin-bottom: 1.5rem;">
          <label class="adm-label" for="csv_file_input" style="margin-bottom:0.25rem;">Select CSV File</label>
          <div class="adm-file-upload">
            <i class="fas fa-cloud-upload-alt adm-file-upload-icon" aria-hidden="true"></i>
            <div class="adm-file-upload-text">Click to browse or drag file here</div>
            <div class="adm-file-upload-subtext">Supports .csv files up to 5MB</div>
            <input type="file" name="csvFile" id="csv_file_input" accept=".csv" required class="adm-file-upload-input">
          </div>
        </div>

        <button type="submit" class="adm-btn adm-btn-primary" style="width: 100%; min-height:44px; justify-content:center;">
          Start Bulk Import
        </button>
      </form>
    </div>
  </div>

  <!-- ════════════════════════════════════════════════════════════
       CREDENTIALS MODAL (Reset Password)
       ════════════════════════════════════════════════════════════ -->
  <div id="credsModal" class="adm-modal-overlay" role="dialog" aria-modal="true" aria-labelledby="credsModalTitle">
    <div class="adm-modal-container adm-modal-container-sm">
      <button class="adm-modal-close-btn" onclick="window.closeModal('credsModal')" aria-label="Close modal" type="button">
        <i class="fas fa-times" aria-hidden="true"></i>
      </button>

      <div style="text-align: center; margin-bottom: 1.5rem;">
        <div style="width: 54px; height: 54px; background: var(--adm-indigo-bg); color: var(--adm-indigo); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.35rem; margin: 0 auto 0.75rem;">
          <i class="fas fa-key" aria-hidden="true"></i>
        </div>
        <h2 id="credsModalTitle" style="font-weight: 700; font-size:1.25rem;">Manage Credentials</h2>
        <p style="color: var(--adm-text-muted); font-size: 0.85rem; margin-top:0.25rem;">
          Reset password for <span id="credsUsername" style="font-weight: 700; color: var(--adm-text-primary);"></span>
        </p>
      </div>

      <form action="/admin/users/reset-password" method="POST">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <input type="hidden" name="user_id" id="credsUserId">
        <input type="hidden" name="return_url" id="credsReturnUrl" value="/admin/students">

        <div class="adm-form-group" style="margin-bottom: 1.5rem;">
          <label class="adm-label" for="reset_new_password">New Password</label>
          <input type="text" name="new_password" id="reset_new_password" required placeholder="Enter new password" class="adm-input" style="font-family:'JetBrains Mono', monospace; font-weight: 600;">
        </div>

        <button type="submit" class="adm-btn adm-btn-primary" style="width: 100%; min-height:42px; justify-content:center;">
          Update Password
        </button>
      </form>
    </div>
  </div>

  <!-- Table Filter Script -->
  <script>
    function openCredsModal(userId, username) {
      window.openModal('credsModal');
      document.getElementById('credsUserId').value = userId;
      document.getElementById('credsUsername').innerText = '@' + username;
      document.getElementById('credsReturnUrl').value = window.location.href;
    }

    // Filter table content locally
    function filterTable(inputId, tableId) {
      const input = document.getElementById(inputId);
      if (!input) return;
      const filter = input.value.toLowerCase();
      const tbody = document.getElementById(tableId);
      if (!tbody) return;
      const rows = tbody.getElementsByTagName('tr');

      for (let i = 0; i < rows.length; i++) {
        const row = rows[i];
        const text = row.textContent.toLowerCase();
        row.style.display = text.includes(filter) ? "" : "none";
      }
    }
  </script>

<%- include('../partials/footer') %>
<%- include('../partials/header') %>

  <!-- ════════════════════════════════════════════════════════════
       ADMIN LAYOUT
       ════════════════════════════════════════════════════════════ -->
  <div class="adm-layout">

    <!-- Sidebar -->
    <%- include('../partials/sidebar', { active: 'classes' }) %>

    <!-- ══ MAIN CONTENT ══════════════════════════════════════════ -->
    <main class="adm-main" role="main" aria-label="Class management">

      <!-- ── Page Header ── -->
      <div class="adm-page-header">
        <div>
          <h1 class="adm-page-title">Class Management</h1>
          <p class="adm-page-subtitle">Define school grades, sections, and monthly fee structures</p>
        </div>

        <button class="adm-btn adm-btn-primary" onclick="window.openModal('addModal')" type="button">
          <i class="fas fa-layer-group" aria-hidden="true"></i> Create New Class
        </button>
      </div>

      <!-- ── Class Cards Grid ── -->
      <div class="adm-class-grid">
        <% classes.forEach(cls => { %>
          <div class="adm-class-card" style="padding-bottom: 1.5rem;">
            
            <div class="adm-class-icon" style="background: var(--adm-indigo-bg); color: var(--adm-indigo);">
              <i class="fas fa-chalkboard" aria-hidden="true"></i>
            </div>
            
            <h2 class="adm-class-title"><%= cls.class_name %></h2>
            <span class="adm-class-section" style="margin-bottom: 0.75rem;">Section: <%= cls.section %></span>

            <% if (typeof isSuperAdmin !== 'undefined' && isSuperAdmin && cls.campus_name) { %>
              <span class="adm-badge adm-badge-blue" style="margin-bottom: 0.75rem;">
                <i class="fas fa-building" style="margin-right:0.25rem;" aria-hidden="true"></i> <%= cls.campus_name %>
              </span>
            <% } %>

            <!-- Teacher Info Box -->
            <div style="width: 100%; background: var(--adm-bg-canvas); padding: 0.75rem; border-radius: var(--adm-r-md); border: 1px solid var(--adm-border); margin: 0.5rem 0 1rem; display: flex; flex-direction: column; align-items: center; gap: 0.25rem;">
              <span style="font-size: 0.75rem; font-weight: 600; color: var(--adm-text-muted); text-transform: uppercase; letter-spacing: 0.05em;">Class Teacher</span>
              <span style="font-weight: 700; color: var(--adm-text-primary); font-size: 0.95rem;">
                <i class="fas fa-user-graduate" style="color: var(--adm-indigo); margin-right: 0.25rem;" aria-hidden="true"></i>
                <%= cls.teacher_name || 'Not Assigned' %>
              </span>
            </div>

            <div style="font-size: 1.1rem; font-weight: 800; color: var(--adm-text-primary); margin-bottom: 1.5rem;">
              Fee: RS <%= cls.monthly_fee ? Number(cls.monthly_fee).toLocaleString() : '0' %>
            </div>

            <!-- Action Buttons Grid -->
            <div style="width: 100%; display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 0.5rem;">
              <button 
                class="adm-btn adm-btn-ghost" 
                onclick="openEditModal('<%= cls.id %>', '<%= cls.monthly_fee %>')"
                type="button"
                style="justify-content: center; background: var(--adm-indigo-bg); color: var(--adm-indigo);"
              >
                <i class="fas fa-edit" aria-hidden="true"></i> Fee
              </button>
              
              <button 
                class="adm-btn adm-btn-ghost" 
                onclick="openAssignModal('<%= cls.id %>', '<%= cls.class_teacher_id %>')"
                type="button"
                style="justify-content: center; background: var(--adm-green-bg); color: var(--adm-green);"
              >
                <i class="fas fa-user-plus" aria-hidden="true"></i> Teacher
              </button>
            </div>
            
            <a 
              href="/admin/classes/delete/<%= cls.id %>" 
              class="adm-btn adm-btn-ghost" 
              style="width: 100%; justify-content: center; color: var(--adm-red); background: var(--adm-red-bg);"
              onclick="return confirm('Delete this class? Error if students are assigned.')"
            >
              <i class="fas fa-trash" aria-hidden="true"></i> Delete Class
            </a>

          </div>
        <% }) %>
        
        <% if (classes.length === 0) { %>
          <div style="grid-column: 1 / -1; padding: 4.5rem; text-align: center; color: var(--adm-text-muted); background: var(--adm-bg-surface); border-radius: var(--adm-r-lg); border: 1px dashed var(--adm-border);">
            <i class="fas fa-layer-group" style="font-size: 2.5rem; opacity: 0.25; display: block; margin-bottom: 1rem;" aria-hidden="true"></i>
            No classes defined yet.
          </div>
        <% } %>
      </div>

    </main>
  </div>

  <!-- ════════════════════════════════════════════════════════════
       CREATE CLASS MODAL
       ════════════════════════════════════════════════════════════ -->
  <div id="addModal" class="adm-modal-overlay" role="dialog" aria-modal="true" aria-labelledby="addModalTitle">
    <div class="adm-modal-container adm-modal-container-sm">
      <button class="adm-modal-close-btn" onclick="window.closeModal('addModal')" aria-label="Close modal" type="button">
        <i class="fas fa-times" aria-hidden="true"></i>
      </button>

      <h2 id="addModalTitle" style="font-weight: 700; font-size:1.35rem; margin-bottom: 0.25rem;">New Class</h2>
      <p style="color: var(--adm-text-muted); font-size: 0.85rem; margin-bottom: 1.75rem;">Create a new grade and section entry.</p>

      <form action="/admin/classes/add" method="POST">
        <!-- CSRF Protection -->
        <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <% } %>

        <div class="adm-form-group" style="margin-bottom: 1.25rem;">
          <label class="adm-label" for="add_class_name">Class Name</label>
          <input type="text" name="class_name" id="add_class_name" placeholder="e.g. Grade 10" required class="adm-input">
        </div>

        <div class="adm-form-group" style="margin-bottom: 1.25rem;">
          <label class="adm-label" for="add_section">Section</label>
          <input type="text" name="section" id="add_section" placeholder="e.g. A" required class="adm-input">
        </div>

        <div class="adm-form-group" style="margin-bottom: 1.75rem;">
          <label class="adm-label" for="add_monthly_fee">Monthly Fee (RS)</label>
          <input type="number" name="monthly_fee" id="add_monthly_fee" placeholder="e.g. 2500" required class="adm-input">
        </div>

        <button type="submit" class="adm-btn adm-btn-primary" style="width: 100%; min-height:44px; justify-content:center;">
          Establish Class
        </button>
      </form>
    </div>
  </div>

  <!-- ════════════════════════════════════════════════════════════
       EDIT FEE MODAL
       ════════════════════════════════════════════════════════════ -->
  <div id="editModal" class="adm-modal-overlay" role="dialog" aria-modal="true" aria-labelledby="editModalTitle">
    <div class="adm-modal-container adm-modal-container-sm">
      <h2 id="editModalTitle" style="font-weight: 700; font-size:1.35rem; margin-bottom: 1.5rem; color: var(--adm-text-primary);">Update Class Fee</h2>
      
      <form action="/admin/classes/update-fee" method="POST">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <input type="hidden" name="class_id" id="edit_class_id">
        
        <div class="adm-form-group" style="margin-bottom: 2rem;">
          <label class="adm-label" for="edit_monthly_fee">New Monthly Fee (RS)</label>
          <input type="number" name="monthly_fee" id="edit_monthly_fee" required class="adm-input">
        </div>
        
        <div style="display: flex; gap: 0.75rem;">
          <button type="button" onclick="window.closeModal('editModal')" class="adm-btn adm-btn-ghost" style="flex: 1; justify-content:center;">
            Cancel
          </button>
          <button type="submit" class="adm-btn adm-btn-primary" style="flex: 1; justify-content:center;">
            Update Now
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- ════════════════════════════════════════════════════════════
       ASSIGN TEACHER MODAL
       ════════════════════════════════════════════════════════════ -->
  <div id="assignModal" class="adm-modal-overlay" role="dialog" aria-modal="true" aria-labelledby="assignModalTitle">
    <div class="adm-modal-container adm-modal-container-sm">
      <h2 id="assignModalTitle" style="font-weight: 700; font-size:1.35rem; margin-bottom: 1.5rem; color: var(--adm-text-primary);">Assign Class Teacher</h2>
      
      <form action="/admin/classes/assign-teacher" method="POST">
        <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <input type="hidden" name="class_id" id="assign_class_id">
        
        <div class="adm-form-group" style="margin-bottom: 2rem;">
          <label class="adm-label" for="assign_teacher_id">Select Teacher</label>
          <select name="teacher_id" id="assign_teacher_id" class="adm-select">
            <option value="">-- No Teacher Assigned --</option>
            <% teachers.forEach(t => { %>
              <option value="<%= t.id %>"><%= t.full_name %></option>
            <% }) %>
          </select>
        </div>
        
        <div style="display: flex; gap: 0.75rem;">
          <button type="button" onclick="window.closeModal('assignModal')" class="adm-btn adm-btn-ghost" style="flex: 1; justify-content:center;">
            Cancel
          </button>
          <button type="submit" class="adm-btn adm-btn-primary" style="flex: 1; justify-content:center; background: var(--adm-green); border-color: var(--adm-green);">
            Assign Now
          </button>
        </div>
      </form>
    </div>
  </div>

  <script>
    function openEditModal(id, currentFee) {
      window.openModal('editModal');
      document.getElementById('edit_class_id').value = id;
      document.getElementById('edit_monthly_fee').value = currentFee;
    }

    function openAssignModal(classId, currentTeacherId) {
      window.openModal('assignModal');
      document.getElementById('assign_class_id').value = classId;
      document.getElementById('assign_teacher_id').value = currentTeacherId || "";
    }
  </script>

<%- include('../partials/footer') %>
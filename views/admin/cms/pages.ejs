<%- include('../../partials/header') %>
    <div class="admin-layout animate-fade-in" style="margin-top: 80px;">
        <%- include('../../partials/sidebar', { active: 'cms' }) %>

            <main class="main-content">
                <header class="page-header"
                    style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
                    <div>
                        <h1 style="font-size: 2rem; color: var(--primary); font-weight: 800;">Website Content Manager
                        </h1>
                        <p style="color: var(--text-muted);">Manage your website pages and content simply.</p>
                    </div>
                    <div style="display: flex; gap: 10px;">
                        <a href="/admin/cms/menus" class="btn-primary" style="background: var(--success);">
                            <i class="fas fa-list"></i> Menus
                        </a>
                        <a href="/admin/cms/settings" class="btn-primary" style="background: var(--secondary);">
                            <i class="fas fa-cog"></i> Global Settings
                        </a>
                    </div>
                </header>

                <div class="grid" style="grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2rem;">
                    <% pages.forEach(page=> { %>
                        <div class="card animate-slide-up"
                            style="border-top: 5px solid <%= page.is_homepage ? 'var(--primary)' : '#cbd5e1' %>; position: relative;">

                            <% if (page.is_homepage) { %>
                                <div
                                    style="position: absolute; top: 10px; right: 10px; background: var(--primary); color: white; padding: 5px 10px; border-radius: 20px; font-size: 0.7rem; font-weight: 700;">
                                    HOMEPAGE</div>
                                <% } %>

                                    <h3 style="margin-bottom: 0.5rem; font-weight: 700;">
                                        <%= page.title %>
                                    </h3>
                                    <p style="color: var(--text-muted); font-size: 0.9rem; margin-bottom: 1.5rem;">/<%=
                                            page.slug %>
                                    </p>

                                    <div
                                        style="display: flex; justify-content: space-between; align-items: center; background: #f8fafc; padding: 10px; border-radius: 10px;">
                                        <span class="status-badge <%= page.status %>"
                                            style="text-transform: capitalize;">
                                            <%= page.status %>
                                        </span>
                                        <a href="/admin/cms/pages/edit/<%= page.id %>" class="btn-sm"
                                            style="background: var(--primary); color: white; text-decoration: none; padding: 8px 15px; border-radius: 8px;">
                                            Edit Content <i class="fas fa-arrow-right"></i>
                                        </a>
                                    </div>
                        </div>
                        <% }) %>
                </div>
            </main>

    </div>
    </body>

    </html>
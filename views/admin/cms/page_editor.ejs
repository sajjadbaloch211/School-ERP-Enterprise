<%- include('../../partials/header') %>
<div class="admin-layout animate-fade-in" style="margin-top: 80px;">
    <%- include('../../partials/sidebar', { active: 'cms' }) %>

    <main class="main-content">

        <!-- TOP HEADER -->
        <div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1rem; margin-bottom:2rem;">
            <div>
                <a href="/admin/cms/pages" style="color:var(--text-muted); text-decoration:none; font-size:0.85rem; font-weight:600;">
                    <i class="fas fa-arrow-left"></i> All Pages
                </a>
                <h1 style="font-size:1.75rem; color:var(--primary); font-weight:800; margin-top:0.5rem;">
                    📄 Page Editor: <span style="color:var(--secondary);"><%= page.title %></span>
                </h1>
                <p style="color:var(--text-muted); font-size:0.85rem; margin:0;">
                    Click <strong>✏️ Edit</strong> on any section below to change its content, images, and links.
                </p>
            </div>
            <a href="/<%= page.slug === 'home' ? '' : page.slug %>" target="_blank"
               style="background:var(--indigo); color:white; padding:10px 20px; border-radius:10px; text-decoration:none; font-weight:700; font-size:0.85rem;">
                <i class="fas fa-external-link-alt"></i> Preview Live Page
            </a>
        </div>

        <!-- SUCCESS BANNER -->
        <% if (typeof locals.query !== 'undefined' || (typeof req !== 'undefined' && req.query && req.query.saved)) { %>
        <% } %>
        <div id="savedBanner" style="display:none; margin-bottom:1.5rem; background:#d1fae5; border:1px solid #6ee7b7; padding:1rem 1.5rem; border-radius:12px; display:flex; align-items:center; gap:1rem;">
            <i class="fas fa-check-circle" style="color:#10b981; font-size:1.25rem;"></i>
            <span style="font-weight:700; color:#065f46;">Changes saved! Your page has been updated.</span>
        </div>
        <script>
            if (window.location.search.includes('saved=true')) {
                document.getElementById('savedBanner').style.display = 'flex';
                // Clean URL
                history.replaceState({}, '', window.location.pathname);
            }
        </script>

        <!-- SECTIONS LIST -->
        <div style="display:flex; flex-direction:column; gap:1rem; margin-bottom:3rem;">
            <% if (sections.length === 0) { %>
            <div class="adm-card" style="text-align:center; padding:3rem;">
                <i class="fas fa-layer-group" style="font-size:3rem; color:#cbd5e1; margin-bottom:1rem;"></i>
                <h3 style="color:var(--text-muted);">No Sections Yet</h3>
                <p style="color:var(--text-muted);">Add your first content block below.</p>
            </div>
            <% } %>

            <% sections.forEach((section, index) => { %>
            <%
                const sectionIcons = {
                    hero: '🏠', features: '⭐', stats: '📊',
                    gallery: '🖼️', text: '📄', content: '📄'
                };
                const sectionDescs = {
                    hero: 'Main banner — headline, image, and call-to-action buttons',
                    features: 'Grid of feature cards with icons',
                    stats: 'Animated number counters',
                    gallery: 'Photo gallery grid',
                    text: 'Rich text content block',
                    content: 'Rich text content block'
                };
            %>
            <div class="adm-card" style="border-left: 5px solid <%= section.enabled ? 'var(--indigo)' : '#cbd5e1' %>;">
                <div style="display:flex; align-items:center; gap:1.5rem; padding:1.25rem 1.5rem;">
                    <!-- Order Number -->
                    <div style="font-size:2rem; font-weight:800; color:#e2e8f0; flex-shrink:0; width:40px; text-align:center;">
                        <%= String(index + 1).padStart(2, '0') %>
                    </div>

                    <!-- Icon -->
                    <div style="font-size:2rem; flex-shrink:0;">
                        <%= sectionIcons[section.section_type] || '📦' %>
                    </div>

                    <!-- Info -->
                    <div style="flex:1; min-width:0;">
                        <div style="display:flex; align-items:center; gap:0.75rem; margin-bottom:0.25rem; flex-wrap:wrap;">
                            <h3 style="font-weight:700; margin:0; font-size:1rem;"><%= section.section_name %></h3>
                            <span style="background:var(--indigo-bg); color:var(--indigo); padding:2px 8px; border-radius:6px; font-size:0.7rem; font-weight:700; text-transform:uppercase;">
                                <%= section.section_type %>
                            </span>
                            <% if (!section.enabled) { %>
                            <span style="background:#fef3c7; color:#92400e; padding:2px 8px; border-radius:6px; font-size:0.7rem; font-weight:700;">HIDDEN</span>
                            <% } %>
                        </div>
                        <p style="color:var(--text-muted); font-size:0.82rem; margin:0;">
                            <%= sectionDescs[section.section_type] || 'Custom section' %>
                        </p>
                    </div>

                    <!-- Actions -->
                    <div style="display:flex; gap:0.5rem; flex-shrink:0;">
                        <a href="/admin/cms/sections/edit/<%= section.id %>" class="adm-btn adm-btn-primary"
                           style="text-decoration:none; font-size:0.85rem;">
                            <i class="fas fa-edit"></i> Edit Content
                        </a>
                        <form action="/admin/cms/sections/delete/<%= section.id %>" method="POST"
                              onsubmit="return confirm('Delete this section? This CANNOT be undone.');">
                            <input type="hidden" name="_csrf" value="<%= locals.csrfToken %>">
                            <button type="submit" class="adm-btn" 
                                    style="background:#fef2f2; color:#ef4444; border:1px solid #fecaca;">
                                <i class="fas fa-trash"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
            <% }); %>
        </div>

        <!-- ADD NEW SECTION BLOCK -->
        <div class="adm-card" style="border:2px dashed #cbd5e1; background:#f8fafc;">
            <div class="adm-card-body">
                <h3 style="font-weight:800; color:var(--text-muted); text-align:center; margin-bottom:1.5rem;">
                    ➕ Add a New Content Block
                </h3>

                <form action="/admin/cms/sections/add" method="POST">
                    <input type="hidden" name="_csrf" value="<%= locals.csrfToken %>">
                    <input type="hidden" name="page_id" value="<%= page.id %>">

                    <div style="display:grid; grid-template-columns:1fr 1fr auto; gap:1rem; align-items:end; flex-wrap:wrap;">
                        <div class="adm-form-group" style="margin:0;">
                            <label class="adm-label">Section Name (for your reference)</label>
                            <input type="text" name="section_name" class="adm-input"
                                   placeholder="e.g. Homepage Hero, Why Choose Us" required>
                        </div>
                        <div class="adm-form-group" style="margin:0;">
                            <label class="adm-label">Section Layout Type</label>
                            <select name="section_type" class="adm-input adm-select" required>
                                <option value="" disabled selected>Choose a layout...</option>
                                <option value="hero">🏠 Hero / Banner — Big title + image + buttons</option>
                                <option value="features">⭐ Features Grid — Icon cards grid</option>
                                <option value="stats">📊 Stats Counter — Numbers (1000 students etc)</option>
                                <option value="gallery">🖼️ Gallery — Photo grid</option>
                                <option value="text">📄 Text Block — Rich body text</option>
                            </select>
                        </div>
                        <button type="submit" class="adm-btn adm-btn-primary" style="height:42px;">
                            <i class="fas fa-plus"></i> Add Block
                        </button>
                    </div>
                </form>

                <!-- Section type descriptions -->
                <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(180px,1fr)); gap:1rem; margin-top:1.5rem;">
                    <div style="padding:1rem; background:white; border-radius:10px; border:1px solid #e2e8f0; text-align:center;">
                        <div style="font-size:1.75rem; margin-bottom:0.5rem;">🏠</div>
                        <strong style="font-size:0.85rem;">Hero / Banner</strong>
                        <p style="color:var(--text-muted); font-size:0.75rem; margin:4px 0 0;">Big title, image, and buttons</p>
                    </div>
                    <div style="padding:1rem; background:white; border-radius:10px; border:1px solid #e2e8f0; text-align:center;">
                        <div style="font-size:1.75rem; margin-bottom:0.5rem;">⭐</div>
                        <strong style="font-size:0.85rem;">Features Grid</strong>
                        <p style="color:var(--text-muted); font-size:0.75rem; margin:4px 0 0;">Cards with icons and descriptions</p>
                    </div>
                    <div style="padding:1rem; background:white; border-radius:10px; border:1px solid #e2e8f0; text-align:center;">
                        <div style="font-size:1.75rem; margin-bottom:0.5rem;">📊</div>
                        <strong style="font-size:0.85rem;">Stats Counter</strong>
                        <p style="color:var(--text-muted); font-size:0.75rem; margin:4px 0 0;">Animated numbers showcase</p>
                    </div>
                    <div style="padding:1rem; background:white; border-radius:10px; border:1px solid #e2e8f0; text-align:center;">
                        <div style="font-size:1.75rem; margin-bottom:0.5rem;">🖼️</div>
                        <strong style="font-size:0.85rem;">Gallery</strong>
                        <p style="color:var(--text-muted); font-size:0.75rem; margin:4px 0 0;">Photo grid display</p>
                    </div>
                    <div style="padding:1rem; background:white; border-radius:10px; border:1px solid #e2e8f0; text-align:center;">
                        <div style="font-size:1.75rem; margin-bottom:0.5rem;">📄</div>
                        <strong style="font-size:0.85rem;">Text Block</strong>
                        <p style="color:var(--text-muted); font-size:0.75rem; margin:4px 0 0;">Paragraphs and rich content</p>
                    </div>
                </div>
            </div>
        </div>

    </main>
</div>
</body>
</html>
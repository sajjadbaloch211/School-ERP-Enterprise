<%- include('../../partials/header') %>
    <div class="admin-layout animate-fade-in" style="margin-top: 80px;">
        <%- include('../../partials/sidebar', { active: 'cms' }) %>

            <main class="main-content">
                <div style="margin-bottom: 2rem;">
                    <a href="/admin/cms/pages"
                        style="color: var(--text-muted); text-decoration: none; font-weight: 600;">
                        <i class="fas fa-arrow-left"></i> Back to Dashboard
                    </a>
                    <h1 style="font-size: 2rem; color: var(--primary); font-weight: 800; margin-top: 1rem;">Global
                        Settings
                    </h1>
                </div>

                <div class="card" style="padding: 2rem;">
                    <form action="/admin/cms/settings/update" method="POST" enctype="multipart/form-data">
                        <input type="hidden" name="_csrf" value="<%= locals.csrfToken %>">

                        <div class="form-group">
                            <label>Site Name</label>
                            <input type="text" name="site_name" class="form-control"
                                value="<%= settings.site_name || '' %>" required>
                        </div>

                        <div class="form-group">
                            <label>Contact Email</label>
                            <input type="email" name="contact_email" class="form-control"
                                value="<%= settings.contact_email || '' %>">
                        </div>

                        <div class="form-group">
                            <label>Contact Phone</label>
                            <input type="text" name="contact_phone" class="form-control"
                                value="<%= settings.contact_phone || '' %>">
                        </div>

                        <div class="form-group">
                            <label>School Address</label>
                            <textarea name="address" class="form-control"
                                rows="2"><%= settings.address || '' %></textarea>
                        </div>

                        <div class="form-group">
                            <label>School Logo</label>
                            <% if (settings.site_logo) { %>
                                <div
                                    style="margin-bottom: 15px; background: #f8fafc; padding: 10px; border-radius: 8px; display: inline-block;">
                                    <img src="<%= settings.site_logo %>" style="height: 60px;">
                                </div>
                                <% } %>
                                    <input type="file" name="site_logo" class="form-control" accept="image/*">
                                    <small style="color: var(--text-muted);">Leave empty to keep current logo</small>
                        </div>

                        <button type="submit" class="btn-primary" style="width: 100%; margin-top: 2rem;">Update Global
                            Settings</button>
                    </form>
                </div>
            </main>

    </div>
    </body>

    </html>
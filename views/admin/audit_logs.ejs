<%- include('../partials/header') %>

  <!-- ════════════════════════════════════════════════════════════
       ADMIN LAYOUT
       ════════════════════════════════════════════════════════════ -->
  <div class="adm-layout">

    <!-- Sidebar -->
    <%- include('../partials/sidebar', { active: 'audit-logs' }) %>

    <!-- ══ MAIN CONTENT ══════════════════════════════════════════ -->
    <main class="adm-main" role="main" aria-label="Security Monitoring Logs">

      <!-- ── Page Header ── -->
      <div class="adm-page-header">
        <div>
          <h1 class="adm-page-title">Security Monitoring</h1>
          <p class="adm-page-subtitle">Real-time tracking of user logins, locations, and potential threats.</p>
        </div>
      </div>

      <!-- ── KPI Cards ── -->
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
        
        <!-- Total Events -->
        <article class="adm-kpi-card" style="border-left-color: var(--adm-blue);">
          <div class="adm-kpi-icon" style="background: var(--adm-blue-bg); color: var(--adm-blue);">
            <i class="fas fa-history" aria-hidden="true"></i>
          </div>
          <div class="adm-kpi-content">
            <h3 class="adm-kpi-title">Total Events</h3>
            <div class="adm-kpi-value" data-target="<%= totalCount %>">
              <%= totalCount %>
            </div>
          </div>
        </article>

        <!-- High Risk Alerts -->
        <% const highRiskCount = logs.filter(l => l.risk_level === 'High' || l.risk_level === 'Medium').length; %>
        <article class="adm-kpi-card" style="border-left-color: var(--adm-red);">
          <div class="adm-kpi-icon" style="background: var(--adm-red-bg); color: var(--adm-red);">
            <i class="fas fa-exclamation-triangle" aria-hidden="true"></i>
          </div>
          <div class="adm-kpi-content">
            <h3 class="adm-kpi-title">High Risk Alerts</h3>
            <div class="adm-kpi-value" data-target="<%= highRiskCount %>">
              <%= highRiskCount %>
            </div>
          </div>
        </article>

        <!-- Unique IPs -->
        <% const uniqueIPs = [...new Set(logs.map(item => item.ip_address))]; %>
        <article class="adm-kpi-card" style="border-left-color: var(--adm-green);">
          <div class="adm-kpi-icon" style="background: var(--adm-green-bg); color: var(--adm-green);">
            <i class="fas fa-globe-americas" aria-hidden="true"></i>
          </div>
          <div class="adm-kpi-content">
            <h3 class="adm-kpi-title">Unique IP Sources</h3>
            <div class="adm-kpi-value" data-target="<%= uniqueIPs.length %>">
              <%= uniqueIPs.length %>
            </div>
          </div>
        </article>

      </div>

      <!-- ── Audit Data Table ── -->
      <div class="adm-card" style="padding: 0; overflow: hidden;">
        
        <div style="padding: 1.5rem; border-bottom: 1px solid var(--adm-border); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
          <h2 style="font-size: 1.25rem; font-weight: 800; color: var(--adm-text-primary); display: flex; align-items: center; gap: 0.5rem; margin: 0;">
            <i class="fas fa-shield-alt" style="color: var(--adm-indigo);" aria-hidden="true"></i> System Audit Logs
          </h2>
          
          <!-- Search Bar -->
          <div style="position: relative; max-width: 350px; width: 100%;">
            <i class="fas fa-search" aria-hidden="true" style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: var(--adm-text-muted);"></i>
            <input type="text" id="logSearch" placeholder="Search logs..." class="adm-input" style="padding-left: 2.5rem; border-radius: 9999px;" onkeyup="filterTable()">
          </div>
        </div>

        <div style="overflow-x: auto;">
          <table class="adm-table" id="auditTable" aria-label="Security Audit Log">
            <thead>
              <tr>
                <th scope="col">Time</th>
                <th scope="col">User / Role</th>
                <th scope="col">Action</th>
                <th scope="col">IP & Location</th>
                <th scope="col">Device OS</th>
                <th scope="col">Risk Level</th>
                <th scope="col" style="text-align: right;">Geolocation</th>
              </tr>
            </thead>
            <tbody id="logTableBody">
              
              <% if (logs.length === 0) { %>
                <tr>
                  <td colspan="7" style="text-align: center; padding: 4rem 1rem;">
                    <div class="adm-empty-state">
                      <i class="fas fa-clipboard-check adm-empty-icon" aria-hidden="true"></i>
                      <h3>No Audit Logs Found</h3>
                      <p>There are no recorded security events in the system yet.</p>
                    </div>
                  </td>
                </tr>
              <% } %>

              <% logs.forEach(log => { %>
                <tr class="log-row">
                  <td style="font-family: 'JetBrains Mono', monospace; font-weight: 600; color: var(--adm-text-primary);">
                    <%= new Date(log.created_at).toLocaleString() %>
                  </td>
                  
                  <td>
                    <div style="font-weight: 700; color: var(--adm-indigo);">
                      <%= log.user_id ? 'ID: ' + log.user_id : 'System / Unknown' %>
                    </div>
                    <div style="font-size: 0.75rem; color: var(--adm-text-muted); font-weight: 600; text-transform: uppercase;">
                      <%= log.role || 'GUEST' %>
                    </div>
                  </td>
                  
                  <td>
                    <% 
                      let actionClass = 'adm-badge-blue';
                      if(log.action.includes('FAIL') || log.action.includes('ERROR')) { actionClass = 'adm-badge-red'; }
                      else if(log.action.includes('LOGIN') || log.action.includes('SUCCESS')) { actionClass = 'adm-badge-green'; }
                    %>
                    <span class="adm-badge <%= actionClass %>" style="font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; letter-spacing: 0.5px;">
                      <%= log.action %>
                    </span>
                  </td>
                  
                  <td>
                    <div style="font-family: 'JetBrains Mono', monospace; font-weight: 700; color: var(--adm-text-primary);">
                      <%= log.ip_address %>
                    </div>
                    <div style="font-size: 0.75rem; color: var(--adm-text-muted); font-weight: 600;">
                      <i class="fas fa-map-marker-alt" aria-hidden="true" style="margin-right: 0.25rem;"></i> <%= log.city || 'Unknown' %>, <%= log.country || 'Unknown' %>
                    </div>
                  </td>
                  
                  <td>
                    <div style="font-weight: 600; color: var(--adm-text-primary); font-size: 0.9rem;">
                      <i class="fas fa-desktop" aria-hidden="true" style="color: var(--adm-text-muted); margin-right: 0.25rem;"></i> <%= log.device || 'Unknown' %>
                    </div>
                    <div style="font-size: 0.75rem; color: var(--adm-text-muted); font-weight: 600;">
                      <%= log.os || 'Unknown OS' %>
                    </div>
                  </td>
                  
                  <td>
                    <% 
                      let riskClass = 'adm-badge-blue';
                      if(log.risk_level === 'High') { riskClass = 'adm-badge-red'; }
                      else if(log.risk_level === 'Medium') { riskClass = 'adm-badge-amber'; }
                      else if(log.risk_level === 'Low') { riskClass = 'adm-badge-green'; }
                    %>
                    <span class="adm-badge <%= riskClass %>" style="font-weight: 800;">
                      <%= log.risk_level %>
                    </span>
                  </td>
                  
                  <td style="text-align: right;">
                    <% if(log.latitude && log.longitude) { %>
                      <button type="button" onclick="viewMap(<%= log.latitude %>, <%= log.longitude %>, '<%= log.ip_address %>')" class="adm-btn adm-btn-ghost" style="padding: 0.5rem 0.75rem;" aria-label="View Map Location">
                        <i class="fas fa-map-marked-alt" aria-hidden="true" style="color: var(--adm-indigo);"></i> Map
                      </button>
                    <% } else { %>
                      <span style="color: var(--adm-text-muted); font-size: 0.8rem; padding-right: 1rem;">-</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

    </main>
  </div>

  <!-- ══ MODALS ══════════════════════════════════════════════════ -->

  <!-- Leaflet Map Modal -->
  <div id="mapModal" class="adm-modal" aria-labelledby="mapModalTitle" aria-hidden="true" role="dialog">
    <div class="adm-modal-content" style="max-width: 800px; padding: 0; overflow: hidden; display: flex; flex-direction: column;">
      
      <!-- Header -->
      <div class="adm-modal-header" style="padding: 1.5rem;">
        <h2 id="mapModalTitle" class="adm-modal-title">Geolocation Source</h2>
        <button type="button" class="adm-modal-close" onclick="window.closeModal('mapModal')" aria-label="Close modal">
          <i class="fas fa-times" aria-hidden="true"></i>
        </button>
      </div>
      
      <!-- Map Container -->
      <div id="mapContainer" style="width: 100%; height: 450px; background: var(--adm-bg-surface); z-index: 1;"></div>
      
    </div>
  </div>

  <!-- Leaflet CSS/JS (For Maps) -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.7.1/dist/leaflet.css" />
  <script src="https://unpkg.com/leaflet@1.7.1/dist/leaflet.js"></script>

  <script>
    // Search Filtering
    function filterTable() {
      const input = document.getElementById('logSearch');
      const filter = input.value.toLowerCase();
      const tbody = document.getElementById('logTableBody');
      const rows = tbody.getElementsByClassName('log-row');

      for (let i = 0; i < rows.length; i++) {
        const text = rows[i].textContent.toLowerCase();
        rows[i].style.display = text.includes(filter) ? "" : "none";
      }
    }

    // Leaflet Map Logic
    let map = null;

    function viewMap(lat, lng, ip) {
      // 1. Open our standard accessible modal
      window.openModal('mapModal');

      // 2. Clear previous map instance if it exists to prevent initialization errors
      if (map) {
        map.remove();
      }

      // 3. Initialize map after a brief delay to ensure modal display completes (DOM dimensions are valid)
      setTimeout(() => {
        map = L.map('mapContainer').setView([lat, lng], 13);
        
        // Add dark/light compatible tiles
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
          attribution: '&copy; OpenStreetMap contributors'
        }).addTo(map);

        L.marker([lat, lng]).addTo(map)
          .bindPopup(`<strong style="font-family: monospace;">IP: ${ip}</strong><br>Detected Login Location`).openPopup();
      }, 150);
    }
  </script>

<%- include('../partials/footer') %>
<%- include('../partials/header') %>

  <!-- ════════════════════════════════════════════════════════════
       ADMIN LAYOUT
       ════════════════════════════════════════════════════════════ -->
  <div class="adm-layout">

    <!-- Sidebar -->
    <%- include('../partials/sidebar', { active: 'fees' }) %>

    <!-- ══ MAIN CONTENT ══════════════════════════════════════════ -->
    <main class="adm-main" role="main" aria-label="Fees Master Ledger">

      <!-- ── Page Header ── -->
      <div class="adm-page-header">
        <div>
          <h1 class="adm-page-title">Master Ledger Center</h1>
          <p class="adm-page-subtitle">One-Voucher Policy: Managing school revenue through master student ledgers</p>
        </div>

        <div style="display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap;">
          <a href="/admin/dashboard" class="adm-btn adm-btn-ghost">
            <i class="fas fa-arrow-left" aria-hidden="true"></i> Back
          </a>
          <!-- Example: Add Fee (currently unimplemented modal, but keeping button for UX parity) -->
          <button class="adm-btn adm-btn-ghost" onclick="alert('Feature under development.')">
            <i class="fas fa-plus-circle" aria-hidden="true"></i> Add Fee
          </button>
          <button class="adm-btn adm-btn-primary" onclick="window.openModal('generateModal')" style="background: var(--adm-indigo); border-color: var(--adm-indigo);">
            <i class="fas fa-magic" aria-hidden="true"></i> Sync Monthly Fees
          </button>
          <a href="/admin/fees/export/excel" class="adm-btn adm-btn-primary" style="background: var(--adm-green); border-color: var(--adm-green);">
            <i class="fas fa-file-excel" aria-hidden="true"></i> Export Excel
          </a>
          <button onclick="window.print()" class="adm-btn adm-btn-ghost">
            <i class="fas fa-print" aria-hidden="true"></i> Annual Report
          </button>
        </div>
      </div>

      <!-- ── KPI Cards ── -->
      <% 
        const totalReceivable = vouchers.reduce((sum, v) => sum + parseFloat(v.total_charged), 0);
        const totalCollected = vouchers.reduce((sum, v) => sum + parseFloat(v.total_paid), 0);
        const totalBalance = vouchers.reduce((sum, v) => sum + parseFloat(v.remaining_balance), 0);
      %>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; margin-bottom: 2rem;">
        
        <!-- Receivable -->
        <article class="adm-kpi-card" style="border-left-color: var(--adm-blue);">
          <div class="adm-kpi-icon" style="background: var(--adm-blue-bg); color: var(--adm-blue);">
            <i class="fas fa-file-invoice-dollar" aria-hidden="true"></i>
          </div>
          <div class="adm-kpi-content">
            <h3 class="adm-kpi-title">Annual Receivable</h3>
            <div class="adm-kpi-value" data-target="<%= totalReceivable %>">
              RS <%= totalReceivable.toLocaleString() %>
            </div>
          </div>
        </article>

        <!-- Collected -->
        <article class="adm-kpi-card" style="border-left-color: var(--adm-green);">
          <div class="adm-kpi-icon" style="background: var(--adm-green-bg); color: var(--adm-green);">
            <i class="fas fa-hand-holding-usd" aria-hidden="true"></i>
          </div>
          <div class="adm-kpi-content">
            <h3 class="adm-kpi-title">Total Collected</h3>
            <div class="adm-kpi-value" data-target="<%= totalCollected %>">
              RS <%= totalCollected.toLocaleString() %>
            </div>
          </div>
        </article>

        <!-- Balance Due -->
        <article class="adm-kpi-card" style="border-left-color: var(--adm-red);">
          <div class="adm-kpi-icon" style="background: var(--adm-red-bg); color: var(--adm-red);">
            <i class="fas fa-exclamation-circle" aria-hidden="true"></i>
          </div>
          <div class="adm-kpi-content">
            <h3 class="adm-kpi-title">Current Dues Balance</h3>
            <div class="adm-kpi-value" data-target="<%= totalBalance %>">
              RS <%= totalBalance.toLocaleString() %>
            </div>
          </div>
        </article>

      </div>

      <!-- ── Data Table ── -->
      <div class="adm-card" style="padding: 0; overflow: hidden;">
        
        <div style="padding: 1.5rem; border-bottom: 1px solid var(--adm-border); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem;">
          <h2 style="font-size: 1.25rem; font-weight: 800; color: var(--adm-text-primary); display: flex; align-items: center; gap: 0.5rem; margin: 0;">
            <i class="fas fa-book-open" style="color: var(--adm-indigo);" aria-hidden="true"></i> Master Voucher Ledger
          </h2>
          
          <!-- Search Bar -->
          <div style="position: relative; max-width: 350px; width: 100%;">
            <i class="fas fa-search" style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: var(--adm-text-muted);" aria-hidden="true"></i>
            <input type="text" id="studentSearch" placeholder="Search by name, ID, class, or year..." class="adm-input" style="padding-left: 2.5rem; border-radius: 9999px;" onkeyup="filterStudents()">
          </div>
        </div>

        <div style="overflow-x: auto;">
          <table class="adm-table" id="feesTable" aria-label="Student Fees Roster">
            <thead>
              <tr>
                <th scope="col">Student / Master ID</th>
                <% if (typeof isSuperAdmin !=='undefined' && isSuperAdmin) { %>
                  <th scope="col">Campus</th>
                <% } %>
                <th scope="col">Year</th>
                <th scope="col">Annual Total</th>
                <th scope="col">Amount Paid</th>
                <th scope="col">Balance Due</th>
                <th scope="col" style="text-align: right;">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (vouchers.length === 0) { %>
                <tr>
                  <td colspan="7" style="text-align: center; padding: 4rem 1rem;">
                    <div class="adm-empty-state">
                      <i class="fas fa-file-invoice adm-empty-icon" aria-hidden="true"></i>
                      <h3>No Ledgers Found</h3>
                      <p>There are no master fee ledgers present in the system.</p>
                    </div>
                  </td>
                </tr>
              <% } %>
              
              <% vouchers.forEach(v => { %>
                <tr class="student-row">
                  <td>
                    <div style="display: flex; align-items: center; gap: 1rem;">
                      <div class="adm-avatar" style="background: var(--adm-indigo-bg); color: var(--adm-indigo); border-radius: var(--adm-r-sm); font-size: 0.8rem; font-family: monospace;">
                        #<%= v.id %>
                      </div>
                      <div>
                        <div style="font-weight: 700; color: var(--adm-text-primary);" class="student-name"><%= v.full_name %></div>
                        <div style="font-size: 0.75rem; color: var(--adm-text-muted); font-weight: 600;" class="student-class">
                          <%= v.class_name %> - <%= v.section %>
                        </div>
                      </div>
                    </div>
                  </td>
                  
                  <% if (typeof isSuperAdmin !=='undefined' && isSuperAdmin) { %>
                    <td>
                      <span class="adm-badge adm-badge-blue"><%= v.campus_name || '-' %></span>
                    </td>
                  <% } %>
                  
                  <td style="font-weight: 600;" class="student-year"><%= v.academic_year %></td>
                  <td style="font-weight: 600; color: var(--adm-text-primary);">RS <%= v.total_charged.toLocaleString() %></td>
                  <td style="font-weight: 700; color: var(--adm-green);">RS <%= v.total_paid.toLocaleString() %></td>
                  <td>
                    <div style="font-weight: 700; color: <%= v.remaining_balance > 0 ? 'var(--adm-red)' : 'var(--adm-green)' %>;">
                      RS <%= v.remaining_balance.toLocaleString() %>
                    </div>
                  </td>
                  
                  <td style="text-align: right;">
                    <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
                      <button type="button" onclick="openPaymentModal('<%= v.id %>', '<%= v.full_name %>', '<%= v.remaining_balance %>')" class="adm-btn adm-btn-ghost" style="color: var(--adm-indigo); background: var(--adm-indigo-bg); padding: 0.5rem 0.75rem;" aria-label="Pay Balance">
                        <i class="fas fa-hand-holding-usd" aria-hidden="true"></i> Pay
                      </button>
                      <a href="/receipt/<%= v.id %>" class="adm-btn adm-btn-ghost" style="padding: 0.5rem 0.75rem;" aria-label="Print Receipt">
                        <i class="fas fa-print" aria-hidden="true"></i>
                      </a>
                      <button type="button" onclick="if(confirm('Are you sure? This will delete the entire MASTER LEDGER for this student!')) window.location.href='/admin/fees/delete/<%= v.id %>'" class="adm-btn adm-btn-ghost adm-btn-danger" style="padding: 0.5rem 0.75rem;" aria-label="Delete Ledger">
                        <i class="fas fa-trash-alt" aria-hidden="true"></i>
                      </button>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

    </main>
  </div>

  <!-- ══ MODALS ══════════════════════════════════════════════════ -->

  <!-- Partial Payment Modal -->
  <div id="paymentModal" class="adm-modal" aria-labelledby="paymentModalTitle" aria-hidden="true" role="dialog">
    <div class="adm-modal-content">
      <div class="adm-modal-header">
        <h2 id="paymentModalTitle" class="adm-modal-title">Record Ledger Payment</h2>
        <button type="button" class="adm-modal-close" onclick="window.closeModal('paymentModal')" aria-label="Close modal">
          <i class="fas fa-times" aria-hidden="true"></i>
        </button>
      </div>
      <div class="adm-modal-body">
        <p id="modalStudentName" style="color: var(--adm-text-muted); font-weight: 600; margin-bottom: 1.5rem; margin-top: -0.5rem;"></p>
        <form id="paymentForm" action="" method="POST">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
          
          <div class="adm-form-group">
            <label for="paymentInput" class="adm-label">Payment Amount (RS)</label>
            <input type="number" name="payment_amount" id="paymentInput" step="0.01" min="1" required class="adm-input" style="font-size: 1.25rem; font-weight: 700; height: auto; padding: 0.75rem 1rem;">
            <p style="margin-top: 0.5rem; font-size: 0.8rem; color: var(--adm-red); font-weight: 600;">Outstanding: <span id="modalMaxAmount"></span></p>
          </div>
          
          <div class="adm-form-group">
            <label for="methodInput" class="adm-label">Payment Method</label>
            <select name="method" id="methodInput" class="adm-input">
              <option value="Cash">Cash</option>
              <option value="Bank">Bank Deposit</option>
              <option value="Online">Online Transfer</option>
            </select>
          </div>
          
          <div class="adm-modal-footer">
            <button type="button" class="adm-btn adm-btn-ghost" onclick="window.closeModal('paymentModal')">Cancel</button>
            <button type="submit" class="adm-btn adm-btn-primary">Confirm Payment</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Sync Global Fees Modal -->
  <div id="generateModal" class="adm-modal" aria-labelledby="generateModalTitle" aria-hidden="true" role="dialog">
    <div class="adm-modal-content">
      <div class="adm-modal-header">
        <h2 id="generateModalTitle" class="adm-modal-title">Sync Monthly Line Items</h2>
        <button type="button" class="adm-modal-close" onclick="window.closeModal('generateModal')" aria-label="Close modal">
          <i class="fas fa-times" aria-hidden="true"></i>
        </button>
      </div>
      <div class="adm-modal-body">
        <p style="font-size: 0.9rem; color: var(--adm-text-muted); margin-bottom: 1.5rem; margin-top: -0.5rem;">
          This will add the specified month as a line item to the master voucher of each student.
        </p>
        <form action="/admin/fees/generate-all" method="POST">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
          
          <div class="adm-form-group">
            <label for="monthInput" class="adm-label">Target Month</label>
            <select name="month" id="monthInput" class="adm-input" required>
              <% ['January','February','March','April','May','June','July','August','September','October','November','December'].forEach(m => { %>
                <option value="<%= m %>" <%= new Date().toLocaleString('default', { month: 'long' }) === m ? 'selected' : '' %>><%= m %></option>
              <% }) %>
            </select>
          </div>
          
          <div class="adm-form-group">
            <label for="yearInput" class="adm-label">Academic Year</label>
            <select name="year" id="yearInput" class="adm-input" required>
              <option value="2024-2025" selected>2024-2025</option>
              <option value="2025-2026">2025-2026</option>
            </select>
          </div>
          
          <div class="adm-form-group">
            <label for="dueDateInput" class="adm-label">Due Date</label>
            <input type="date" name="due_date" id="dueDateInput" class="adm-input" required>
          </div>
          
          <div class="adm-modal-footer">
            <button type="button" class="adm-btn adm-btn-ghost" onclick="window.closeModal('generateModal')">Cancel</button>
            <button type="submit" class="adm-btn adm-btn-primary" style="background: var(--adm-indigo); border-color: var(--adm-indigo);">Sync Now</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script>
    // Search Filtering
    function filterStudents() {
      let input = document.getElementById("studentSearch");
      let filter = input.value.toUpperCase();
      let table = document.getElementById("feesTable");
      let tr = table.getElementsByClassName("student-row");

      for (let i = 0; i < tr.length; i++) {
        let textContent = tr[i].textContent || tr[i].innerText;
        if (textContent.toUpperCase().indexOf(filter) > -1) {
          tr[i].style.display = "";
        } else {
          tr[i].style.display = "none";
        }
      }
    }

    // Modal Interaction
    function openPaymentModal(voucherId, studentName, remainingBalance) {
      document.getElementById('modalStudentName').textContent = 'Student: ' + studentName;
      document.getElementById('paymentInput').max = remainingBalance;
      document.getElementById('modalMaxAmount').textContent = 'RS ' + Number(remainingBalance).toLocaleString();
      document.getElementById('paymentForm').action = '/admin/fees/pay/' + voucherId;
      window.openModal('paymentModal');
    }
  </script>

<%- include('../partials/footer') %>
<%- include('../partials/header') %>

  <!-- ════════════════════════════════════════════════════════════
       ADMIN LAYOUT
       ════════════════════════════════════════════════════════════ -->
  <div class="adm-layout">

    <!-- Sidebar -->
    <%- include('../partials/sidebar', { active: 'exams' }) %>

    <!-- ══ MAIN CONTENT ══════════════════════════════════════════ -->
    <main class="adm-main" role="main" aria-label="Exam Management">

      <!-- ── Page Header ── -->
      <div class="adm-page-header">
        <div>
          <h1 class="adm-page-title">Exam Management</h1>
          <p class="adm-page-subtitle">Create exams, manage schedules, and track results</p>
        </div>
        <div>
          <button class="adm-btn adm-btn-primary" onclick="window.openModal('addExamModal')">
            <i class="fas fa-plus-circle" aria-hidden="true"></i> Create Exam
          </button>
        </div>
      </div>

      <!-- ── Exams Grid ── -->
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem;">
        
        <% if (exams.length === 0) { %>
          <div style="grid-column: 1 / -1; padding: 4.5rem; text-align: center; color: var(--adm-text-muted); background: var(--adm-bg-surface); border-radius: var(--adm-r-lg); border: 1px dashed var(--adm-border);">
            <i class="fas fa-clipboard-list" style="font-size: 2.5rem; opacity: 0.25; display: block; margin-bottom: 1rem;" aria-hidden="true"></i>
            <h3 style="color: var(--adm-text-primary); font-weight: 700; margin-bottom: 0.5rem;">No Exams Created</h3>
            <p>Click "Create Exam" to schedule your first assessment.</p>
          </div>
        <% } %>

        <% exams.forEach(exam => { %>
          <article class="adm-card" style="padding: 1.5rem; display: flex; flex-direction: column;">
            
            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1rem;">
              <span class="adm-badge adm-badge-green" style="font-size: 0.75rem;">
                <i class="fas fa-calendar-check" aria-hidden="true" style="margin-right: 0.25rem;"></i> Active
              </span>
              <a href="/admin/exams/delete/<%= exam.id %>" onclick="return confirm('Delete this exam? All results will be lost forever.')" class="adm-btn adm-btn-ghost adm-btn-danger" style="padding: 0.5rem; margin: -0.5rem;" aria-label="Delete Exam">
                <i class="fas fa-trash-alt" aria-hidden="true"></i>
              </a>
            </div>

            <h3 style="font-size: 1.3rem; font-weight: 800; color: var(--adm-text-primary); margin-bottom: 0.5rem;">
              <%= exam.exam_name %>
            </h3>

            <% if (typeof isSuperAdmin !== 'undefined' && isSuperAdmin && exam.campus_name) { %>
              <div style="margin-bottom: 0.5rem;">
                <span class="adm-badge adm-badge-blue" style="font-size: 0.75rem;">
                  <i class="fas fa-building" aria-hidden="true" style="margin-right: 0.25rem;"></i> <%= exam.campus_name %>
                </span>
              </div>
            <% } %>

            <div style="color: var(--adm-text-muted); font-size: 0.85rem; font-weight: 600; margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem;">
              <i class="far fa-clock" aria-hidden="true"></i>
              <%= new Date(exam.start_date).toLocaleDateString() %> - <%= exam.end_date ? new Date(exam.end_date).toLocaleDateString() : 'Ongoing' %>
            </div>

            <a href="/admin/exams/<%= exam.id %>/results" class="adm-btn adm-btn-ghost" style="width: 100%; justify-content: center; background: var(--adm-indigo-bg); color: var(--adm-indigo); margin-top: auto;">
              View Results <i class="fas fa-arrow-right" aria-hidden="true" style="margin-left: 0.25rem; font-size: 0.8rem;"></i>
            </a>

          </article>
        <% }); %>

      </div>
    </main>
  </div>

  <!-- ══ MODALS ══════════════════════════════════════════════════ -->

  <!-- Add Exam Modal -->
  <div id="addExamModal" class="adm-modal" aria-labelledby="addExamModalTitle" aria-hidden="true" role="dialog">
    <div class="adm-modal-content">
      <div class="adm-modal-header">
        <h2 id="addExamModalTitle" class="adm-modal-title">Create New Exam</h2>
        <button type="button" class="adm-modal-close" onclick="window.closeModal('addExamModal')" aria-label="Close modal">
          <i class="fas fa-times" aria-hidden="true"></i>
        </button>
      </div>
      <div class="adm-modal-body">
        <form action="/admin/exams/add" method="POST">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
          
          <div class="adm-form-group">
            <label for="examNameInput" class="adm-label">Exam Name</label>
            <input type="text" name="exam_name" id="examNameInput" required placeholder="e.g. Mid Term 2024" class="adm-input">
          </div>

          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 2rem;">
            <div>
              <label for="startDateInput" class="adm-label">Start Date</label>
              <input type="date" name="start_date" id="startDateInput" required class="adm-input">
            </div>
            <div>
              <label for="endDateInput" class="adm-label">End Date (Optional)</label>
              <input type="date" name="end_date" id="endDateInput" class="adm-input">
            </div>
          </div>

          <div class="adm-modal-footer">
            <button type="button" class="adm-btn adm-btn-ghost" onclick="window.closeModal('addExamModal')">Cancel</button>
            <button type="submit" class="adm-btn adm-btn-primary">Create Exam</button>
          </div>
        </form>
      </div>
    </div>
  </div>

<%- include('../partials/footer') %>
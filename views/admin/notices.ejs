<%- include('../partials/header') %>

  <!-- ════════════════════════════════════════════════════════════
       ADMIN LAYOUT
       ════════════════════════════════════════════════════════════ -->
  <div class="adm-layout">

    <!-- Sidebar -->
    <%- include('../partials/sidebar', { active: 'notices' }) %>

    <!-- ══ MAIN CONTENT ══════════════════════════════════════════ -->
    <main class="adm-main" role="main" aria-label="Notice Board">

      <!-- ── Page Header ── -->
      <div class="adm-page-header">
        <div>
          <h1 class="adm-page-title">Notice Board</h1>
          <p class="adm-page-subtitle">Publish announcements and broadcasts to the community</p>
        </div>

        <button class="adm-btn adm-btn-primary" onclick="window.openModal('addModal')" type="button">
          <i class="fas fa-paper-plane" aria-hidden="true"></i> Publish New Notice
        </button>
      </div>

      <!-- ── Notices Feed ── -->
      <div style="display: flex; flex-direction: column; gap: 1.5rem;">
        <% notices.forEach(notice => { %>
          <article class="adm-card" style="padding: 2.25rem;">
            
            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1.25rem; flex-wrap: wrap; gap: 1rem;">
              <div>
                <h2 style="font-weight: 800; color: var(--adm-text-primary); font-size: 1.35rem; margin-bottom: 0.5rem; line-height: 1.25;">
                  <%= notice.title %>
                </h2>
                
                <div style="display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap;">
                  <% if (typeof isSuperAdmin !== 'undefined' && isSuperAdmin && notice.campus_name) { %>
                    <span class="adm-badge adm-badge-blue">
                      <i class="fas fa-building" style="margin-right:0.25rem;" aria-hidden="true"></i> <%= notice.campus_name %>
                    </span>
                  <% } %>
                  
                  <span style="color: var(--adm-text-muted); font-size: 0.825rem; font-weight: 600; display: flex; align-items: center; gap: 0.35rem;">
                    <i class="far fa-calendar-alt" aria-hidden="true"></i>
                    <time datetime="<%= new Date(notice.created_at).toISOString() %>"><%= new Date(notice.created_at).toLocaleString() %></time>
                  </span>
                </div>
              </div>

              <a 
                href="/admin/notices/delete/<%= notice.id %>"
                class="adm-btn adm-btn-ghost" 
                style="color: var(--adm-red); background: var(--adm-red-bg); border-color: transparent; width: 40px; height: 40px; padding: 0; display: flex; align-items: center; justify-content: center;"
                onclick="return confirm('Delete this notice permanently?')"
                aria-label="Delete announcement: <%= notice.title %>"
              >
                <i class="fas fa-trash" aria-hidden="true"></i>
              </a>
            </div>

            <!-- Content Body -->
            <div style="color: var(--adm-text-primary); line-height: 1.7; font-size: 1rem; margin-bottom: 1.5rem; white-space: pre-wrap;">
              <%= notice.content %>
            </div>

            <!-- Optional Attachment Callout -->
            <% if (notice.attachment_path) { %>
              <div style="padding: 1rem 1.25rem; background: var(--adm-bg-canvas); border-radius: var(--adm-r-md); border: 1px dashed var(--adm-border); display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem;">
                <div style="display: flex; align-items: center; gap: 1rem;">
                  <div style="width: 44px; height: 44px; background: var(--adm-indigo-bg); color: var(--adm-indigo); border-radius: var(--adm-r-sm); display: flex; align-items: center; justify-content: center; font-size: 1.2rem;">
                    <i class="fas <%= notice.attachment_path.endsWith('.pdf') ? 'fa-file-pdf' : 'fa-image' %>" aria-hidden="true"></i>
                  </div>
                  <div>
                    <h3 style="margin: 0; font-weight: 700; color: var(--adm-text-primary); font-size: 0.9rem;">Attachment Available</h3>
                    <p style="margin: 0; font-size: 0.75rem; color: var(--adm-text-muted);">View or download the included document</p>
                  </div>
                </div>
                
                <a 
                  href="<%= notice.attachment_path %>" 
                  target="_blank" 
                  download 
                  class="adm-btn adm-btn-ghost"
                  style="background: var(--adm-indigo-bg); color: var(--adm-indigo); font-weight: 700; border: none;"
                >
                  <i class="fas fa-download" aria-hidden="true"></i> Download File
                </a>
              </div>
            <% } %>

            <!-- Footer Tags -->
            <footer style="margin-top: 1.5rem; padding-top: 1.25rem; border-top: 1px solid var(--adm-border); display: flex; gap: 15px;">
              <span class="adm-badge adm-badge-blue" style="background: var(--adm-bg-canvas); color: var(--adm-text-secondary); padding: 0.35rem 0.75rem;">
                <i class="fas fa-tag" style="margin-right: 0.25rem;" aria-hidden="true"></i> Announcement
              </span>
            </footer>

          </article>
        <% }) %>

        <% if (notices.length === 0) { %>
          <div style="padding: 4.5rem; text-align: center; color: var(--adm-text-muted); background: var(--adm-bg-surface); border-radius: var(--adm-r-lg); border: 1px dashed var(--adm-border);">
            <i class="fas fa-inbox" style="font-size: 2.5rem; opacity: 0.25; display: block; margin-bottom: 1rem;" aria-hidden="true"></i>
            No announcements have been published yet.
          </div>
        <% } %>
      </div>

    </main>
  </div>

  <!-- ════════════════════════════════════════════════════════════
       CREATE ANNOUNCEMENT MODAL
       ════════════════════════════════════════════════════════════ -->
  <div id="addModal" class="adm-modal-overlay" role="dialog" aria-modal="true" aria-labelledby="addModalTitle">
    <div class="adm-modal-container">
      <button class="adm-modal-close-btn" onclick="window.closeModal('addModal')" aria-label="Close modal" type="button">
        <i class="fas fa-times" aria-hidden="true"></i>
      </button>

      <h2 id="addModalTitle" style="font-weight: 700; font-size:1.35rem; margin-bottom: 0.25rem;">Create Announcement</h2>
      <p style="color: var(--adm-text-muted); font-size: 0.85rem; margin-bottom: 1.75rem;">Broadcast a new notice to all students and staff.</p>

      <form action="/admin/notices/add" method="POST" enctype="multipart/form-data">
        <!-- CSRF Protection -->
        <% if (typeof csrfToken !== 'undefined' && csrfToken) { %>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <% } %>

        <div class="adm-form-group" style="margin-bottom: 1.25rem;">
          <label class="adm-label" for="notice_title">Notice Title</label>
          <input type="text" name="title" id="notice_title" required placeholder="e.g. Winter Vacation Schedule" class="adm-input">
        </div>

        <div class="adm-form-group" style="margin-bottom: 1.5rem;">
          <label class="adm-label" for="notice_content">Announcement Content</label>
          <textarea name="content" id="notice_content" required rows="6" placeholder="Write the full details here..." class="adm-textarea"></textarea>
        </div>

        <div class="adm-form-group" style="margin-bottom: 2rem;">
          <label class="adm-label" for="notice_attachment" style="display:flex; align-items:center; gap:0.35rem;">
            <i class="fas fa-paperclip" aria-hidden="true"></i> Attach File (Optional)
          </label>
          <p style="font-size: 0.75rem; color: var(--adm-text-muted); margin-bottom: 0.5rem; margin-top:0.25rem;">Upload PDF or Image (JPG, PNG) - Max 10MB</p>
          <div class="adm-file-upload">
            <i class="fas fa-cloud-upload-alt adm-file-upload-icon" aria-hidden="true"></i>
            <div class="adm-file-upload-text">Click to browse or drag file here</div>
            <input type="file" name="attachment" id="notice_attachment" accept=".pdf,.jpg,.jpeg,.png,.gif" class="adm-file-upload-input">
          </div>
        </div>

        <button type="submit" class="adm-btn adm-btn-primary" style="width: 100%; min-height:44px; justify-content:center;">
          Publish to Board
        </button>
      </form>
    </div>
  </div>

<%- include('../partials/footer') %>
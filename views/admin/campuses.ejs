<%- include('../partials/header') %>

  <!-- ════════════════════════════════════════════════════════════
       ADMIN LAYOUT
       ════════════════════════════════════════════════════════════ -->
  <div class="adm-layout">

    <!-- Sidebar -->
    <%- include('../partials/sidebar', { active: 'campuses' }) %>

    <!-- ══ MAIN CONTENT ══════════════════════════════════════════ -->
    <main class="adm-main" role="main" aria-label="Campus Management">

      <!-- ── Page Header ── -->
      <div class="adm-page-header">
        <div>
          <h1 class="adm-page-title">Campus Management</h1>
          <p class="adm-page-subtitle">Configure and manage multiple school branches and campuses</p>
        </div>
        <div>
          <% if (isSuperAdmin) { %>
            <button class="adm-btn adm-btn-primary" onclick="window.openModal('addCampusModal')">
              <i class="fas fa-plus-circle" aria-hidden="true"></i> Add New Campus
            </button>
          <% } %>
        </div>
      </div>

      <!-- ── Campuses Grid ── -->
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem;">
        
        <% if (campuses.length === 0) { %>
          <div style="grid-column: 1 / -1; padding: 4.5rem; text-align: center; color: var(--adm-text-muted); background: var(--adm-bg-surface); border-radius: var(--adm-r-lg); border: 1px dashed var(--adm-border);">
            <i class="fas fa-building" style="font-size: 3rem; opacity: 0.25; display: block; margin-bottom: 1rem;" aria-hidden="true"></i>
            <h3 style="color: var(--adm-text-primary); font-weight: 700; margin-bottom: 0.5rem;">No Campuses Found</h3>
            <p>Click "Add New Campus" to create your first branch.</p>
          </div>
        <% } %>

        <% campuses.forEach(campus => { %>
          <article class="adm-card" style="padding: 1.5rem; display: flex; flex-direction: column;">
            
            <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1.25rem;">
              <div class="adm-avatar" style="width: 48px; height: 48px; border-radius: var(--adm-r-sm); background: var(--adm-indigo-bg); color: var(--adm-indigo); font-size: 1.25rem;">
                <i class="fas fa-building" aria-hidden="true"></i>
              </div>
              <span class="adm-badge adm-badge-blue" style="font-family: 'JetBrains Mono', monospace; font-size: 0.75rem;">
                CODE: <%= campus.campus_code %>
              </span>
            </div>

            <h3 style="font-size: 1.3rem; font-weight: 800; color: var(--adm-text-primary); margin-bottom: 0.5rem;">
              <%= campus.campus_name %>
            </h3>

            <div style="color: var(--adm-text-muted); font-size: 0.9rem; margin-bottom: 1.5rem; flex-grow: 1;">
              <p style="margin: 0.5rem 0; display: flex; align-items: center; gap: 0.5rem;">
                <i class="fas fa-map-marker-alt" aria-hidden="true" style="width: 16px; text-align: center;"></i>
                <%= campus.city %>
              </p>
              <p style="margin: 0.5rem 0; display: flex; align-items: center; gap: 0.5rem;">
                <i class="fas fa-phone" aria-hidden="true" style="width: 16px; text-align: center;"></i>
                <%= campus.contact_phone || 'N/A' %>
              </p>
            </div>

            <div style="border-top: 1px solid var(--adm-border); padding-top: 1rem; display: flex; gap: 0.75rem;">
              <button class="adm-btn adm-btn-ghost" style="flex: 1; justify-content: center; background: var(--adm-bg-elevated); border: 1px solid var(--adm-border);">
                Edit Settings
              </button>
              
              <% if(isSuperAdmin && campus.id !== 1) { %>
                <a href="/admin/campuses/delete/<%= campus.id %>" onclick="return confirm('CRITICAL WARNING: This will delete ALL data (students, teachers, fees, exams) associated with this campus. Proceed?')" class="adm-btn adm-btn-ghost adm-btn-danger" style="padding: 0.5rem 1rem;" aria-label="Delete Campus">
                  Delete
                </a>
              <% } %>
            </div>

          </article>
        <% }); %>

      </div>
    </main>
  </div>

  <!-- ══ MODALS ══════════════════════════════════════════════════ -->

  <!-- Add Campus Modal -->
  <div id="addCampusModal" class="adm-modal" aria-labelledby="addCampusModalTitle" aria-hidden="true" role="dialog">
    <div class="adm-modal-content">
      <div class="adm-modal-header">
        <h2 id="addCampusModalTitle" class="adm-modal-title">Add New Campus</h2>
        <button type="button" class="adm-modal-close" onclick="window.closeModal('addCampusModal')" aria-label="Close modal">
          <i class="fas fa-times" aria-hidden="true"></i>
        </button>
      </div>
      <div class="adm-modal-body">
        <form action="/admin/campuses/add" method="POST">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
          
          <div class="adm-form-group">
            <label for="campusNameInput" class="adm-label">Campus Name</label>
            <input type="text" name="campus_name" id="campusNameInput" required placeholder="e.g. North Campus" class="adm-input">
          </div>

          <div class="adm-form-group">
            <label for="campusCodeInput" class="adm-label">Campus Code (Short ID)</label>
            <input type="text" name="campus_code" id="campusCodeInput" required placeholder="e.g. NORTH" class="adm-input" style="text-transform: uppercase; font-family: 'JetBrains Mono', monospace;">
            <p style="margin-top: 0.25rem; font-size: 0.8rem; color: var(--adm-text-muted);">Used for cross-system mapping and login routing (e.g. NORTH).</p>
          </div>

          <div class="adm-form-group">
            <label for="adminPassInput" class="adm-label">Admin Password</label>
            <input type="password" name="admin_password" id="adminPassInput" required placeholder="Default Admin Password" class="adm-input">
            <p style="margin-top: 0.25rem; font-size: 0.8rem; color: var(--adm-text-muted);">Sets the password for the default 'admin' user of this campus.</p>
          </div>

          <div class="adm-form-group">
            <label for="cityInput" class="adm-label">City / Location</label>
            <input type="text" name="city" id="cityInput" required placeholder="e.g. Lahore" class="adm-input">
          </div>

          <div class="adm-form-group" style="margin-bottom: 2rem;">
            <label for="addressInput" class="adm-label">Full Address (Optional)</label>
            <input type="text" name="address" id="addressInput" placeholder="Enter complete physical address" class="adm-input">
          </div>

          <div class="adm-modal-footer">
            <button type="button" class="adm-btn adm-btn-ghost" onclick="window.closeModal('addCampusModal')">Cancel</button>
            <button type="submit" class="adm-btn adm-btn-primary">Create Campus</button>
          </div>
        </form>
      </div>
    </div>
  </div>

<%- include('../partials/footer') %>
<%- include('../partials/header') %>

  <!-- ════════════════════════════════════════════════════════════
       ADMIN LAYOUT
       ════════════════════════════════════════════════════════════ -->
  <div class="adm-layout">

    <!-- Sidebar -->
    <%- include('../partials/sidebar', { active: 'exams' }) %>

    <!-- ══ MAIN CONTENT ══════════════════════════════════════════ -->
    <main class="adm-main" role="main" aria-label="Exam Results">

      <!-- ── Page Header ── -->
      <div class="adm-page-header" style="flex-direction: column; align-items: flex-start; gap: 0.5rem;">
        <a href="/admin/exams" class="adm-btn adm-btn-ghost" style="padding: 0; background: transparent; color: var(--adm-text-muted); font-size: 0.9rem; margin-bottom: 0.25rem;">
          <i class="fas fa-arrow-left" aria-hidden="true" style="margin-right: 0.5rem;"></i> Back to Exams
        </a>
        <div>
          <h1 class="adm-page-title"><%= exam.exam_name %> Results</h1>
          <p class="adm-page-subtitle">View student performance by class and evaluate outcomes</p>
        </div>
      </div>

      <!-- ── Dynamic Content: Overview or Detail ── -->
      <% if (viewMode === 'overview') { %>

        <!-- OVERVIEW MODE (Class Grid) -->
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem;">
          <% overview.forEach(cls => {
            const hasResults = cls.results_count > 0;
          %>
            <a href="/admin/exams/<%= exam.id %>/results?class_id=<%= cls.id %>" class="adm-card" style="text-decoration: none; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 2.5rem 2rem; transition: transform 0.2s ease, box-shadow 0.2s ease;">
              
              <div class="adm-avatar" style="width: 64px; height: 64px; font-size: 1.5rem; background: var(--adm-indigo-bg); color: var(--adm-indigo); margin-bottom: 1.25rem;">
                <i class="fas fa-users" aria-hidden="true"></i>
              </div>
              
              <h3 style="font-size: 1.4rem; font-weight: 800; color: var(--adm-text-primary); margin-bottom: 0.75rem; text-align: center;">
                <%= cls.class_name %>
              </h3>

              <% if(hasResults) { %>
                <span class="adm-badge adm-badge-green">
                  View Results <i class="fas fa-arrow-right" aria-hidden="true" style="margin-left: 0.25rem;"></i>
                </span>
              <% } else { %>
                <span class="adm-badge" style="background: var(--adm-bg-elevated); color: var(--adm-text-muted); border: 1px solid var(--adm-border);">
                  No Results
                </span>
              <% } %>

            </a>
          <% }); %>
          
          <% if (overview.length === 0) { %>
            <div style="grid-column: 1 / -1; padding: 4rem 1rem; text-align: center; background: var(--adm-bg-surface); border: 1px dashed var(--adm-border); border-radius: var(--adm-r-lg);">
              <i class="fas fa-layer-group" style="font-size: 2.5rem; color: var(--adm-text-muted); opacity: 0.3; margin-bottom: 1rem;" aria-hidden="true"></i>
              <h3 style="color: var(--adm-text-muted); font-weight: 600;">No Classes Configured</h3>
            </div>
          <% } %>
        </div>

      <% } else { %>

        <!-- DETAIL VIEW (Results Sheet) -->
        <div class="adm-card" style="padding: 0; overflow: hidden;">
          
          <!-- Header Bar -->
          <div style="display: flex; justify-content: space-between; align-items: center; padding: 1.5rem; border-bottom: 1px solid var(--adm-border); flex-wrap: wrap; gap: 1rem;">
            <div>
              <h2 style="font-size: 1.3rem; font-weight: 800; color: var(--adm-text-primary); margin: 0;">
                <%= currentClass.class_name %> (Sec: <%= currentClass.section %>)
              </h2>
              <p style="color: var(--adm-text-muted); font-weight: 600; font-size: 0.85rem; margin-top: 0.25rem;">Result Sheet</p>
            </div>
            <a href="/admin/exams/<%= exam.id %>/results" class="adm-btn adm-btn-ghost" style="background: var(--adm-bg-elevated);">
              <i class="fas fa-th" aria-hidden="true"></i> View All Classes
            </a>
          </div>

          <!-- Data Table -->
          <div style="overflow-x: auto;">
            <table class="adm-table" aria-label="Student Exam Results">
              <thead>
                <tr>
                  <th scope="col" style="width: 80px;">Roll No</th>
                  <th scope="col">Student Name</th>
                  <th scope="col">Subject</th>
                  <th scope="col">Marks Obtained</th>
                  <th scope="col">Total Marks</th>
                  <th scope="col" style="text-align: right;">Grade</th>
                </tr>
              </thead>
              <tbody>
                <% if (results.length === 0) { %>
                  <tr>
                    <td colspan="6" style="padding: 4rem 1rem; text-align: center;">
                      <div class="adm-empty-state">
                        <i class="fas fa-clipboard-list adm-empty-icon" aria-hidden="true"></i>
                        <h3>No Results Uploaded</h3>
                        <p>There are no grades recorded for this class yet.</p>
                      </div>
                    </td>
                  </tr>
                <% } %>
                
                <% results.forEach(res => { %>
                  <% if(res.marks_obtained !== null) { 
                      let badgeClass = 'adm-badge-blue';
                      if(['A+', 'A'].includes(res.grade)) badgeClass = 'adm-badge-green';
                      else if(['F'].includes(res.grade)) badgeClass = 'adm-badge-red';
                      else if(['B+', 'B'].includes(res.grade)) badgeClass = 'adm-badge-purple';
                      else if(['C', 'D'].includes(res.grade)) badgeClass = 'adm-badge-amber';
                  %>
                    <tr>
                      <td style="font-family: 'JetBrains Mono', monospace; font-weight: 600; color: var(--adm-text-primary);">
                        <%= res.roll_no %>
                      </td>
                      <td style="font-weight: 700; color: var(--adm-text-primary);">
                        <%= res.full_name %>
                      </td>
                      <td style="font-weight: 600; color: var(--adm-text-muted);">
                        <%= res.subject %>
                      </td>
                      <td style="font-weight: 800; color: var(--adm-text-primary); font-size: 1.1rem;">
                        <%= res.marks_obtained %>
                      </td>
                      <td style="font-weight: 600; color: var(--adm-text-muted);">
                        <%= res.total_marks %>
                      </td>
                      <td style="text-align: right;">
                        <span class="adm-badge <%= badgeClass %>" style="font-size: 0.85rem; font-weight: 800; padding: 0.4rem 0.8rem;">
                          <%= res.grade %>
                        </span>
                      </td>
                    </tr>
                  <% } %>
                <% }); %>
              </tbody>
            </table>
          </div>

        </div>
      <% } %>

    </main>
  </div>

<%- include('../partials/footer') %>
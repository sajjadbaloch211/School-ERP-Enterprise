<%- include('../partials/header') %>

    <div class="admin-layout animate-fade-in" style="margin-top: 80px;">
        <!-- Sidebar -->
        <!-- Sidebar -->
        <%- include('../partials/sidebar', { active: 'timetable' }) %>

            <main class="main-content">
                <header
                    style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 3rem;">
                    <div>
                        <h2 style="font-size: 2rem; font-weight: 800; color: var(--primary);">Timetable Management</h2>
                        <p style="color: var(--text-muted);">Schedule classes and assign teachers</p>
                    </div>
                    <button class="btn-primary"
                        onclick="document.getElementById('addTimetableModal').style.display='flex'"
                        style="padding: 12px 25px; border-radius: 50px; display: flex; align-items: center; gap: 10px;">
                        <i class="fas fa-plus"></i> Add Schedule
                    </button>
                </header>

                <!-- Timetable View -->
                <div class="card animate-slide-up" style="overflow-x: auto;">
                    <table class="data-table" style="width: 100%; border-collapse: collapse;">
                        <thead>
                            <tr style="background: var(--bg-light); text-align: left;">
                                <th style="padding: 1rem; border-radius: 12px 0 0 12px;">Day</th>
                                <th style="padding: 1rem;">Time Slot</th>
                                <th style="padding: 1rem;">Class</th>
                                <% if (typeof isSuperAdmin !=='undefined' && isSuperAdmin) { %>
                                    <th style="padding: 1rem;">Campus</th>
                                    <% } %>
                                        <th style="padding: 1rem;">Subject</th>
                                        <th style="padding: 1rem;">Teacher</th>
                                        <th style="padding: 1rem; border-radius: 0 12px 12px 0;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if(timetable.length===0) { %>
                                <tr>
                                    <td colspan="<%= (typeof isSuperAdmin !== 'undefined' && isSuperAdmin) ? 7 : 6 %>"
                                        style="padding: 2rem; text-align: center; color: var(--text-muted);">
                                        No schedules found. Click "Add Schedule" to create one.
                                    </td>
                                </tr>
                                <% } %>
                                    <% timetable.forEach(entry=> { %>
                                        <tr style="border-bottom: 1px solid rgba(0,0,0,0.05);">
                                            <td style="padding: 1rem; font-weight: 700;">
                                                <span
                                                    style="background: #e0f2fe; color: #0284c7; padding: 5px 10px; border-radius: 12px; font-size: 0.9rem;">
                                                    <%= entry.day %>
                                                </span>
                                            </td>
                                            <td style="padding: 1rem; font-family: monospace; color: var(--text-main);">
                                                <%= entry.start_time %> - <%= entry.end_time %>
                                            </td>
                                            <td style="padding: 1rem;">
                                                <div style="font-weight: 600;">
                                                    <%= entry.class_name %>
                                                </div>
                                                <div style="font-size: 0.8rem; color: var(--text-muted);">Sec: <%=
                                                        entry.section %>
                                                </div>
                                            </td>
                                            <% if (typeof isSuperAdmin !=='undefined' && isSuperAdmin) { %>
                                                <td style="padding: 1rem;">
                                                    <span class="badge badge-sm badge-info"
                                                        style="background: #e0f2fe; color: var(--primary); padding: 4px 10px; border-radius: 8px; font-weight: 600; font-size: 0.8rem;">
                                                        <%= entry.campus_name || '-' %>
                                                    </span>
                                                </td>
                                                <% } %>
                                                    <td style="padding: 1rem; font-weight: 600; color: var(--primary);">
                                                        <%= entry.subject %>
                                                    </td>
                                                    <td style="padding: 1rem;">
                                                        <div style="display: flex; align-items: center; gap: 10px;">
                                                            <div
                                                                style="width: 30px; height: 30px; background: var(--bg-light); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.8rem;">
                                                                <i class="fas fa-user-tie"
                                                                    style="color: var(--text-muted);"></i>
                                                            </div>
                                                            <span>
                                                                <%= entry.teacher_name || 'Unassigned' %>
                                                            </span>
                                                        </div>
                                                    </td>
                                                    <td style="padding: 1rem;">
                                                        <a href="/admin/timetable/delete/<%= entry.id %>"
                                                            onclick="return confirm('Remove this schedule?')"
                                                            style="color: var(--danger); background: rgba(239, 68, 68, 0.1); width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; border-radius: 8px; text-decoration: none;">
                                                            <i class="fas fa-trash"></i>
                                                        </a>
                                                    </td>
                                        </tr>
                                        <% }); %>
                        </tbody>
                    </table>
                </div>
            </main>
    </div>

    <!-- Add Modal -->
    <div id="addTimetableModal" class="modal"
        style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); z-index: 9999; align-items: center; justify-content: center;">
        <div class="glass animate-slide-up"
            style="width: 100%; max-width: 500px; padding: 2rem; border-radius: 24px; background: white;">
            <h3 style="margin-bottom: 1.5rem; color: var(--primary);">Add New Schedule</h3>
            <form action="/admin/timetable/add" method="POST">
                <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                <div class="form-group mb-3">
                    <label style="font-weight: 600; margin-bottom: 0.5rem; display: block;">Select Class</label>
                    <select name="class_id" required class="form-control"
                        style="width: 100%; padding: 12px; border-radius: 12px; border: 1px solid #ddd;">
                        <% classes.forEach(cls=> { %>
                            <option value="<%= cls.id %>">
                                <%= cls.class_name %> - Section <%= cls.section %>
                            </option>
                            <% }); %>
                    </select>
                </div>

                <div class="form-group mb-3">
                    <label style="font-weight: 600; margin-bottom: 0.5rem; display: block;">Day of Week</label>
                    <select name="day" required class="form-control"
                        style="width: 100%; padding: 12px; border-radius: 12px; border: 1px solid #ddd;">
                        <option value="Monday">Monday</option>
                        <option value="Tuesday">Tuesday</option>
                        <option value="Wednesday">Wednesday</option>
                        <option value="Thursday">Thursday</option>
                        <option value="Friday">Friday</option>
                        <option value="Saturday">Saturday</option>
                    </select>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                    <div class="form-group">
                        <label style="font-weight: 600; margin-bottom: 0.5rem; display: block;">Start Time</label>
                        <input type="time" name="start_time" required class="form-control"
                            style="width: 100%; padding: 12px; border-radius: 12px; border: 1px solid #ddd;">
                    </div>
                    <div class="form-group">
                        <label style="font-weight: 600; margin-bottom: 0.5rem; display: block;">End Time</label>
                        <input type="time" name="end_time" required class="form-control"
                            style="width: 100%; padding: 12px; border-radius: 12px; border: 1px solid #ddd;">
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label style="font-weight: 600; margin-bottom: 0.5rem; display: block;">Subject</label>
                    <input type="text" name="subject" required placeholder="e.g. Mathematics" class="form-control"
                        style="width: 100%; padding: 12px; border-radius: 12px; border: 1px solid #ddd;">
                </div>

                <div class="form-group mb-4">
                    <label style="font-weight: 600; margin-bottom: 0.5rem; display: block;">Assign Teacher</label>
                    <select name="teacher_id" class="form-control"
                        style="width: 100%; padding: 12px; border-radius: 12px; border: 1px solid #ddd;">
                        <option value="">-- No Teacher Assigned --</option>
                        <% teachers.forEach(t=> { %>
                            <option value="<%= t.id %>">
                                <%= t.full_name %>
                            </option>
                            <% }); %>
                    </select>
                </div>

                <div style="display: flex; gap: 10px; justify-content: flex-end;">
                    <button type="button" onclick="document.getElementById('addTimetableModal').style.display='none'"
                        class="btn"
                        style="background: transparent; color: var(--text-muted); font-weight: 600;">Cancel</button>
                    <button type="submit" class="btn-primary" style="padding: 12px 25px;">Save Schedule</button>
                </div>
            </form>
        </div>
    </div>

    <%- include('../partials/footer') %>
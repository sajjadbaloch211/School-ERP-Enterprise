<%- include('../partials/header') %>

  <!-- ════════════════════════════════════════════════════════════
       ADMIN LAYOUT
       ════════════════════════════════════════════════════════════ -->
  <div class="adm-layout">

    <!-- Sidebar -->
    <%- include('../partials/sidebar', { active: 'timetable' }) %>

    <!-- ══ MAIN CONTENT ══════════════════════════════════════════ -->
    <main class="adm-main" role="main" aria-label="Timetable Management">

      <!-- ── Page Header ── -->
      <div class="adm-page-header">
        <div>
          <h1 class="adm-page-title">Timetable Management</h1>
          <p class="adm-page-subtitle">Schedule classes, time slots, and assign teachers</p>
        </div>
        <div>
          <button class="adm-btn adm-btn-primary" onclick="window.openModal('addTimetableModal')">
            <i class="fas fa-plus-circle" aria-hidden="true"></i> Add Schedule
          </button>
        </div>
      </div>

      <!-- ── Timetable View ── -->
      <div class="adm-card" style="padding: 0; overflow: hidden;">
        
        <div style="overflow-x: auto;">
          <table class="adm-table" aria-label="Class Schedule">
            <thead>
              <tr>
                <th scope="col">Day</th>
                <th scope="col">Time Slot</th>
                <th scope="col">Class</th>
                <% if (typeof isSuperAdmin !=='undefined' && isSuperAdmin) { %>
                  <th scope="col">Campus</th>
                <% } %>
                <th scope="col">Subject</th>
                <th scope="col">Teacher</th>
                <th scope="col" style="text-align: right;">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if(timetable.length === 0) { %>
                <tr>
                  <td colspan="<%= (typeof isSuperAdmin !== 'undefined' && isSuperAdmin) ? 7 : 6 %>" style="text-align: center; padding: 4rem 1rem;">
                    <div class="adm-empty-state">
                      <i class="fas fa-calendar-times adm-empty-icon" aria-hidden="true"></i>
                      <h3>No Schedules Found</h3>
                      <p>Click "Add Schedule" to create a new class timetable entry.</p>
                    </div>
                  </td>
                </tr>
              <% } %>
              
              <% timetable.forEach(entry => { 
                // Determine badge color for day
                let dayBadge = 'adm-badge-blue';
                if(['Saturday', 'Sunday'].includes(entry.day)) { dayBadge = 'adm-badge-purple'; }
              %>
                <tr>
                  <td>
                    <span class="adm-badge <%= dayBadge %>" style="font-weight: 700; font-size: 0.8rem;"><%= entry.day %></span>
                  </td>
                  <td style="font-family: 'JetBrains Mono', monospace; font-weight: 600; color: var(--adm-text-primary);">
                    <%= entry.start_time %> - <%= entry.end_time %>
                  </td>
                  <td>
                    <div style="font-weight: 700; color: var(--adm-text-primary);"><%= entry.class_name %></div>
                    <div style="font-size: 0.75rem; color: var(--adm-text-muted); font-weight: 600;">Sec: <%= entry.section %></div>
                  </td>
                  <% if (typeof isSuperAdmin !=='undefined' && isSuperAdmin) { %>
                    <td>
                      <span class="adm-badge adm-badge-blue" style="font-size: 0.75rem;"><%= entry.campus_name || '-' %></span>
                    </td>
                  <% } %>
                  <td style="font-weight: 700; color: var(--adm-indigo);">
                    <%= entry.subject %>
                  </td>
                  <td>
                    <div style="display: flex; align-items: center; gap: 0.75rem;">
                      <div class="adm-avatar" style="background: var(--adm-bg-elevated); color: var(--adm-text-muted); width: 32px; height: 32px; border: 1px solid var(--adm-border);">
                        <i class="fas fa-user-tie" aria-hidden="true"></i>
                      </div>
                      <span style="font-weight: 600; color: var(--adm-text-primary);">
                        <%= entry.teacher_name || 'Unassigned' %>
                      </span>
                    </div>
                  </td>
                  <td style="text-align: right;">
                    <a href="/admin/timetable/delete/<%= entry.id %>" onclick="return confirm('Remove this schedule?')" class="adm-btn adm-btn-ghost adm-btn-danger" style="padding: 0.5rem 0.75rem;" aria-label="Delete Schedule">
                      <i class="fas fa-trash-alt" aria-hidden="true"></i>
                    </a>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>

    </main>
  </div>

  <!-- ══ MODALS ══════════════════════════════════════════════════ -->

  <!-- Add Timetable Modal -->
  <div id="addTimetableModal" class="adm-modal" aria-labelledby="addTimetableModalTitle" aria-hidden="true" role="dialog">
    <div class="adm-modal-content">
      <div class="adm-modal-header">
        <h2 id="addTimetableModalTitle" class="adm-modal-title">Add New Schedule</h2>
        <button type="button" class="adm-modal-close" onclick="window.closeModal('addTimetableModal')" aria-label="Close modal">
          <i class="fas fa-times" aria-hidden="true"></i>
        </button>
      </div>
      <div class="adm-modal-body">
        <form action="/admin/timetable/add" method="POST">
          <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
          
          <div class="adm-form-group">
            <label for="classIdInput" class="adm-label">Select Class</label>
            <select name="class_id" id="classIdInput" required class="adm-input">
              <% classes.forEach(cls => { %>
                <option value="<%= cls.id %>">
                  <%= cls.class_name %> - Section <%= cls.section %>
                </option>
              <% }); %>
            </select>
          </div>

          <div class="adm-form-group">
            <label for="dayInput" class="adm-label">Day of Week</label>
            <select name="day" id="dayInput" required class="adm-input">
              <option value="Monday">Monday</option>
              <option value="Tuesday">Tuesday</option>
              <option value="Wednesday">Wednesday</option>
              <option value="Thursday">Thursday</option>
              <option value="Friday">Friday</option>
              <option value="Saturday">Saturday</option>
            </select>
          </div>

          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.5rem;">
            <div>
              <label for="startTimeInput" class="adm-label">Start Time</label>
              <input type="time" name="start_time" id="startTimeInput" required class="adm-input">
            </div>
            <div>
              <label for="endTimeInput" class="adm-label">End Time</label>
              <input type="time" name="end_time" id="endTimeInput" required class="adm-input">
            </div>
          </div>

          <div class="adm-form-group">
            <label for="subjectInput" class="adm-label">Subject</label>
            <input type="text" name="subject" id="subjectInput" required placeholder="e.g. Mathematics" class="adm-input">
          </div>

          <div class="adm-form-group" style="margin-bottom: 2rem;">
            <label for="teacherIdInput" class="adm-label">Assign Teacher</label>
            <select name="teacher_id" id="teacherIdInput" class="adm-input">
              <option value="">-- No Teacher Assigned --</option>
              <% teachers.forEach(t => { %>
                <option value="<%= t.id %>">
                  <%= t.full_name %>
                </option>
              <% }); %>
            </select>
          </div>

          <div class="adm-modal-footer">
            <button type="button" class="adm-btn adm-btn-ghost" onclick="window.closeModal('addTimetableModal')">Cancel</button>
            <button type="submit" class="adm-btn adm-btn-primary">Save Schedule</button>
          </div>
        </form>
      </div>
    </div>
  </div>

<%- include('../partials/footer') %>
<%- include('../partials/header') %>

  <!-- ════════════════════════════════════════════════════════════
       ADMIN LAYOUT
       ════════════════════════════════════════════════════════════ -->
  <div class="adm-layout">

    <!-- Sidebar -->
    <%- include('../partials/sidebar', { active: 'email' }) %>

    <!-- ══ MAIN CONTENT ══════════════════════════════════════════ -->
    <main class="adm-main" role="main" aria-label="Email Communication">

      <div style="max-width: 800px; margin: 0 auto; width: 100%;">
        
        <!-- ── Page Header ── -->
        <div class="adm-page-header" style="margin-bottom: 2rem;">
          <div>
            <h1 class="adm-page-title">Email Communication</h1>
            <p class="adm-page-subtitle">Send bulk announcements and notifications to students and teachers.</p>
          </div>
        </div>

        <!-- ── Email Composer ── -->
        <article class="adm-card" style="padding: 2.5rem;">
          
          <!-- Flash Messages -->
          <% if (typeof success !== 'undefined' && success) { %>
            <div style="background: var(--adm-green-bg); color: var(--adm-green); padding: 1rem 1.5rem; border-radius: var(--adm-r-md); margin-bottom: 2rem; font-weight: 600; display: flex; align-items: center; gap: 0.75rem;">
              <i class="fas fa-check-circle" aria-hidden="true" style="font-size: 1.25rem;"></i>
              <%= success %>
            </div>
          <% } %>

          <% if (typeof error !== 'undefined' && error) { %>
            <div style="background: var(--adm-red-bg); color: var(--adm-red); padding: 1rem 1.5rem; border-radius: var(--adm-r-md); margin-bottom: 2rem; font-weight: 600; display: flex; align-items: center; gap: 0.75rem;">
              <i class="fas fa-exclamation-circle" aria-hidden="true" style="font-size: 1.25rem;"></i>
              <%= error %>
            </div>
          <% } %>

          <!-- Composer Form -->
          <form action="/admin/send-email" method="POST">
            <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

            <div class="adm-form-group">
              <label class="adm-label" for="recipientGroup">Recipient Group <span style="color: var(--adm-red);">*</span></label>
              <select name="recipient_group" id="recipientGroup" required class="adm-input">
                <option value="both">Both (All Students & Teachers)</option>
                <option value="students">All Students</option>
                <option value="teachers">All Teachers</option>
              </select>
            </div>

            <div class="adm-form-group">
              <label class="adm-label" for="subjectInput">Subject <span style="color: var(--adm-red);">*</span></label>
              <input type="text" name="subject" id="subjectInput" required placeholder="e.g. Important Announcement: Term Finals Schedule" class="adm-input">
            </div>

            <div class="adm-form-group" style="margin-bottom: 2.5rem;">
              <label class="adm-label" for="messageInput">Message <span style="color: var(--adm-red);">*</span></label>
              <textarea name="message" id="messageInput" required rows="10" placeholder="Type your broadcast message here..." class="adm-input" style="resize: vertical; font-family: inherit;"></textarea>
            </div>

            <button type="submit" class="adm-btn adm-btn-primary" style="width: 100%; justify-content: center; padding: 1rem; font-size: 1.1rem; box-shadow: 0 4px 12px rgba(99, 102, 241, 0.25);">
              <i class="fas fa-paper-plane" aria-hidden="true"></i> Send Email Broadcast
            </button>
            
          </form>
        </article>

      </div>
    </main>
  </div>

<%- include('../partials/footer') %>
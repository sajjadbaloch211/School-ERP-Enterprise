<!-- Dynamic Stats Section -->
<section class="stats-section"
    style="padding: 100px 5%; background: <%= content.backgroundColor || 'linear-gradient(135deg, #0f172a, #1e293b)' %>; color: white;">
    <div class="container" style="max-width: 1200px; margin: 0 auto;">
        <div
            style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 3rem; text-align: center;">
            <% (content.items || []).forEach(stat=> { %>
                <div class="stat-card"
                    style="padding: 2.5rem; background: rgba(255,255,255,0.05); border-radius: 20px; border: 1px solid rgba(255,255,255,0.1); backdrop-filter: blur(10px);">
                    <div style="font-size: 3.5rem; font-weight: 800; color: #3b82f6; margin-bottom: 0.5rem;">
                        <%= stat.number %>
                    </div>
                    <div
                        style="font-size: 1.1rem; text-transform: uppercase; letter-spacing: 2px; opacity: 0.8; font-weight: 600;">
                        <%= stat.label %>
                    </div>
                </div>
                <% }) %>
        </div>
    </div>
</section>
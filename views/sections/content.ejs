<!-- Dynamic Content Section (Rich Text) -->
<section class="dynamic-content" style="padding: 80px 5%; background: <%= content.backgroundColor || '#ffffff' %>;">
    <div class="container" style="max-width: 900px; margin: 0 auto;">
        <div class="rich-text-content" style="font-size: 1.15rem; line-height: 1.8; color: #334155;">
            <%- content.html %>
        </div>
    </div>
</section>
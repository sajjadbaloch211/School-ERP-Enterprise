<!-- Contact Section Template -->
<section class="contact-section section" style="background: #f9fafb;">
    <div class="container">
        <% if (content.title) { %>
            <h2 class="section-title">
                <%= content.title %>
            </h2>
            <% } %>
                <% if (content.subtitle) { %>
                    <p class="section-subtitle">
                        <%= content.subtitle %>
                    </p>
                    <% } %>

                        <div class="contact-grid">
                            <div class="contact-info">
                                <% if (content.address) { %>
                                    <div class="contact-item">
                                        <i class="fas fa-map-marker-alt"
                                            style="color: <%= theme.colors.primary %>;"></i>
                                        <div>
                                            <h4>Address</h4>
                                            <p>
                                                <%= content.address %>
                                            </p>
                                        </div>
                                    </div>
                                    <% } %>

                                        <% if (content.phone) { %>
                                            <div class="contact-item">
                                                <i class="fas fa-phone" style="color: <%= theme.colors.primary %>;"></i>
                                                <div>
                                                    <h4>Phone</h4>
                                                    <p>
                                                        <%= content.phone %>
                                                    </p>
                                                </div>
                                            </div>
                                            <% } %>

                                                <% if (content.email) { %>
                                                    <div class="contact-item">
                                                        <i class="fas fa-envelope"
                                                            style="color: <%= theme.colors.primary %>;"></i>
                                                        <div>
                                                            <h4>Email</h4>
                                                            <p>
                                                                <%= content.email %>
                                                            </p>
                                                        </div>
                                                    </div>
                                                    <% } %>
                            </div>

                            <% if (content.show_form) { %>
                                <div class="contact-form">
                                    <form action="/contact/submit" method="POST">
                                        <input type="text" name="name" placeholder="Your Name" required>
                                        <input type="email" name="email" placeholder="Your Email" required>
                                        <input type="text" name="subject" placeholder="Subject" required>
                                        <textarea name="message" rows="5" placeholder="Your Message"
                                            required></textarea>
                                        <button type="submit" class="btn btn-primary">Send Message</button>
                                    </form>
                                </div>
                                <% } %>
                        </div>

                        <% if (content.map_embed) { %>
                            <div class="contact-map" style="margin-top: 50px;">
                                <%- content.map_embed %>
                            </div>
                            <% } %>
    </div>
</section>

<style>
    .contact-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
        gap: 50px;
        margin-top: 40px;
    }

    .contact-item {
        display: flex;
        gap: 20px;
        margin-bottom: 30px;
    }

    .contact-item i {
        font-size: 32px;
        margin-top: 5px;
    }

    .contact-item h4 {
        font-size: 18px;
        margin-bottom: 8px;
        color: var(--color-text);
    }

    .contact-item p {
        color: var(--color-text-light);
    }

    .contact-form input,
    .contact-form textarea {
        width: 100%;
        padding: 15px;
        margin-bottom: 15px;
        border: 1px solid #ddd;
        border-radius: 8px;
        font-family: var(--font-body);
        font-size: 16px;
    }

    .contact-form input:focus,
    .contact-form textarea:focus {
        outline: none;
        border-color: var(--color-primary);
    }

    .contact-map iframe {
        width: 100%;
        height: 400px;
        border-radius: 12px;
        border: none;
    }
</style>
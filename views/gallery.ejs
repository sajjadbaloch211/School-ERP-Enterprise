<%- include('partials/frontend_header') %>

    <!-- Hero Banner -->
    <section class="hero-section" style="min-height: 52vh; background-image: url('/images/school-bg.jpg');">
        <div class="hero-overlay"></div>
        <div class="container hero-content text-center animate-up">
            <span class="hero-badge"><i class="fas fa-images me-2"></i> Visual Journey</span>
            <h1 class="hero-title">Our <span style="color: var(--accent-color);">Gallery</span></h1>
            <p class="hero-lead mx-auto" style="max-width:600px;">
                A glimpse into the vibrant life, events, and achievements at our school.
            </p>
        </div>
    </section>

    <!-- Gallery Section -->
    <section class="section-padding" style="background: var(--bg-light);">
        <div class="container">
            <div class="text-center mb-5 animate-up">
                <span class="section-label">School Life</span>
                <h2 class="section-title">Moments & Memories</h2>
            </div>

            <div class="row g-4">
                <% if (typeof gallery !== 'undefined' && gallery && gallery.length > 0) { %>
                    <% gallery.forEach((item, index) => { %>
                    <div class="col-lg-4 col-md-6 animate-up">
                        <div class="gallery-card h-100">
                            <img src="<%= item.image_path || item %>" alt="<%= item.title || 'Gallery Image' %>" style="height:280px;object-fit:cover;width:100%;">
                            <div class="gallery-overlay">
                                <div>
                                    <h5 class="text-white fw-bold mb-1"><%= item.title || 'School Memory' %></h5>
                                    <p class="text-white-50 small mb-0"><%= item.description || 'A cherished moment.' %></p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% }); %>
                <% } else { %>
                    <!-- Static Fallback Images -->
                    <% const galleryItems = [
                        { src: '/images/event1.jpg', title: 'Cultural Celebration', desc: 'Celebrating our rich cultural heritage.' },
                        { src: '/images/award.jpg', title: 'Annual Awards Night', desc: 'Recognizing students of excellence.' },
                        { src: '/images/classroom_boys.jpg', title: 'Interactive Sessions', desc: 'Engaging and dynamic classroom environments.' },
                        { src: '/images/classroom_girls.jpg', title: 'Girls Wing', desc: 'Empowering future women leaders.' },
                        { src: '/images/school-bg.jpg', title: 'Our Campus', desc: 'A beautiful environment for learning.' },
                        { src: '/images/event1.jpg', title: 'Sports Day', desc: 'Developing teamwork and leadership through sports.' }
                    ]; galleryItems.forEach((item, index) => { %>
                    <div class="col-lg-4 col-md-6 animate-up">
                        <div class="gallery-card" style="border-radius: 16px; overflow: hidden; box-shadow: 0 8px 25px rgba(0,0,0,0.1);">
                            <img src="<%= item.src %>" alt="<%= item.title %>" style="height:280px;object-fit:cover;width:100%;display:block;">
                            <div class="gallery-overlay" style="border-radius: 0 0 16px 16px;">
                                <div>
                                    <h5 class="text-white fw-bold mb-1"><%= item.title %></h5>
                                    <p class="text-white-50 small mb-0"><%= item.desc %></p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% }); %>
                <% } %>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="section-padding" style="background: linear-gradient(135deg, var(--primary-color) 0%, #312e81 100%);">
        <div class="container text-center text-white">
            <h2 class="fw-bold mb-3" style="font-size:2.5rem;">Be Part of Our Story</h2>
            <p class="mb-4 text-white-50 fs-5">Join our community and create your own memories.</p>
            <a href="/admissions" class="btn btn-light btn-lg rounded-pill fw-bold px-5">
                <i class="fas fa-graduation-cap me-2"></i> Apply for Admission
            </a>
        </div>
    </section>

<%- include('partials/frontend_footer') %>
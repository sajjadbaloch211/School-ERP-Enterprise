<%- include('../partials/header') %>

    <div class="admin-layout animate-fade-in" style="margin-top: 80px;">
        <%- include('../partials/sidebar_student', { active: 'homework' }) %>

            <main class="main-content">
                <header
                    style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 3rem;">
                    <div>
                        <h2 style="font-size: 2rem; font-weight: 800; color: var(--primary);">Class Homework</h2>
                        <p style="color: var(--text-muted);">View assignments and submit your work</p>
                    </div>
                </header>

                <% if (success) { %>
                    <div class="alert alert-success"
                        style="background: #ecfdf5; color: #10b981; padding: 1rem; border-radius: 12px; margin-bottom: 2rem;">
                        <i class="fas fa-check-circle"></i>
                        <%= success %>
                    </div>
                    <% } %>

                        <div class="grid"
                            style="grid-template-columns: repeat(auto-fill, minmax(350px, 1fr)); gap: 2rem;">
                            <% if (homework.length===0) { %>
                                <div class="card"
                                    style="grid-column: 1/-1; padding: 4rem; text-align: center; color: var(--text-muted);">
                                    <i class="fas fa-tasks"
                                        style="font-size: 3rem; margin-bottom: 1rem; opacity: 0.3;"></i>
                                    <p>No homework assignments found for your class.</p>
                                </div>
                                <% } %>

                                    <% homework.forEach(hw=> { %>
                                        <div class="card animate-slide-up"
                                            style="padding: 2rem; border-radius: 24px; display: flex; flex-direction: column; gap: 1rem;">
                                            <div
                                                style="display: flex; justify-content: space-between; align-items: center;">
                                                <span class="badge" style="background: #eff6ff; color: #3b82f6;">
                                                    <%= hw.subject %>
                                                </span>
                                                <% if (hw.submission_id) { %>
                                                    <span class="badge" style="background: #ecfdf5; color: #10b981;"><i
                                                            class="fas fa-check"></i> Submitted</span>
                                                    <% } else { %>
                                                        <span class="badge"
                                                            style="background: #fff1f2; color: #e11d48;">Pending</span>
                                                        <% } %>
                                            </div>

                                            <h3 style="font-weight: 800; color: var(--primary);">
                                                <%= hw.title %>
                                            </h3>
                                            <p style="font-size: 0.9rem; color: var(--text-muted); line-height: 1.5;">
                                                <%= hw.description %>
                                            </p>

                                            <div
                                                style="background: #f8fafc; padding: 15px; border-radius: 15px; font-size: 0.85rem;">
                                                <div
                                                    style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                                                    <span style="color: var(--text-muted);">Teacher:</span>
                                                    <span style="font-weight: 700;">
                                                        <%= hw.teacher_name %>
                                                    </span>
                                                </div>
                                                <div
                                                    style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                                                    <span style="color: var(--text-muted);">Due Date:</span>
                                                    <span style="font-weight: 700; color: #ef4444;">
                                                        <%= new Date(hw.due_date).toLocaleDateString() %>
                                                    </span>
                                                </div>
                                                <div style="display: flex; justify-content: space-between;">
                                                    <span style="color: var(--text-muted);">Grading:</span>
                                                    <span style="font-weight: 700;">
                                                        <%= hw.marks_obtained !==null ? hw.marks_obtained : '-' %> / <%=
                                                                hw.total_marks %>
                                                    </span>
                                                </div>
                                            </div>

                                            <% if (hw.attachment_path) { %>
                                                <a href="<%= hw.attachment_path %>" target="_blank"
                                                    style="color: var(--primary); background: #f1f5f9; padding: 10px; border-radius: 12px; text-decoration: none; font-size: 0.85rem; display: flex; align-items: center; justify-content: center; gap: 10px;">
                                                    <i class="fas fa-file-download"></i> Download Assignment Material
                                                </a>
                                                <% } %>

                                                    <% if (!hw.submission_id) { %>
                                                        <form action="/student/homework/submit" method="POST"
                                                            enctype="multipart/form-data" style="margin-top: auto;">
                                                            <input type="hidden" name="_csrf"
                                                                value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
                                                            <input type="hidden" name="homework_id"
                                                                value="<%= hw.id %>">
                                                            <div style="margin-bottom: 10px;">
                                                                <label
                                                                    style="font-size: 0.8rem; font-weight: 700; color: var(--text-muted);">Upload
                                                                    Solution:</label>
                                                                <input type="file" name="submission" required
                                                                    style="width: 100%; font-size: 0.8rem; margin-top: 5px;">
                                                            </div>
                                                            <button type="submit" class="btn-primary"
                                                                style="width: 100%; padding: 12px; border-radius: 12px; font-weight: 700;">
                                                                Submit Homework
                                                            </button>
                                                        </form>
                                                        <% } else { %>
                                                            <div
                                                                style="margin-top: auto; padding: 15px; background: #f0fdf4; border: 1px dashed #22c55e; border-radius: 15px; text-align: center;">
                                                                <p
                                                                    style="color: #166534; font-weight: 700; font-size: 0.9rem;">
                                                                    Submitted <%= hw.submission_status==='late'
                                                                        ? '(Late)' : 'on time' %>
                                                                </p>
                                                                <p
                                                                    style="font-size: 0.75rem; color: #166534; opacity: 0.8;">
                                                                    <%= new Date(hw.submitted_at).toLocaleString() %>
                                                                </p>
                                                                <% if (hw.teacher_remarks) { %>
                                                                    <div
                                                                        style="margin-top: 10px; padding-top: 10px; border-top: 1px solid rgba(22, 101, 52, 0.1); font-size: 0.8rem; color: #166534;">
                                                                        <strong>Teacher's Feedback:</strong><br>
                                                                        <%= hw.teacher_remarks %>
                                                                    </div>
                                                                    <% } %>
                                                            </div>
                                                            <% } %>
                                        </div>
                                        <% }) %>
                        </div>
            </main>
    </div>

    <%- include('../partials/footer') %>
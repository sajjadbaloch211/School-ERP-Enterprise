<%- include('../partials/header') %>

    <div class="admin-layout animate-fade-in" style="margin-top: 80px;">
        <!-- Sidebar -->
        <aside class="sidebar glass"
            style="margin: 20px; border-radius: 24px; border: 1px solid rgba(0,0,0,0.05); box-shadow: var(--card-shadow);">
            <div style="margin-bottom: 3rem; text-align: center;">
                <div
                    style="width: 80px; height: 80px; background: #eff6ff; border-radius: 24px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; border: 3px solid var(--accent);">
                    <i class="fas fa-user-graduate" style="font-size: 2rem; color: var(--accent);"></i>
                </div>
                <h3 style="color: var(--primary); font-weight: 800;">Student Portal</h3>
            </div>
            <ul class="sidebar-nav">
                <li><a href="/student/dashboard"><i class="fas fa-th-large"></i> Overview</a></li>
                <li><a href="/student/attendance"><i class="fas fa-calendar-check"></i> Attendance</a></li>
                <li><a href="/student/timetable" class="active"><i class="fas fa-calendar-alt"></i> Timetable</a></li>
                <li><a href="/student/results"><i class="fas fa-poll"></i> Exam Results</a></li>
                <li><a href="/student/fees"><i class="fas fa-file-invoice-dollar"></i> Fee History</a></li>
                <li><a href="/library"><i class="fas fa-book-reader"></i> E-Library</a></li>
                <li style="margin-top: 2rem;"><a href="/logout" style="color: var(--danger);"><i
                            class="fas fa-sign-out-alt"></i> Sign Out</a></li>
            </ul>
        </aside>

        <main class="main-content">
            <header style="margin-bottom: 3rem;">
                <h2 style="font-size: 2.2rem; font-weight: 900; color: var(--primary);">Class Schedule</h2>
                <p style="color: var(--text-muted); font-weight: 500;">Stay organized with your personal weekly
                    timetable.</p>
            </header>

            <div class="card animate-slide-up" style="padding: 0; overflow: hidden; border-radius: 20px;">
                <table style="width: 100%; border-collapse: collapse;">
                    <thead>
                        <tr style="background: var(--primary); color: white; text-align: left;">
                            <th
                                style="padding: 1.5rem 2rem; border-radius: 20px 0 0 0; font-weight: 800; text-transform: uppercase; font-size: 0.8rem;">
                                Day</th>
                            <th
                                style="padding: 1.5rem 2rem; font-weight: 800; text-transform: uppercase; font-size: 0.8rem;">
                                Subject</th>
                            <th
                                style="padding: 1.5rem 2rem; font-weight: 800; text-transform: uppercase; font-size: 0.8rem;">
                                Professor</th>
                            <th
                                style="padding: 1.5rem 2rem; border-radius: 0 20px 0 0; font-weight: 800; text-transform: uppercase; font-size: 0.8rem; text-align: right;">
                                Time Slot</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(timetable.length===0) { %>
                            <tr>
                                <td colspan="4" style="padding: 5rem; text-align: center; color: var(--text-muted);">
                                    <i class="fas fa-calendar-times"
                                        style="font-size: 3rem; opacity: 0.1; display: block; margin-bottom: 1rem;"></i>
                                    No classes scheduled for your class yet.
                                </td>
                            </tr>
                            <% } %>
                                <% let lastDay="" ; timetable.forEach(row=> {
                                    %>
                                    <tr style="border-bottom: 1px solid #f1f5f9; transition: all 0.2s;"
                                        onmouseover="this.style.background='#f8fafc'"
                                        onmouseout="this.style.background='transparent'">
                                        <td style="padding: 1.5rem 2rem;">
                                            <% if(row.day !==lastDay) { %>
                                                <span
                                                    style="background: var(--accent); color: white; padding: 5px 15px; border-radius: 20px; font-size: 0.75rem; font-weight: 900; text-transform: uppercase;">
                                                    <%= row.day %>
                                                </span>
                                                <% } %>
                                        </td>
                                        <td style="padding: 1.5rem 2rem; font-weight: 800; color: var(--primary);">
                                            <%= row.subject %>
                                        </td>
                                        <td style="padding: 1.5rem 2rem; font-weight: 600; color: #64748b;">
                                            <div style="display: flex; align-items: center; gap: 8px;">
                                                <i class="fas fa-chalkboard-teacher"
                                                    style="font-size: 0.8rem; opacity: 0.5;"></i>
                                                <%= row.teacher_member || 'No Instructor' %>
                                            </div>
                                        </td>
                                        <td
                                            style="padding: 1.5rem 2rem; text-align: right; font-weight: 900; color: var(--primary); font-family: 'Outfit', sans-serif;">
                                            <%= row.start_time %> - <%= row.end_time %>
                                        </td>
                                    </tr>
                                    <% lastDay=row.day; }) %>
                    </tbody>
                </table>
            </div>
        </main>
    </div>

    <%- include('../partials/footer') %>
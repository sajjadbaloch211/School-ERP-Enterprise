<%- include('../partials/header') %>

    <div style="background: #f8fafc; min-height: 100vh; padding-top: 80px;">
        <div class="container" style="max-width: 1200px; margin: 0 auto; padding: 2rem;">

            <!-- Parent Header -->
            <header style="margin-bottom: 3rem; display: flex; justify-content: space-between; align-items: flex-end;">
                <div>
                    <h1 style="color: var(--primary); font-weight: 900; font-size: 2.5rem; margin: 0;">Family Portal
                    </h1>
                    <p style="color: var(--text-muted); font-weight: 600; font-size: 1.1rem; margin-top: 5px;">Managing
                        your child's academic and financial journey</p>
                </div>
                <div style="text-align: right;">
                    <p
                        style="margin: 0; color: var(--text-muted); font-weight: 700; text-transform: uppercase; font-size: 0.8rem;">
                        Current Balance</p>
                    <% const totalChildBalance=vouchers.reduce((sum, v)=> sum + parseFloat(v.remaining_balance), 0);
                        %>
                        <h2
                            style="margin: 0; font-weight: 900; color: <%= totalChildBalance > 0 ? '#ef4444' : '#10b981' %>; font-size: 2.2rem;">
                            RS <%= totalChildBalance.toLocaleString() %>
                        </h2>
                </div>
            </header>

            <% if (childData) { %>
                <div class="grid" style="grid-template-columns: 350px 1fr; gap: 2.5rem; align-items: start;">

                    <!-- Child Info Column -->
                    <aside>
                        <div class="card glass animate-fade-in"
                            style="padding: 2.5rem; border-radius: 30px; text-align: center; border: 1px solid rgba(59, 130, 246, 0.1);">
                            <div
                                style="width: 120px; height: 120px; background: #eff6ff; border-radius: 40px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; border: 4px solid white; box-shadow: 0 10px 20px rgba(0,0,0,0.05);">
                                <i class="fas fa-user-graduate" style="font-size: 3.5rem; color: var(--primary);"></i>
                            </div>
                            <h2 style="font-weight: 900; color: var(--text-main); margin-bottom: 5px;">
                                <%= childData.full_name %>
                            </h2>
                            <p
                                style="color: var(--primary); font-weight: 800; text-transform: uppercase; font-size: 0.85rem; letter-spacing: 1px;">
                                <%= childData.class_name %> - <%= childData.section %>
                            </p>

                            <div style="margin-top: 2rem; display: grid; gap: 10px;">
                                <a href="/student/attendance" class="btn"
                                    style="background: #f1f5f9; color: var(--text-main); padding: 12px; border-radius: 12px; font-weight: 700; text-decoration: none; display: block;">View
                                    Attendance</a>
                                <a href="/student/results" class="btn"
                                    style="background: #f1f5f9; color: var(--text-main); padding: 12px; border-radius: 12px; font-weight: 700; text-decoration: none; display: block;">Exam
                                    Results</a>
                            </div>
                        </div>
                    </aside>

                    <!-- Finance Column (Ledger) -->
                    <section>
                        <div class="card"
                            style="padding: 2.5rem; border-radius: 30px; border: none; box-shadow: 0 15px 35px rgba(0,0,0,0.03);">
                            <h3
                                style="font-weight: 900; color: var(--primary); margin-bottom: 2rem; display: flex; align-items: center; gap: 15px;">
                                <i class="fas fa-file-invoice-dollar" style="color: var(--accent);"></i> Financial
                                Ledger Overview
                            </h3>

                            <% if (vouchers.length> 0) { %>
                                <% vouchers.forEach(v=> { %>
                                    <div
                                        style="background: #f8fafc; border-radius: 20px; padding: 1.5rem; border: 1px solid #edf2f7; margin-bottom: 1.5rem;">
                                        <div
                                            style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                                            <div>
                                                <p
                                                    style="margin: 0; font-size: 0.75rem; color: var(--text-muted); font-weight: 800; text-transform: uppercase;">
                                                    Academic Year</p>
                                                <h4
                                                    style="margin: 0; font-weight: 900; font-size: 1.4rem; color: var(--primary);">
                                                    <%= v.academic_year %> Session
                                                </h4>
                                            </div>
                                            <div style="text-align: right;">
                                                <p
                                                    style="margin: 0; font-size: 0.65rem; color: var(--text-muted); font-weight: 800; text-transform: uppercase;">
                                                    Voucher Status</p>
                                                <span
                                                    style="background: <%= v.remaining_balance > 0 ? '#fff1f2' : '#ecfdf5' %>; color: <%= v.remaining_balance > 0 ? '#ef4444' : '#10b981' %>; padding: 5px 12px; border-radius: 50px; font-size: 0.65rem; font-weight: 900; border: 1px solid currentColor;">
                                                    <%= v.remaining_balance> 0 ? 'DUE: RS ' +
                                                        v.remaining_balance.toLocaleString() : 'FULLY PAID' %>
                                                </span>
                                            </div>
                                        </div>

                                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                                            <div
                                                style="background: white; padding: 1.2rem; border-radius: 15px; border-bottom: 3px solid #10b981;">
                                                <p
                                                    style="margin: 0; font-size: 0.7rem; color: #64748b; font-weight: 800;">
                                                    TOTAL PAID</p>
                                                <h5
                                                    style="margin: 5px 0 0; font-weight: 900; color: #065f46; font-size: 1.2rem;">
                                                    RS <%= v.total_paid.toLocaleString() %>
                                                </h5>
                                            </div>
                                            <div
                                                style="background: white; padding: 1.2rem; border-radius: 15px; border-bottom: 3px solid var(--primary);">
                                                <p
                                                    style="margin: 0; font-size: 0.7rem; color: #64748b; font-weight: 800;">
                                                    TOTAL CHARGES</p>
                                                <h5
                                                    style="margin: 5px 0 0; font-weight: 900; color: #1e3a8a; font-size: 1.2rem;">
                                                    RS <%= v.total_charged.toLocaleString() %>
                                                </h5>
                                            </div>
                                        </div>

                                        <div style="margin-top: 1.5rem; text-align: right;">
                                            <a href="/receipt/<%= v.id %>"
                                                style="color: var(--primary); font-weight: 800; font-size: 0.85rem; text-decoration: none;">
                                                <i class="fas fa-print"></i> Download Annual Statement
                                            </a>
                                        </div>
                                    </div>
                                    <% }) %>
                                        <% } else { %>
                                            <div style="text-align: center; padding: 3rem; color: var(--text-muted);">
                                                <i class="fas fa-info-circle"
                                                    style="font-size: 2rem; margin-bottom: 1rem;"></i>
                                                <p style="font-weight: 700;">No billing history available yet.</p>
                                            </div>
                                            <% } %>
                        </div>
                    </section>

                </div>
                <% } else { %>
                    <div class="card" style="text-align: center; padding: 5rem; border-radius: 30px;">
                        <h3 style="font-weight: 800; color: var(--primary);">No Student Profile Linked</h3>
                        <p style="color: var(--text-muted);">Please contact school administration to link your child's
                            profile to this parent account.</p>
                    </div>
                    <% } %>
        </div>
    </div>

    <%- include('../partials/footer') %>
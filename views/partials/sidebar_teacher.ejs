<aside class="sidebar glass"
    style="margin: 20px; border-radius: 24px; border: 1px solid rgba(0,0,0,0.05); box-shadow: var(--card-shadow);">
    <div style="margin-bottom: 3rem; text-align: center;">
        <div
            style="width: 80px; height: 80px; background: white; border-radius: 20px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; border: 2px solid #eee; overflow: hidden; padding: 5px;">
            <img src="/images/waqar.png" alt="Logo" style="width: 100%; height: 100%; object-fit: contain;">
        </div>
        <h3 style="color: var(--primary); font-weight: 800;">Teacher Portal</h3>
        <p style="font-size: 0.8rem; color: var(--text-muted);">
            <%= teacherData ? teacherData.subject : 'Faculty' %> Instructor
        </p>
    </div>
    <ul class="sidebar-nav">
        <li><a href="/teacher/dashboard"
                class="<%= typeof active !== 'undefined' && active === 'dashboard' ? 'active' : '' %>"><i
                    class="fas fa-home"></i> Home</a></li>
        <li><a href="/teacher/attendance"
                class="<%= typeof active !== 'undefined' && active === 'attendance' ? 'active' : '' %>"><i
                    class="fas fa-tasks"></i> Mark Attendance</a></li>
        <li><a href="/teacher/homework"
                class="<%= typeof active !== 'undefined' && active === 'homework' ? 'active' : '' %>"><i
                    class="fas fa-book-open"></i> Homework</a></li>
        <li><a href="/teacher/exams"
                class="<%= typeof active !== 'undefined' && active === 'exams' ? 'active' : '' %>"><i
                    class="fas fa-clipboard-list"></i> Exam Results</a></li>
        <li><a href="/teacher/timetable"
                class="<%= typeof active !== 'undefined' && active === 'timetable' ? 'active' : '' %>"><i
                    class="fas fa-calendar-alt"></i> My Timetable</a></li>
        <li><a href="/teacher/students"
                class="<%= typeof active !== 'undefined' && active === 'students' ? 'active' : '' %>"><i
                    class="fas fa-user-friends"></i> My Students</a></li>
        <li><a href="/library" class="<%= typeof active !== 'undefined' && active === 'library' ? 'active' : '' %>"><i
                    class="fas fa-book-reader"></i> Digital Library</a></li>
        <li style="margin-top: 2rem;"><a href="/logout" style="color: var(--danger);"><i
                    class="fas fa-sign-out-alt"></i> Logout</a></li>
    </ul>
</aside>
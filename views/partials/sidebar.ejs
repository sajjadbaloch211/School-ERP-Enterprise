<aside class="adm-sidebar" id="admSidebar" role="navigation" aria-label="Admin navigation" aria-hidden="false">
  
  <button class="adm-sidebar-close" id="admSidebarClose" aria-label="Close navigation" type="button">
    <i class="fas fa-times" aria-hidden="true"></i>
  </button>

  <!-- ── 1. HEADER (BRAND) — Fixed ── -->
  <div class="adm-sidebar-brand" role="banner">
    <div class="adm-sidebar-logo">
      <img src="<%= (typeof settings !== 'undefined' && settings && settings.site_logo) ? settings.site_logo : '/images/waqar.png' %>" alt="School Logo">
    </div>
    <div class="adm-sidebar-school">
      <div class="adm-sidebar-school-name">
        <%= (typeof campus !== 'undefined' && campus && campus.campus_name) ? campus.campus_name : ((typeof settings !== 'undefined' && settings && settings.site_name) ? settings.site_name : 'Admin Panel') %>
      </div>
    </div>
  </div>

  <!-- ── 2. USER PROFILE — Fixed ── -->
  <div class="adm-sidebar-profile">
    <div class="adm-avatar" aria-hidden="true">
      <%= typeof user !== 'undefined' && user && user.full_name ? user.full_name.trim().split(' ').map(n => n[0]).join('').slice(0,2).toUpperCase() : 'AD' %>
    </div>
    <div class="adm-sidebar-profile-info">
      <div class="adm-sidebar-profile-name">
        <%= typeof user !== 'undefined' && user && user.full_name ? user.full_name : 'Admin User' %>
      </div>
      <div class="adm-sidebar-profile-role">
        <%= typeof user !== 'undefined' && user && user.role ? user.role : 'Administrator' %>
      </div>
    </div>
  </div>

  <!-- ── 3. NAVIGATION — Scrollable ── -->
  <div class="adm-sidebar-nav" role="navigation" aria-label="Main menu">
    
    <div class="adm-nav-section">
      <a href="/admin/dashboard" class="adm-nav-item <%= (typeof active !== 'undefined' && active === 'dashboard') ? 'active' : '' %>">
        <div class="adm-nav-group-header-left">
            <i class="fas fa-home adm-nav-icon" aria-hidden="true"></i>
            <span>Dashboard</span>
        </div>
      </a>
      
      <a href="/admin/students" class="adm-nav-item <%= (typeof active !== 'undefined' && active === 'students') ? 'active' : '' %>">
        <div class="adm-nav-group-header-left">
            <i class="fas fa-user-graduate adm-nav-icon" aria-hidden="true"></i>
            <span>Students</span>
        </div>
      </a>

      <a href="/admin/teachers" class="adm-nav-item <%= (typeof active !== 'undefined' && active === 'teachers') ? 'active' : '' %>">
        <div class="adm-nav-group-header-left">
            <i class="fas fa-chalkboard-teacher adm-nav-icon" aria-hidden="true"></i>
            <span>Teachers</span>
        </div>
      </a>

      <a href="/admin/classes" class="adm-nav-item <%= (typeof active !== 'undefined' && active === 'classes') ? 'active' : '' %>">
        <div class="adm-nav-group-header-left">
            <i class="fas fa-school adm-nav-icon" aria-hidden="true"></i>
            <span>Classes</span>
        </div>
      </a>

      <a href="/admin/attendance" class="adm-nav-item <%= (typeof active !== 'undefined' && active === 'attendance') ? 'active' : '' %>">
        <div class="adm-nav-group-header-left">
            <i class="fas fa-calendar-check adm-nav-icon" aria-hidden="true"></i>
            <span>Attendance</span>
        </div>
      </a>

      <a href="/admin/timetable" class="adm-nav-item <%= (typeof active !== 'undefined' && active === 'timetable') ? 'active' : '' %>">
        <div class="adm-nav-group-header-left">
            <i class="fas fa-clock adm-nav-icon" aria-hidden="true"></i>
            <span>Timetable</span>
        </div>
      </a>

      <a href="/admin/exams" class="adm-nav-item <%= (typeof active !== 'undefined' && active === 'exams') ? 'active' : '' %>">
        <div class="adm-nav-group-header-left">
            <i class="fas fa-pen-alt adm-nav-icon" aria-hidden="true"></i>
            <span>Exams</span>
        </div>
      </a>

      <a href="/admin/fees" class="adm-nav-item <%= (typeof active !== 'undefined' && active === 'fees') ? 'active' : '' %>">
        <div class="adm-nav-group-header-left">
            <i class="fas fa-coins adm-nav-icon" aria-hidden="true"></i>
            <span>Fees</span>
        </div>
      </a>

      <a href="/admin/payroll" class="adm-nav-item <%= (typeof active !== 'undefined' && active === 'payroll') ? 'active' : '' %>">
        <div class="adm-nav-group-header-left">
            <i class="fas fa-money-check-alt adm-nav-icon" aria-hidden="true"></i>
            <span>Payroll</span>
        </div>
      </a>

      <a href="/admin/finance" class="adm-nav-item <%= (typeof active !== 'undefined' && active === 'finance') ? 'active' : '' %>">
        <div class="adm-nav-group-header-left">
            <i class="fas fa-chart-line adm-nav-icon" aria-hidden="true"></i>
            <span>Finance Ledger</span>
        </div>
      </a>

      <a href="/admin/wallet" class="adm-nav-item <%= (typeof active !== 'undefined' && active === 'wallet') ? 'active' : '' %>">
        <div class="adm-nav-group-header-left">
            <i class="fas fa-wallet adm-nav-icon" aria-hidden="true"></i>
            <span>Student Wallet</span>
        </div>
      </a>

      <a href="/admin/notifications" class="adm-nav-item <%= (typeof active !== 'undefined' && active === 'notifications') ? 'active' : '' %>" id="notif-nav-link">
        <div class="adm-nav-group-header-left">
            <i class="fas fa-bell adm-nav-icon" aria-hidden="true"></i>
            <span>Notifications <span id="sidebar-notif-badge" style="display:none;background:var(--adm-red,#ef4444);color:#fff;font-size:.65rem;font-weight:700;padding:1px 6px;border-radius:50px;margin-left:4px;"></span></span>
        </div>
      </a>

      <a href="/admin/campuses" class="adm-nav-item <%= (typeof active !== 'undefined' && active === 'campuses') ? 'active' : '' %>">

        <div class="adm-nav-group-header-left">
            <i class="fas fa-university adm-nav-icon" aria-hidden="true"></i>
            <span>Campuses</span>
        </div>
      </a>

      <a href="/admin/library" class="adm-nav-item <%= (typeof active !== 'undefined' && active === 'library') ? 'active' : '' %>">
        <div class="adm-nav-group-header-left">
            <i class="fas fa-book adm-nav-icon" aria-hidden="true"></i>
            <span>Library</span>
        </div>
      </a>

      <a href="/admin/notices" class="adm-nav-item <%= (typeof active !== 'undefined' && active === 'notices') ? 'active' : '' %>">
        <div class="adm-nav-group-header-left">
            <i class="fas fa-bullhorn adm-nav-icon" aria-hidden="true"></i>
            <span>Notices</span>
        </div>
      </a>

      <a href="/admin/email" class="adm-nav-item <%= (typeof active !== 'undefined' && active === 'email') ? 'active' : '' %>">
        <div class="adm-nav-group-header-left">
            <i class="fas fa-envelope adm-nav-icon" aria-hidden="true"></i>

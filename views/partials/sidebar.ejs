      <!-- Administration / System Options -->
      <a href="/admin/cms/pages" class="adm-nav-item <%= (typeof active !== 'undefined' && (active === 'cms_pages' || active === 'cms')) ? 'active' : '' %>">
        <div class="adm-nav-group-header-left">
            <i class="fas fa-columns adm-nav-icon" aria-hidden="true"></i>
            <span>Website Builder</span>
        </div>
      </a>

      <a href="/admin/cms/menus" class="adm-nav-item <%= (typeof active !== 'undefined' && active === 'cms_menus') ? 'active' : '' %>">
        <div class="adm-nav-group-header-left">
            <i class="fas fa-list adm-nav-icon" aria-hidden="true"></i>
            <span>CMS Menus</span>
        </div>
      </a>

      <a href="/admin/cms/theme" class="adm-nav-item <%= (typeof active !== 'undefined' && active === 'cms_theme') ? 'active' : '' %>">
        <div class="adm-nav-group-header-left">
            <i class="fas fa-paint-brush adm-nav-icon" aria-hidden="true"></i>
            <span>Theme Management</span>
        </div>
      </a>

      <a href="/admin/cms/settings" class="adm-nav-item <%= (typeof active !== 'undefined' && active === 'cms_settings') ? 'active' : '' %>">
        <div class="adm-nav-group-header-left">
            <i class="fas fa-cog adm-nav-icon" aria-hidden="true"></i>
            <span>CMS Settings</span>
        </div>
      </a>

      <a href="/admin/audit-logs" class="adm-nav-item <%= (typeof active !== 'undefined' && active === 'audit-logs') ? 'active' : '' %>">
        <div class="adm-nav-group-header-left">
            <i class="fas fa-history adm-nav-icon" aria-hidden="true"></i>
            <span>Audit Logs</span>
        </div>
      </a>

      <% if (typeof user !== 'undefined' && user && user.role === 'admin') { %>
        <a href="/admin/mfa-setup" class="adm-nav-item <%= (typeof active !== 'undefined' && active === 'mfa') ? 'active' : '' %>">
          <div class="adm-nav-group-header-left">
              <i class="fas fa-shield-alt adm-nav-icon" aria-hidden="true"></i>
              <span>Security Logs & MFA</span>
          </div>
        </a>
      <% } %>

    </div>

    <!-- Spacer to ensure bottom items aren't cut off -->
    <div style="height: 1.5rem;"></div>
  </div>

  <!-- ── 4. FOOTER (ACTIONS) — Fixed ── -->
  <div class="adm-sidebar-footer" role="contentinfo">
    <a href="/admin/notifications" class="adm-btn adm-btn-ghost adm-btn-icon" aria-label="Notifications" style="position:relative" id="notif-footer-btn">
      <i class="fas fa-bell" aria-hidden="true"></i>
      <span id="notif-footer-badge" style="display:none;position:absolute;top:4px;right:4px;width:8px;height:8px;background:var(--adm-red,#ef4444);border-radius:50%;"></span>
    </a>
    <a href="/admin/profile" class="adm-btn adm-btn-ghost adm-btn-icon" aria-label="Profile Settings">
      <i class="fas fa-cog" aria-hidden="true"></i>
    </a>
    <button type="button" class="adm-btn adm-btn-ghost adm-btn-icon" aria-label="Toggle Theme" onclick="toggleTheme()">
      <i class="fas fa-moon" id="themeIcon" aria-hidden="true"></i>
    </button>
    <a href="/logout" class="adm-btn adm-btn-ghost adm-btn-icon" aria-label="Log Out" style="color: var(--adm-red);">
      <i class="fas fa-sign-out-alt" aria-hidden="true"></i>
    </a>
  </div>

</aside>

<!-- Mobile Overlay Backdrop -->
<div class="adm-sidebar-backdrop" id="admSidebarBackdrop" aria-hidden="true"></div>

<!-- 🔔 Live Notification Badge Updater -->
<script>
(function updateNotifBadge() {
    fetch('/api/notifications/count')
        .then(r => r.json())
        .then(data => {
            const count = data.count || 0;
            const sideBadge = document.getElementById('sidebar-notif-badge');
            const footBadge = document.getElementById('notif-footer-badge');
            if (sideBadge) {
                sideBadge.textContent = count > 99 ? '99+' : count;
                sideBadge.style.display = count > 0 ? 'inline' : 'none';
            }
            if (footBadge) {
                footBadge.style.display = count > 0 ? 'block' : 'none';
            }
        })
        .catch(() => {});
    setTimeout(updateNotifBadge, 30000); // re-poll every 30s
})();
</script>
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= (typeof page !=='undefined' && page.title) ? page.title : ((typeof settings !=='undefined' &&
            settings.site_name) ? settings.site_name : 'WPHSS — W.P. Higher Secondary School') %>
    </title>
    <meta name="description"
        content="<%= (typeof page !== 'undefined' && page.description) ? page.description : 'W.P. Higher Secondary School — Excellence in Education since 1995. Admissions open for 2026 session.' %>">
    <meta name="robots" content="index, follow">
    <meta property="og:title" content="WPHSS — W.P. Higher Secondary School">
    <meta property="og:description" content="Excellence in Education — Empowering students since 1995.">
    <meta property="og:type" content="website">

    <!-- Google Fonts: Playfair Display + Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700;800;900&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <!-- Premium Frontend CSS -->
    <link rel="stylesheet" href="/modern-frontend.css">

    <!-- Bootstrap 5 (utilities + grid only) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        :root {
            /* Dynamic theme from CMS — overrides CSS variables */
            --navy: <%=(typeof theme !=='undefined' && theme.colors && theme.colors.primary) ? theme.colors.primary: '#0B1C3D' %>;
            --navy-mid: <%=(typeof theme !=='undefined' && theme.colors && theme.colors.secondary) ? theme.colors.secondary: '#112347' %>;
            --navy-light: <%=(typeof theme !=='undefined' && theme.colors && theme.colors.accent) ? theme.colors.accent: '#1a3560' %>;
            --gold:  <%=(typeof theme !=='undefined' && theme.colors && theme.colors.accent)  ? theme.colors.accent  : '#F5A623' %>;
            --text-main: <%=(typeof theme !=='undefined' && theme.colors && theme.colors.text) ? theme.colors.text: '#0B1C3D' %>;
            --text-muted: <%=(typeof theme !=='undefined' && theme.colors && theme.colors.textLight) ? theme.colors.textLight: '#64748b' %>;
            
            /* Typography mapping */
            --heading-font: <%=(typeof theme !=='undefined' && theme.fonts && theme.fonts.heading) ? theme.fonts.heading : "'Playfair Display', Georgia, serif" %>;
            --body-font: <%=(typeof theme !=='undefined' && theme.fonts && theme.fonts.body) ? theme.fonts.body : "'Inter', sans-serif" %>;
            
            /* Buttons */
            --btn-radius: <%=(typeof theme !=='undefined' && theme.button_styles && theme.button_styles.borderRadius) ? theme.button_styles.borderRadius : '8px' %>;
            --btn-shadow: <%=(typeof theme !=='undefined' && theme.button_styles && theme.button_styles.shadow) ? theme.button_styles.shadow : '0 4px 6px rgba(0,0,0,0.1)' %>;
        }

        body {
            font-family: var(--body-font) !important;
        }

        h1, h2, h3, h4, h5, h6, .display-1, .display-2, .display-3, .display-4 {
            font-family: var(--heading-font) !important;
        }
    </style>
</head>

<body>

<!-- ═══════════════════════════════════════════════
     PREMIUM NAVBAR
═══════════════════════════════════════════════ -->
<nav class="wphss-navbar" id="mainNav" role="navigation" aria-label="Main navigation">
    <div class="container">
        <div class="nav-inner">

            <!-- Brand -->
            <a href="/" class="nav-brand" aria-label="WPHSS Home">
                <img src="<%= (typeof settings !== 'undefined' && settings.site_logo) ? settings.site_logo : '/images/waqar.png' %>"
                     alt="WPHSS Logo">
                <div class="nav-brand-text">
                    <span class="nav-brand-title">
                        <%= (typeof settings !=='undefined' && settings.site_name_short) ? settings.site_name_short : 'WPHSS' %>
                    </span>
                    <span class="nav-brand-sub">Est. 1995</span>
                </div>
            </a>

            <!-- Desktop Nav Links -->
            <ul class="nav-links" id="desktopNav">
                <% if (typeof headerMenu !=='undefined' && headerMenu && headerMenu.length > 0) { %>
                    <% headerMenu.forEach(item=> { %>
                        <li><a href="<%= item.url %>"><%= item.label %></a></li>
                    <% }); %>
                <% } else { %>
                    <li><a href="/">Home</a></li>
                    <li><a href="/about">About</a></li>
                    <li><a href="/admissions">Admissions</a></li>
                    <li><a href="/fee-structure">Fee Structure</a></li>
                    <li><a href="/gallery">Gallery</a></li>
                    <li><a href="/contact">Contact</a></li>
                <% } %>
            </ul>

            <!-- Portal Button -->
            <% if(typeof user !=='undefined' && user) { %>
                <a href="/<%= user.role %>/dashboard" class="btn-portal d-none d-lg-inline-flex">
                    <i class="fas fa-th-large"></i> Dashboard
                </a>
            <% } else { %>
                <a href="/login" class="btn-portal d-none d-lg-inline-flex">
                    <i class="fas fa-lock"></i> Portal Login
                </a>
            <% } %>

            <!-- Hamburger (Mobile) -->
            <button class="nav-hamburger" id="hamburgerBtn" aria-label="Toggle menu" aria-expanded="false">
                <span></span><span></span><span></span>
            </button>
        </div>
    </div>
</nav>

<!-- Mobile Drawer Overlay -->
<div class="nav-drawer-overlay" id="drawerOverlay"></div>

<!-- Mobile Slide-Out Drawer -->
<div class="nav-drawer" id="navDrawer" role="dialog" aria-modal="true" aria-label="Mobile menu">
    <ul>
        <% if (typeof headerMenu !=='undefined' && headerMenu && headerMenu.length > 0) { %>
            <% headerMenu.forEach(item=> { %>
                <li><a href="<%= item.url %>"><%= item.label %></a></li>
            <% }); %>
        <% } else { %>
            <li><a href="/"><i class="fas fa-home" style="width:20px;color:var(--gold)"></i> Home</a></li>
            <li><a href="/about"><i class="fas fa-school" style="width:20px;color:var(--gold)"></i> About</a></li>
            <li><a href="/admissions"><i class="fas fa-graduation-cap" style="width:20px;color:var(--gold)"></i> Admissions</a></li>
            <li><a href="/fee-structure"><i class="fas fa-file-invoice-dollar" style="width:20px;color:var(--gold)"></i> Fee Structure</a></li>
            <li><a href="/gallery"><i class="fas fa-images" style="width:20px;color:var(--gold)"></i> Gallery</a></li>
            <li><a href="/contact"><i class="fas fa-envelope" style="width:20px;color:var(--gold)"></i> Contact</a></li>
        <% } %>
        <li style="margin-top:24px;border:none;">
            <% if(typeof user !=='undefined' && user) { %>
                <a href="/<%= user.role %>/dashboard" class="btn-gold" style="display:flex;justify-content:center;">
                    <i class="fas fa-th-large"></i> Dashboard
                </a>
            <% } else { %>
                <a href="/login" class="btn-primary-wphss" style="display:flex;justify-content:center;">
                    <i class="fas fa-lock"></i> Portal Login
                </a>
            <% } %>
        </li>
    </ul>
</div>

<!-- Spacer for Fixed Nav (not on homepage hero) -->
<% if (typeof isHomepage === 'undefined' || !isHomepage) { %>
    <div style="height: 82px;"></div>
<% } %>

<script>
// Navbar scroll effect
window.addEventListener('scroll', () => {
    const nav = document.getElementById('mainNav');
    if (nav) nav.classList.toggle('scrolled', window.scrollY > 60);
});

// Hamburger + Drawer
const hamburger = document.getElementById('hamburgerBtn');
const drawer = document.getElementById('navDrawer');
const overlay = document.getElementById('drawerOverlay');

function toggleDrawer(open) {
    hamburger.classList.toggle('open', open);
    drawer.classList.toggle('open', open);
    overlay.classList.toggle('open', open);
    hamburger.setAttribute('aria-expanded', open);
    document.body.style.overflow = open ? 'hidden' : '';
}

if (hamburger) {
    hamburger.addEventListener('click', () => toggleDrawer(!drawer.classList.contains('open')));
}
if (overlay) {
    overlay.addEventListener('click', () => toggleDrawer(false));
}
// Close on Escape
document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawer.classList.contains('open')) toggleDrawer(false);
});
</script>
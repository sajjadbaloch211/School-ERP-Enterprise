<!-- ═══════════════════════════════════════════════
     WPHSS PREMIUM FOOTER
═══════════════════════════════════════════════ -->
<footer class="wphss-footer" role="contentinfo">
    <div class="container">
        <div class="footer-grid">

            <!-- Brand Column -->
            <div>
                <div class="footer-brand-logo">
                    <img src="<%= (typeof settings !== 'undefined' && settings.site_logo) ? settings.site_logo : '/images/waqar.png' %>"
                         alt="WPHSS Logo">
                    <span><%= (typeof settings !=='undefined' && settings.site_name_short) ? settings.site_name_short : 'WPHSS' %></span>
                </div>
                <p class="footer-tagline">
                    <%= (typeof settings !=='undefined' && settings.footer_tagline) ? settings.footer_tagline : 'Empowering generations through quality education, strong values, and academic excellence since 1995.' %>
                </p>
                <div class="footer-social">
                    <a href="<%= (typeof settings !== 'undefined' && settings.social_facebook) ? settings.social_facebook : '#' %>"
                       class="footer-social-icon" aria-label="Facebook">
                        <i class="fab fa-facebook-f"></i>
                    </a>
                    <a href="<%= (typeof settings !== 'undefined' && settings.social_twitter) ? settings.social_twitter : '#' %>"
                       class="footer-social-icon" aria-label="Twitter/X">
                        <i class="fab fa-twitter"></i>
                    </a>
                    <a href="<%= (typeof settings !== 'undefined' && settings.social_instagram) ? settings.social_instagram : '#' %>"
                       class="footer-social-icon" aria-label="Instagram">
                        <i class="fab fa-instagram"></i>
                    </a>
                    <a href="<%= (typeof settings !== 'undefined' && settings.social_youtube) ? settings.social_youtube : '#' %>"
                       class="footer-social-icon" aria-label="YouTube">
                        <i class="fab fa-youtube"></i>
                    </a>
                </div>
            </div>

            <!-- Quick Links -->
            <div>
                <h5 class="footer-col-title">Quick Links</h5>
                <ul class="footer-links">
                    <% if (typeof footerMenu !=='undefined' && footerMenu && footerMenu.length > 0) { %>
                        <% footerMenu.forEach(item=> { %>
                            <li><a href="<%= item.url %>"><i class="fas fa-chevron-right" style="font-size:0.6rem"></i> <%= item.label %></a></li>
                        <% }); %>
                    <% } else { %>
                        <li><a href="/"><i class="fas fa-chevron-right" style="font-size:0.6rem"></i> Home</a></li>
                        <li><a href="/about"><i class="fas fa-chevron-right" style="font-size:0.6rem"></i> About Us</a></li>
                        <li><a href="/admissions"><i class="fas fa-chevron-right" style="font-size:0.6rem"></i> Admissions</a></li>
                        <li><a href="/fee-structure"><i class="fas fa-chevron-right" style="font-size:0.6rem"></i> Fee Structure</a></li>
                        <li><a href="/gallery"><i class="fas fa-chevron-right" style="font-size:0.6rem"></i> Gallery</a></li>
                        <li><a href="/contact"><i class="fas fa-chevron-right" style="font-size:0.6rem"></i> Contact</a></li>
                        <li><a href="/login"><i class="fas fa-chevron-right" style="font-size:0.6rem"></i> Portal Login</a></li>
                    <% } %>
                </ul>
            </div>

            <!-- Contact Info -->
            <div>
                <h5 class="footer-col-title">Contact Us</h5>
                <div class="footer-contact-item">
                    <i class="fas fa-map-marker-alt"></i>
                    <span>
                        <%= (typeof settings !=='undefined' && settings.school_address) ? settings.school_address : "Main Road, Khairpur Mir's, Sindh, Pakistan" %>
                    </span>
                </div>
                <div class="footer-contact-item">
                    <i class="fas fa-phone-alt"></i>
                    <span>
                        <%= (typeof settings !=='undefined' && settings.school_phone) ? settings.school_phone : "+92 243 714 5600" %>
                    </span>
                </div>
                <div class="footer-contact-item">
                    <i class="fas fa-envelope"></i>
                    <span>
                        <%= (typeof settings !=='undefined' && settings.school_email) ? settings.school_email : "info@wphss.edu.pk" %>
                    </span>
                </div>
                <div class="footer-contact-item">
                    <i class="fas fa-clock"></i>
                    <span>Mon – Sat &nbsp;|&nbsp; 7:30 AM – 2:00 PM</span>
                </div>
            </div>

            <!-- Newsletter -->
            <div>
                <h5 class="footer-col-title">Stay Updated</h5>
                <p style="font-size:0.85rem;color:rgba(255,255,255,0.5);margin-bottom:16px;line-height:1.7;">
                    Subscribe to receive admissions news, exam schedules, and school events directly.
                </p>
                <div class="footer-newsletter-input">
                    <input type="email" placeholder="Enter your email" aria-label="Email for newsletter">
                    <button type="button" aria-label="Subscribe">
                        <i class="fas fa-paper-plane"></i>
                    </button>
                </div>
                <p style="font-size:0.72rem;color:rgba(255,255,255,0.3);margin-top:10px;">
                    No spam. Unsubscribe anytime.
                </p>
            </div>
        </div>

        <!-- Footer Bottom -->
        <div class="footer-bottom">
            <p>&copy; <%= new Date().getFullYear() %>
                <%= (typeof settings !=='undefined' && settings.site_name) ? settings.site_name : 'W.P. Higher Secondary School' %>.
                All Rights Reserved.
            </p>
            <p>
                Designed with <i class="fas fa-heart" style="color:var(--gold)"></i> for academic excellence &nbsp;|&nbsp;
                <a href="/login">Staff Portal</a>
            </p>
        </div>
    </div>
</footer>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<!-- Scroll Reveal -->
<script>
(function() {
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.classList.add('revealed');
                observer.unobserve(entry.target);
            }
        });
    }, { threshold: 0.12 });

    document.querySelectorAll('.reveal, .reveal-left, .reveal-right').forEach(el => observer.observe(el));
})();
</script>

</body>
</html>
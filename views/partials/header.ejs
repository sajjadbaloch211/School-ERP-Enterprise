<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="<%= settings && settings.site_name ? settings.site_name : 'Waqar Public Higher Secondary School' %> — Admin Portal">
  <title>
    <%= page && page.title ? page.title : (settings && settings.site_title ? settings.site_title : 'Admin Portal — Waqar School') %>
  </title>

  <!-- Prevent FOUC: apply theme before render -->
  <script>
    (function () {
      var t = localStorage.getItem('adm-theme');
      if (t) document.documentElement.setAttribute('data-theme', t);
      else if (window.matchMedia('(prefers-color-scheme: dark)').matches)
        document.documentElement.setAttribute('data-theme', 'dark');
    })();
  </script>

  <!-- Google Fonts: Inter + JetBrains Mono -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap">

  <!-- Font Awesome -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

  <!-- Admin Design System CSS -->
  <link rel="stylesheet" href="/admin.css">

  <!-- Legacy style.css for any shared public utilities still referenced -->
  <link rel="stylesheet" href="/style.css">

  <!-- Theme color injection from CMS (kept for public page compatibility) -->
  <style>
    :root {
      --primary: <%=theme.colors.primary %>;
      --secondary: <%=theme.colors.secondary %>;
      --accent: <%=theme.colors.accent %>;
    }
  </style>
</head>

<body class="admin-body">

  <!-- ════════════════════════════════════════════
       ADMIN TOPBAR
       ════════════════════════════════════════════ -->
  <header class="adm-topbar" id="admTopbar" role="banner">

    <!-- Left: Hamburger + Brand (brand visible on mobile) -->
    <div class="adm-topbar-left">
      <button
        class="adm-hamburger"
        id="admHamburger"
        aria-label="Open navigation menu"
        aria-controls="admSidebar"
        aria-expanded="false"
        type="button"
      >
        <i class="fas fa-bars" aria-hidden="true"></i>
      </button>

      <!-- Brand (mobile only) -->
      <a href="/admin/dashboard" class="adm-topbar-brand" aria-label="Go to dashboard">
        <img src="<%= settings && settings.site_logo ? settings.site_logo : '/images/waqar.png' %>" alt="School Logo">
        <span><%= settings && settings.site_name ? settings.site_name.split(' ').slice(0,2).join(' ') : 'Admin Panel' %></span>
      </a>

      <!-- Search -->
      <div class="adm-topbar-search" role="search">
        <i class="fas fa-search adm-topbar-search-icon" aria-hidden="true"></i>
        <input
          type="search"
          placeholder="Search students, teachers…"
          aria-label="Search across the portal"
          autocomplete="off"
        >
      </div>
    </div>

    <!-- Right: Actions -->
    <div class="adm-topbar-actions" role="group" aria-label="Topbar actions">

      <!-- Dark mode toggle -->
      <button
        class="adm-icon-btn adm-dark-toggle"
        id="admDarkToggle"
        aria-label="Switch to dark mode"
        type="button"
        title="Toggle dark mode"
      >
        <i class="fas fa-moon" aria-hidden="true"></i>
      </button>

      <!-- Notifications -->
      <button class="adm-icon-btn" aria-label="Notifications" type="button" title="Notifications">
        <i class="fas fa-bell" aria-hidden="true"></i>
        <span class="adm-badge-dot" aria-hidden="true"></span>
      </button>

      <!-- User Avatar -->
      <% if (typeof user !== 'undefined' && user) { %>
      <div class="adm-topbar-user" role="button" tabindex="0" aria-label="User menu" title="<%= user.full_name %>">
        <div class="adm-avatar" aria-hidden="true">
          <%= user.full_name ? user.full_name.trim().split(' ').map(n => n[0]).join('').slice(0,2).toUpperCase() : 'AD' %>
        </div>
        <div class="adm-avatar-info">
          <span class="adm-avatar-name"><%= user.full_name %></span>
          <span class="adm-avatar-role"><%= user.role %></span>
        </div>
        <i class="fas fa-chevron-down" style="font-size:0.6rem; color: var(--adm-text-muted); margin-left:0.125rem;" aria-hidden="true"></i>
      </div>
      <% } %>

    </div>
  </header>

  <!-- Mobile overlay (new admin pages) -->
  <div class="adm-sidebar-overlay" id="admOverlay" aria-hidden="true"></div>

  <!-- Legacy overlay & toggle for non-upgraded pages (student, teacher, other admin pages) -->
  <div class="sidebar-overlay" id="sidebarOverlay"></div>

  <!-- Chart.js loaded async for performance -->
  <script id="chartJsScript" src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js" defer></script>

  <!-- Admin JS (dark mode ASAP, rest on DOMContentLoaded) -->
  <script src="/admin.js" defer></script>
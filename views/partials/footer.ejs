<footer class="animate-fade-in" style="background: <%= theme.colors.primary %>; color: white;">
    <div class="footer-grid">
        <div class="footer-col">
            <h3 style="font-weight: 800; font-size: 1.5rem; margin-bottom: 1.5rem;">
                <%= settings.school_name || 'Waqar Public Higher Secondary School' %>
            </h3>
            <p style="color: rgba(255,255,255,0.6); line-height: 1.8;">
                <%= settings.footer_about || 'Providing a balanced education that nurtures both the mind and soul.' %>
            </p>
            <div style="margin-top: 1.5rem; display: flex; gap: 15px;">
                <% if(settings.facebook_url) { %>
                    <a href="<%= settings.facebook_url %>"
                        style="width: 35px; height: 35px; border-radius: 50%; background: rgba(255,255,255,0.1); display: flex; align-items: center; justify-content: center; color: white;"><i
                            class="fab fa-facebook-f"></i></a>
                    <% } %>
                        <% if(settings.twitter_url) { %>
                            <a href="<%= settings.twitter_url %>"
                                style="width: 35px; height: 35px; border-radius: 50%; background: rgba(255,255,255,0.1); display: flex; align-items: center; justify-content: center; color: white;"><i
                                    class="fab fa-twitter"></i></a>
                            <% } %>
                                <% if(settings.instagram_url) { %>
                                    <a href="<%= settings.instagram_url %>"
                                        style="width: 35px; height: 35px; border-radius: 50%; background: rgba(255,255,255,0.1); display: flex; align-items: center; justify-content: center; color: white;"><i
                                            class="fab fa-instagram"></i></a>
                                    <% } %>
            </div>
        </div>
        <div class="footer-col">
            <h3>Quick Links</h3>
            <ul>
                <% if (footerMenu && footerMenu.length> 0) { %>
                    <% footerMenu.forEach(item=> { %>
                        <li><a href="<%= item.url %>">
                                <%= item.label %>
                            </a></li>
                        <% }) %>
                            <% } else { %>
                                <li><a href="/about">About Us</a></li>
                                <li><a href="/admissions">Admissions</a></li>
                                <li><a href="/gallery">Gallery</a></li>
                                <li><a href="/contact">Contact</a></li>
                                <% } %>
            </ul>
        </div>
        <div class="footer-col">
            <h3>Student Portal</h3>
            <ul>
                <li><a href="/login">Portal Login</a></li>
                <li><a href="/fee-structure">Fee Details</a></li>
                <li><a href="/downloads">Resources</a></li>
            </ul>
        </div>
        <div class="footer-col">
            <h3>Contact Us</h3>
            <p style="margin-bottom: 1rem; color: rgba(255,255,255,0.6);"><i class="fas fa-map-marker-alt"
                    style="color: var(--accent); margin-right: 10px;"></i>
                <%= settings.address || 'Main Road, Khairpur Mir\' s' %>
            </p>
            <p style="margin-bottom: 1rem; color: rgba(255,255,255,0.6);"><i class="fas fa-phone-alt"
                    style="color: var(--accent); margin-right: 10px;"></i>
                <%= settings.phone || '+92 123 4567890' %>
            </p>
            <p style="color: rgba(255,255,255,0.6);"><i class="fas fa-envelope"
                    style="color: var(--accent); margin-right: 10px;"></i>
                <%= settings.email || 'info@waqar.edu.pk' %>
            </p>
        </div>
    </div>
    <div class="copyright">
        <p>&copy; <%= new Date().getFullYear() %>
                <%= settings.school_name || 'Waqar Public' %>. All Rights Reserved.</p>
    </div>
</footer>
<script src="/script.js"></script>
</body>

</html>
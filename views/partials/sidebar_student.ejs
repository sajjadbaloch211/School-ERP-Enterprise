<aside class="sidebar glass"
    style="margin: 20px; border-radius: 24px; border: 1px solid rgba(0,0,0,0.05); box-shadow: var(--card-shadow);">
    <div style="margin-bottom: 3rem; text-align: center;">
        <div
            style="width: 80px; height: 80px; background: white; border-radius: 24px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.5rem; border: 2px solid #eee; overflow: hidden; padding: 5px; box-shadow: 0 10px 20px rgba(0,0,0,0.05);">
            <img src="/images/waqar.png" alt="Logo" style="width: 100%; height: 100%; object-fit: contain;">
        </div>
        <h3 style="color: var(--primary); font-weight: 800;">Student Portal</h3>
        <p style="font-size: 0.8rem; color: var(--text-muted); font-weight: 600;">
            <%= studentData.class_name %> - <%= studentData.section %>
        </p>
    </div>
    <ul class="sidebar-nav">
        <li><a href="/student/dashboard"
                class="<%= typeof active !== 'undefined' && active === 'dashboard' ? 'active' : '' %>"><i
                    class="fas fa-th-large"></i> Overview</a></li>
        <li><a href="/student/attendance"
                class="<%= typeof active !== 'undefined' && active === 'attendance' ? 'active' : '' %>"><i
                    class="fas fa-calendar-check"></i> Attendance</a></li>
        <li><a href="/student/homework"
                class="<%= typeof active !== 'undefined' && active === 'homework' ? 'active' : '' %>"><i
                    class="fas fa-book-open"></i> Homework</a></li>
        <li><a href="/student/timetable"
                class="<%= typeof active !== 'undefined' && active === 'timetable' ? 'active' : '' %>"><i
                    class="fas fa-calendar-alt"></i> Timetable</a></li>
        <li><a href="/student/results"
                class="<%= typeof active !== 'undefined' && active === 'results' ? 'active' : '' %>"><i
                    class="fas fa-poll"></i> Exam Results</a></li>
        <li><a href="/student/fees" class="<%= typeof active !== 'undefined' && active === 'fees' ? 'active' : '' %>"><i
                    class="fas fa-file-invoice-dollar"></i> Fee History</a></li>
        <li><a href="/library" class="<%= typeof active !== 'undefined' && active === 'library' ? 'active' : '' %>"><i
                    class="fas fa-book-reader"></i> E-Library</a></li>
        <li style="margin-top: 2rem;"><a href="/logout" style="color: var(--danger);"><i
                    class="fas fa-sign-out-alt"></i> Sign Out</a></li>
    </ul>
</aside>
<%- include('partials/frontend_header') %>

    <!-- Hero Banner -->
    <section class="hero-section" style="min-height: 52vh; background-image: url('/images/school-bg.jpg');">
        <div class="hero-overlay"></div>
        <div class="container hero-content text-center animate-up">
            <span class="hero-badge"><i class="fas fa-file-invoice-dollar me-2"></i> Academic Year 2026-27</span>
            <h1 class="hero-title">Fee <span style="color: var(--accent-color);">Structure</span></h1>
            <p class="hero-lead mx-auto" style="max-width:600px;">
                Investing in quality education. Our competitive and transparent fee structure for all wings.
            </p>
        </div>
    </section>

    <!-- Pricing Section -->
    <section class="section-padding bg-white">
        <div class="container">
            <div class="text-center mb-5 animate-up">
                <span class="section-label">Monthly Tuition</span>
                <h2 class="section-title">Academic Session 2026-27</h2>
                <p class="section-desc">Transparent and affordable fee structure for every student.</p>
            </div>

            <div class="row g-4 justify-content-center align-items-center">
                <!-- Primary Wing -->
                <div class="col-lg-4 col-md-6 animate-up">
                    <div class="card h-100 border-0 shadow-lg rounded-4 overflow-hidden text-center shadow-hover">
                        <div class="p-4 text-white" style="background: linear-gradient(135deg, var(--primary-color), #2d5ed4);">
                            <i class="fas fa-child fa-2x mb-3 opacity-75"></i>
                            <h4 class="fw-bold mb-0">Primary Wing</h4>
                            <span class="small opacity-75">Grade 1 – 5</span>
                        </div>
                        <div class="card-body p-5">
                            <h2 class="fw-bold mb-0" style="font-size:3rem; color:var(--primary-color);">Rs. 1,500</h2>
                            <span class="text-muted small d-block mb-4">Per Month</span>
                            <ul class="list-unstyled text-start">
                                <li class="mb-3 d-flex gap-2"><i class="fas fa-check-circle text-success mt-1 flex-shrink-0"></i> <span class="text-muted">Qualified & Experienced Teachers</span></li>
                                <li class="mb-3 d-flex gap-2"><i class="fas fa-check-circle text-success mt-1 flex-shrink-0"></i> <span class="text-muted">Activity Based Learning</span></li>
                                <li class="mb-3 d-flex gap-2"><i class="fas fa-check-circle text-success mt-1 flex-shrink-0"></i> <span class="text-muted">Sports, Arts & Extracurriculars</span></li>
                                <li class="mb-3 d-flex gap-2"><i class="fas fa-check-circle text-success mt-1 flex-shrink-0"></i> <span class="text-muted">Monthly Progress Reports</span></li>
                            </ul>
                        </div>
                        <div class="p-4 bg-light border-top">
                            <a href="/admissions" class="btn btn-outline-primary rounded-pill w-100 fw-bold py-2">Apply Now</a>
                        </div>
                    </div>
                </div>

                <!-- Secondary Wing (Featured) -->
                <div class="col-lg-4 col-md-6 animate-up delay-100">
                    <div class="card h-100 border-0 shadow-lg rounded-4 overflow-hidden text-center" style="transform: scale(1.05); z-index: 10; box-shadow: 0 30px 60px rgba(15,23,42,0.2) !important;">
                        <div class="py-2 text-dark fw-bold small text-uppercase tracking-widest" style="background: #fbbf24; letter-spacing: 1px;">
                            <i class="fas fa-star me-1"></i> Most Popular
                        </div>
                        <div class="p-4 text-white" style="background: linear-gradient(135deg, #0f172a, #1e293b);">
                            <i class="fas fa-book-open fa-2x mb-3 opacity-75"></i>
                            <h4 class="fw-bold mb-0">Secondary Wing</h4>
                            <span class="small opacity-75">Grade 6 – 10</span>
                        </div>
                        <div class="card-body p-5">
                            <h2 class="fw-bold mb-0" style="font-size:3rem; color:#0f172a;">Rs. 2,500</h2>
                            <span class="text-muted small d-block mb-4">Per Month</span>
                            <ul class="list-unstyled text-start">
                                <li class="mb-3 d-flex gap-2"><i class="fas fa-check-circle text-success mt-1 flex-shrink-0"></i> <span class="text-muted">Science Labs Access</span></li>
                                <li class="mb-3 d-flex gap-2"><i class="fas fa-check-circle text-success mt-1 flex-shrink-0"></i> <span class="text-muted">Computer Education</span></li>
                                <li class="mb-3 d-flex gap-2"><i class="fas fa-check-circle text-success mt-1 flex-shrink-0"></i> <span class="text-muted">Board Exam Preparation</span></li>
                                <li class="mb-3 d-flex gap-2"><i class="fas fa-check-circle text-success mt-1 flex-shrink-0"></i> <span class="text-muted">Digital Learning Resources</span></li>
                            </ul>
                        </div>
                        <div class="p-4 border-top">
                            <a href="/admissions" class="btn w-100 fw-bold py-2 rounded-pill text-white" style="background:var(--primary-color);">Apply Now</a>
                        </div>
                    </div>
                </div>

                <!-- Higher Secondary -->
                <div class="col-lg-4 col-md-6 animate-up delay-200">
                    <div class="card h-100 border-0 shadow-lg rounded-4 overflow-hidden text-center shadow-hover">
                        <div class="p-4 text-white" style="background: linear-gradient(135deg, #7c3aed, #5b21b6);">
                            <i class="fas fa-graduation-cap fa-2x mb-3 opacity-75"></i>
                            <h4 class="fw-bold mb-0">Higher Secondary</h4>
                            <span class="small opacity-75">Grade 11 – 12</span>
                        </div>
                        <div class="card-body p-5">
                            <h2 class="fw-bold mb-0" style="font-size:3rem; color:#7c3aed;">Rs. 3,500</h2>
                            <span class="text-muted small d-block mb-4">Per Month</span>
                            <ul class="list-unstyled text-start">
                                <li class="mb-3 d-flex gap-2"><i class="fas fa-check-circle text-success mt-1 flex-shrink-0"></i> <span class="text-muted">Pre-Medical / Pre-Engineering</span></li>
                                <li class="mb-3 d-flex gap-2"><i class="fas fa-check-circle text-success mt-1 flex-shrink-0"></i> <span class="text-muted">Career Counseling Sessions</span></li>
                                <li class="mb-3 d-flex gap-2"><i class="fas fa-check-circle text-success mt-1 flex-shrink-0"></i> <span class="text-muted">University Preparation</span></li>
                                <li class="mb-3 d-flex gap-2"><i class="fas fa-check-circle text-success mt-1 flex-shrink-0"></i> <span class="text-muted">Special Coaching Classes</span></li>
                            </ul>
                        </div>
                        <div class="p-4 bg-light border-top">
                            <a href="/admissions" class="btn btn-outline-primary rounded-pill w-100 fw-bold py-2">Apply Now</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center mt-5 animate-up delay-300">
                <div class="d-inline-block px-5 py-3 rounded-3" style="background:#fffbeb; border: 1px solid #fbbf24;">
                    <i class="fas fa-info-circle text-warning me-2"></i>
                    <span class="text-muted small">* Additional Annual Charges & one-time Admission Fee apply. Contact admissions office for concession schemes.</span>
                </div>
            </div>
        </div>
    </section>

    <!-- Additional Charges Table -->
    <section class="section-padding" style="background: var(--bg-light);">
        <div class="container">
            <div class="text-center mb-5">
                <span class="section-label">Other Charges</span>
                <h2 class="section-title">Additional Fee Details</h2>
            </div>
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <div class="bg-white rounded-4 shadow-sm overflow-hidden animate-up">
                        <table class="table table-hover mb-0">
                            <thead style="background:var(--primary-color); color:white;">
                                <tr>
                                    <th class="py-3 px-4">Charge Type</th>
                                    <th class="py-3 px-4 text-end">Amount (Rs.)</th>
                                    <th class="py-3 px-4">Frequency</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr><td class="py-3 px-4">Admission Fee</td><td class="py-3 px-4 text-end fw-bold">3,000</td><td class="py-3 px-4 text-muted">One-time</td></tr>
                                <tr><td class="py-3 px-4">Annual Charges</td><td class="py-3 px-4 text-end fw-bold">2,000</td><td class="py-3 px-4 text-muted">Per Year</td></tr>
                                <tr><td class="py-3 px-4">Examination Fee</td><td class="py-3 px-4 text-end fw-bold">500</td><td class="py-3 px-4 text-muted">Per Term</td></tr>
                                <tr><td class="py-3 px-4">Library Fee</td><td class="py-3 px-4 text-end fw-bold">200</td><td class="py-3 px-4 text-muted">Per Month</td></tr>
                                <tr class="table-success"><td class="py-3 px-4 fw-bold text-success">Merit Scholarship</td><td class="py-3 px-4 text-end fw-bold text-success">Up to 50%</td><td class="py-3 px-4 text-success">Monthly Discount</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="section-padding" style="background: linear-gradient(135deg, var(--primary-color) 0%, #312e81 100%);">
        <div class="container text-center text-white">
            <h2 class="fw-bold mb-3" style="font-size:2.5rem;">Have Questions About Fees?</h2>
            <p class="mb-4 text-white-50 fs-5">Our admissions team is ready to assist you with fee plans and scholarships.</p>
            <a href="/contact" class="btn btn-light btn-lg rounded-pill fw-bold px-5">
                <i class="fas fa-phone-alt me-2"></i> Contact Us
            </a>
        </div>
    </section>

<%- include('partials/frontend_footer') %>
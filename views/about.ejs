<%- include('partials/frontend_header') %>

    <!-- Hero Banner -->
    <section class="hero-section" style="min-height: 52vh; background-image: url('/images/school-bg.jpg');">
        <div class="hero-overlay"></div>
        <div class="container hero-content text-center animate-up">
            <span class="hero-badge"><i class="fas fa-history me-2"></i> Est. 1995 — Over 25 Years of Excellence</span>
            <h1 class="hero-title">About <span style="color: var(--accent-color);">Our School</span></h1>
            <p class="hero-lead mx-auto" style="max-width:600px;">
                A legacy of academic excellence, character building, and shaping the future leaders of tomorrow.
            </p>
        </div>
    </section>

    <!-- Our Story Section -->
    <section class="section-padding bg-white">
        <div class="container">
            <div class="row align-items-center g-5">
                <div class="col-lg-6 animate-up">
                    <img src="/images/award.jpg" alt="About Our School" class="img-fluid rounded-4 shadow-lg w-100" style="object-fit:cover; max-height: 450px;">
                </div>
                <div class="col-lg-6 animate-up delay-100">
                    <span class="section-label">Our Story</span>
                    <h2 class="section-title">Empowering <span class="text-gradient">Young Minds</span></h2>
                    <p class="text-muted lead" style="line-height:1.9;">
                        <strong><%= (typeof settings !== 'undefined' && settings.site_name) ? settings.site_name : 'Waqar Public Higher Secondary School' %></strong>
                        has been a beacon of academic excellence in Khairpur Mir's for over two decades. Founded with a vision to provide quality education to the youth of Sindh, we have consistently produced top-tier students who are now leading in various professional fields.
                    </p>
                    <p class="text-muted" style="line-height:1.9;">
                        Our approach combines rigorous academic training with a strong focus on character development, sports, and cultural awareness. We believe in nurturing well-rounded individuals ready to face global challenges.
                    </p>
                    <div class="row g-3 mt-3">
                        <div class="col-6">
                            <div class="d-flex align-items-center gap-3">
                                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:48px;height:48px;background:rgba(30,58,138,0.1);">
                                    <i class="fas fa-users" style="color:var(--primary-color);"></i>
                                </div>
                                <div>
                                    <div class="fw-bold fs-4" style="color:var(--primary-color);">1500+</div>
                                    <div class="small text-muted">Students</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="d-flex align-items-center gap-3">
                                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:48px;height:48px;background:rgba(59,130,246,0.1);">
                                    <i class="fas fa-chalkboard-teacher" style="color:var(--secondary-color);"></i>
                                </div>
                                <div>
                                    <div class="fw-bold fs-4" style="color:var(--secondary-color);">100+</div>
                                    <div class="small text-muted">Teachers</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="d-flex align-items-center gap-3">
                                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:48px;height:48px;background:rgba(124,58,237,0.1);">
                                    <i class="fas fa-trophy" style="color:#7c3aed;"></i>
                                </div>
                                <div>
                                    <div class="fw-bold fs-4" style="color:#7c3aed;">50+</div>
                                    <div class="small text-muted">Awards</div>
                                </div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="d-flex align-items-center gap-3">
                                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width:48px;height:48px;background:rgba(5,150,105,0.1);">
                                    <i class="fas fa-calendar-alt" style="color:#059669;"></i>
                                </div>
                                <div>
                                    <div class="fw-bold fs-4" style="color:#059669;">25+</div>
                                    <div class="small text-muted">Years</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Mission Vision Values -->
    <section class="section-padding" style="background: var(--bg-light);">
        <div class="container">
            <div class="text-center mb-5">
                <span class="section-label">What Drives Us</span>
                <h2 class="section-title">Our Mission, Vision & Values</h2>
            </div>
            <div class="row g-4">
                <div class="col-md-4 animate-up">
                    <div class="card-feature h-100" style="text-align:left;">
                        <div class="icon-box ms-0" style="background:rgba(30,58,138,0.08);color:var(--primary-color);">
                            <i class="fas fa-bullseye"></i>
                        </div>
                        <h4 class="fw-bold mt-4 mb-3">Our Mission</h4>
                        <p class="text-muted">To provide affordable, high-quality education that empowers students to achieve academic excellence, moral integrity, and lifelong success.</p>
                    </div>
                </div>
                <div class="col-md-4 animate-up delay-100">
                    <div class="card-feature h-100" style="text-align:left;">
                        <div class="icon-box ms-0" style="background:rgba(5,150,105,0.08);color:#059669;">
                            <i class="fas fa-eye"></i>
                        </div>
                        <h4 class="fw-bold mt-4 mb-3">Our Vision</h4>
                        <p class="text-muted">To be a leading institution that fosters innovation, leadership, and a lifelong passion for learning in every student we serve.</p>
                    </div>
                </div>
                <div class="col-md-4 animate-up delay-200">
                    <div class="card-feature h-100" style="text-align:left;">
                        <div class="icon-box ms-0" style="background:rgba(245,158,11,0.08);color:#d97706;">
                            <i class="fas fa-heart"></i>
                        </div>
                        <h4 class="fw-bold mt-4 mb-3">Core Values</h4>
                        <p class="text-muted">Integrity, Discipline, Respect, Excellence, and Community Service are the core pillars that guide our institution every day.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Principal's Message -->
    <section class="section-padding bg-white">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-9">
                    <div class="p-5 rounded-4 shadow-sm border animate-up" style="border-left: 5px solid var(--primary-color) !important; background: #f8fafc;">
                        <i class="fas fa-quote-left fa-3x mb-4 d-block" style="color:var(--secondary-color);opacity:0.3;"></i>
                        <blockquote class="mb-4">
                            <p class="fs-5 fst-italic text-muted" style="line-height:1.9;">
                                "Education is not just about filling a bucket, but lighting a fire. At Waqar Public School, we strive to ignite that spark of curiosity and ambition in every child — preparing them not just for exams, but for life."
                            </p>
                        </blockquote>
                        <div class="d-flex align-items-center gap-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0 text-white fw-bold" style="width:52px;height:52px;background:var(--primary-color);font-size:1.2rem;">P</div>
                            <div>
                                <div class="fw-bold" style="color:var(--primary-color);">The Principal</div>
                                <div class="small text-muted"><%= (typeof settings !== 'undefined' && settings.site_name) ? settings.site_name : 'Waqar Public Higher Secondary School' %></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="section-padding" style="background: linear-gradient(135deg, var(--primary-color) 0%, #312e81 100%);">
        <div class="container text-center text-white">
            <h2 class="fw-bold mb-3" style="font-size:2.5rem;">Become Part of Our Family</h2>
            <p class="mb-4 text-white-50 fs-5">Admissions are now open for the 2026-27 academic year.</p>
            <div class="d-flex gap-3 justify-content-center flex-wrap">
                <a href="/admissions" class="btn btn-light btn-lg rounded-pill fw-bold px-5">
                    <i class="fas fa-graduation-cap me-2"></i> Apply Now
                </a>
                <a href="/contact" class="btn btn-outline-light btn-lg rounded-pill fw-bold px-5">
                    <i class="fas fa-envelope me-2"></i> Contact Us
                </a>
            </div>
        </div>
    </section>

<%- include('partials/frontend_footer') %>
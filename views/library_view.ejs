<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Digital Library - Waqar Public School</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/style.css">
</head>

<body style="background: var(--bg-light);">

    <!-- Header -->
    <header class="glass" style="position: sticky; top: 0; z-index: 1000; padding: 1rem 5%;">
        <div
            style="display: flex; justify-content: space-between; align-items: center; max-width: 1400px; margin: 0 auto;">
            <div style="display: flex; align-items: center; gap: 15px;">
                <img src="/logo.jpg" alt="Logo" style="height: 50px; border-radius: 12px;">
                <h2 style="color: var(--primary); font-weight: 800; font-size: 1.5rem;">Digital Library</h2>
            </div>
            <div style="display: flex; align-items: center; gap: 15px;">
                <span
                    style="font-size: 0.8rem; background: #e2e8f0; padding: 5px 12px; border-radius: 50px; font-weight: 700; color: var(--primary);">
                    <i class="fas fa-user-circle"></i>
                    <%= String(role).toUpperCase() %>
                        <% if(typeof studentClass !=='undefined' ) { %> | <%= studentClass %>
                                <% } %>
                </span>
                <% if(role) { %>
                    <a href="/<%= role %>/dashboard" class="btn" style="color: var(--text-muted); font-weight: 600;"><i
                            class="fas fa-arrow-left"></i> Back to Dashboard</a>
                    <% } else { %>
                        <a href="/login" class="btn-primary">Login</a>
                        <% } %>
            </div>
        </div>
    </header>

    <main style="padding: 3rem 5%; max-width: 1400px; margin: 0 auto;" class="animate-fade-in">
        <!-- Hero Section with Illustration -->
        <div
            style="display: flex; align-items: center; justify-content: space-between; gap: 4rem; margin-bottom: 5rem; flex-wrap: wrap;">
            <div style="flex: 1; min-width: 350px; text-align: left;">
                <span
                    style="background: #eff6ff; color: #3b82f6; padding: 8px 16px; border-radius: 50px; font-weight: 800; font-size: 0.9rem; margin-bottom: 1.5rem; display: inline-block; text-transform: uppercase; letter-spacing: 1px;">
                    Knowledge Hub
                </span>
                <h1
                    style="font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 900; color: var(--primary); margin-bottom: 1.5rem; line-height: 1.1;">
                    Explore <span
                        style="color: transparent; -webkit-text-stroke: 1.5px var(--primary); opacity: 0.7;">Digital</span>
                    <br>Knowledge
                </h1>
                <p
                    style="color: var(--text-muted); font-size: 1.25rem; line-height: 1.6; max-width: 550px; margin-bottom: 2rem; font-weight: 500;">
                    Access a vast collection of e-books, research papers, and study materials curated to empower your
                    learning journey.
                </p>
                <div style="display: flex; gap: 15px;">
                    <button onclick="document.getElementById('searchInput').focus()" class="btn-primary"
                        style="padding: 15px 30px; border-radius: 15px; font-weight: 700; font-size: 1rem; box-shadow: 0 10px 20px rgba(59, 130, 246, 0.3);">
                        Start Browsing
                    </button>
                    <div
                        style="display: flex; align-items: center; gap: 10px; color: var(--text-muted); font-weight: 600;">
                        <i class="fas fa-play-circle" style="font-size: 2rem; color: #3b82f6; opacity: 0.5;"></i> Watch
                        Guide
                    </div>
                </div>
            </div>

            <div style="flex: 1.2; min-width: 350px; position: relative;">
                <div
                    style="position: absolute; top: 10%; left: 10%; width: 80%; height: 80%; background: var(--primary); filter: blur(100px); opacity: 0.1; z-index: -1;">
                </div>
                <img src="/images/library_hero.png" alt="Digital Library Illustration"
                    style="width: 100%; height: auto; border-radius: 32px; box-shadow: 0 30px 60px rgba(0,0,0,0.1); transform: perspective(1000px) rotateY(-5deg); transition: transform 0.5s ease;"
                    onmouseover="this.style.transform='perspective(1000px) rotateY(0deg) scale(1.02)'"
                    onmouseout="this.style.transform='perspective(1000px) rotateY(-5deg)'">

                <!-- Floating Stats -->
                <div class="glass"
                    style="position: absolute; bottom: -30px; left: -30px; padding: 1.5rem; border-radius: 20px; display: flex; align-items: center; gap: 15px; box-shadow: 0 20px 40px rgba(0,0,0,0.1);">
                    <div
                        style="width: 50px; height: 50px; background: #ecfdf5; color: #10b981; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem;">
                        <i class="fas fa-book"></i>
                    </div>
                    <div>
                        <div style="font-size: 1.2rem; font-weight: 900; color: var(--primary);">
                            <%= books.length %>+
                        </div>
                        <div style="font-size: 0.75rem; font-weight: 700; color: var(--text-muted);">E-Books Available
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Filter/Search Bar -->
        <div class="glass" style="padding: 1.5rem; margin-bottom: 3rem; border-radius: 20px;">
            <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
                <div style="flex: 2; position: relative; min-width: 300px;">
                    <i class="fas fa-search"
                        style="position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: var(--text-muted);"></i>
                    <input type="text" id="searchInput" onkeyup="filterLibrary()" placeholder="Search by title..."
                        style="width: 100%; padding: 12px 12px 12px 40px; border-radius: 12px; border: 1px solid rgba(0,0,0,0.1); background: white;">
                </div>

                <% if (role==='teacher' || role==='admin' ) { %>
                    <div style="flex: 1; min-width: 150px;">
                        <select id="gradeFilter" onchange="filterLibrary()"
                            style="width: 100%; padding: 12px; border-radius: 12px; border: 1px solid rgba(0,0,0,0.1); background: white;">
                            <option value="all">All Grades</option>
                            <% const uniqueGrades=[...new Set(books.map(b=> b.target_grade || 'General'))];
                                uniqueGrades.sort().forEach(g => { %>
                                <option value="<%= g %>">
                                    <%= g %>
                                </option>
                                <% }) %>
                        </select>
                    </div>
                    <% } %>

                        <div style="flex: 1; min-width: 150px;">
                            <select id="subjectFilter" onchange="filterLibrary()"
                                style="width: 100%; padding: 12px; border-radius: 12px; border: 1px solid rgba(0,0,0,0.1); background: white;">
                                <option value="all">All Subjects</option>
                                <% const uniqueSubjects=[...new Set(books.map(b=> b.subject))];
                                    uniqueSubjects.sort().forEach(s => { %>
                                    <option value="<%= s %>">
                                        <%= s %>
                                    </option>
                                    <% }) %>
                            </select>
                        </div>
            </div>
        </div>

        <% if (books.length===0) { %>
            <div style="text-align: center; padding: 5rem; opacity: 0.6;">
                <i class="fas fa-book-open"
                    style="font-size: 4rem; color: var(--text-muted); margin-bottom: 1.5rem;"></i>
                <h3 style="color: var(--primary); font-weight: 700;">Library is Empty</h3>
                <p>Check back later for new uploads.</p>
            </div>
            <% } else { %>
                <div class="grid animate-slide-up"
                    style="grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2rem;" id="libraryGrid">
                    <% books.forEach(book=> { %>
                        <div class="card library-item" data-title="<%= book.title.toLowerCase() %>"
                            data-grade="<%= (book.target_grade || 'General') %>" data-subject="<%= book.subject %>"
                            style="padding: 2rem; border-radius: 20px; transition: var(--transition);">

                            <div
                                style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 1.5rem;">
                                <% let icon='fa-file-alt' ; let color='#64748b' ; let bg='#e2e8f0' ;
                                    if(book.file_type==='pdf' ) { icon='fa-file-pdf' ; color='#ef4444' ; bg='#fef2f2' ;
                                    } else if(book.file_type==='word' ) { icon='fa-file-word' ; color='#3b82f6' ;
                                    bg='#eff6ff' ; } else if(book.file_type==='image' ) { icon='fa-file-image' ;
                                    color='#10b981' ; bg='#ecfdf5' ; } else if(book.file_type==='video' ) {
                                    icon='fa-file-video' ; color='#8b5cf6' ; bg='#f5f3ff' ; } else
                                    if(book.file_type==='archive' ) { icon='fa-file-archive' ; color='#f59e0b' ;
                                    bg='#fffbeb' ; } %>
                                    <div
                                        style="width: 60px; height: 60px; border-radius: 16px; background: <%= bg %>; color: <%= color %>; display: flex; align-items: center; justify-content: center; font-size: 2rem;">
                                        <i class="fas <%= icon %>"></i>
                                    </div>
                                    <div
                                        style="display: flex; flex-direction: column; align-items: flex-end; gap: 5px;">
                                        <span
                                            style="font-size: 0.7rem; font-weight: 700; color: #3b82f6; background: #eff6ff; padding: 4px 10px; border-radius: 50px;">
                                            <%= book.target_grade || 'General' %>
                                        </span>
                                        <span
                                            style="font-size: 0.7rem; font-weight: 700; color: var(--text-muted); background: var(--bg-light); padding: 4px 10px; border-radius: 50px;">
                                            <%= book.subject %>
                                        </span>
                                    </div>
                            </div>

                            <h3
                                style="font-weight: 800; color: var(--primary); margin-bottom: 0.5rem; font-size: 1.2rem; min-height: 3rem; line-height: 1.4;">
                                <%= book.title %>
                            </h3>

                            <div style="display: flex; gap: 10px; margin-top: 1rem;">
                                <a href="<%= book.file_path %>" target="_blank" class="btn-primary"
                                    style="flex: 1; text-align: center; display: flex; align-items: center; justify-content: center; gap: 8px; padding: 10px; border-radius: 12px; font-size: 0.85rem; text-decoration: none;">
                                    <i class="fas fa-eye"></i> View
                                </a>
                                <a href="<%= book.file_path %>" download="<%= book.title %>" class="btn"
                                    style="flex: 1; text-align: center; display: flex; align-items: center; justify-content: center; gap: 8px; padding: 10px; border-radius: 12px; font-size: 0.85rem; background: var(--bg-main); border: 1px solid #e2e8f0; color: var(--primary); text-decoration: none;">
                                    <i class="fas fa-download"></i> Download
                                </a>
                            </div>
                        </div>
                        <% }) %>
                </div>
                <% } %>
    </main>

    <script>
        function filterLibrary() {
            const search = document.getElementById('searchInput').value.toLowerCase();
            const grade = document.getElementById('gradeFilter') ? document.getElementById('gradeFilter').value : 'all';
            const subject = document.getElementById('subjectFilter').value;
            const items = document.querySelectorAll('.library-item');

            items.forEach(item => {
                const titleMatch = item.getAttribute('data-title').includes(search);
                const gradeMatch = grade === 'all' || item.getAttribute('data-grade') === grade;
                const subjectMatch = subject === 'all' || item.getAttribute('data-subject') === subject;

                if (titleMatch && gradeMatch && subjectMatch) {
                    item.style.display = 'block';
                } else {
                    item.style.display = 'none';
                }
            });
        }
    </script>

    <footer style="text-align: center; padding: 3rem; color: var(--text-muted); font-weight: 600;">
        <p>&copy; <%= new Date().getFullYear() %> Waqar Public Higher Secondary School. All Rights Reserved.</p>
    </footer>

</body>

</html>
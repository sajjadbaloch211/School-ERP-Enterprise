<%- include('../partials/header') %>

    <div class="admin-layout animate-fade-in" style="margin-top: 80px;">
        <%- include('../partials/sidebar_teacher', { active: 'homework' }) %>

            <main class="main-content">
                <header
                    style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 3rem;">
                    <div>
                        <a href="/teacher/homework"
                            style="color: var(--primary); text-decoration: none; font-weight: 700; display: flex; align-items: center; gap: 5px; margin-bottom: 10px;">
                            <i class="fas fa-arrow-left"></i> Back to Homework
                        </a>
                        <h2 style="font-size: 2rem; font-weight: 800; color: var(--primary);">
                            <%= homework.title %>
                        </h2>
                        <p style="color: var(--text-muted);">Class: <%= homework.class_name %> - <%= homework.section %>
                                    | Due: <%= new Date(homework.due_date).toLocaleDateString() %>
                        </p>
                    </div>
                </header>

                <div class="card animate-slide-up" style="border-radius: 24px; padding: 0; overflow: hidden;">
                    <table class="data-table" style="width: 100%; border-collapse: collapse;">
                        <thead>
                            <tr style="background: #f8fafc; text-align: left;">
                                <th style="padding: 1.5rem; color: #64748b; font-weight: 700;">Roll No</th>
                                <th style="padding: 1.5rem; color: #64748b; font-weight: 700;">Student Name</th>
                                <th style="padding: 1.5rem; color: #64748b; font-weight: 700;">Status</th>
                                <th style="padding: 1.5rem; color: #64748b; font-weight: 700;">Submission File</th>
                                <th style="padding: 1.5rem; color: #64748b; font-weight: 700;">Marks (<%=
                                        homework.total_marks %>)</th>
                                <th style="padding: 1.5rem; color: #64748b; font-weight: 700;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% submissions.forEach(sub=> { %>
                                <tr style="border-bottom: 1px solid #f1f5f9;">
                                    <td style="padding: 1.5rem; font-weight: 700; color: var(--primary);">
                                        <%= sub.roll_no %>
                                    </td>
                                    <td style="padding: 1.5rem; font-weight: 600;">
                                        <%= sub.full_name %>
                                    </td>
                                    <td style="padding: 1.5rem;">
                                        <% if (!sub.submission_id) { %>
                                            <span class="badge" style="background: #fee2e2; color: #ef4444;">Not
                                                Submitted</span>
                                            <% } else if (sub.status==='late' ) { %>
                                                <span class="badge" style="background: #fef3c7; color: #d97706;">Late
                                                    Submission</span>
                                                <div
                                                    style="font-size: 0.75rem; color: var(--text-muted); margin-top: 4px;">
                                                    <%= new Date(sub.submitted_at).toLocaleString('en-GB', { hour12:
                                                        true }) %>
                                                </div>
                                                <% } else { %>
                                                    <span class="badge" style="background: #ecfdf5; color: #10b981;">On
                                                        Time</span>
                                                    <div
                                                        style="font-size: 0.75rem; color: var(--text-muted); margin-top: 4px;">
                                                        <%= new Date(sub.submitted_at).toLocaleString('en-GB') %>
                                                    </div>
                                                    <% } %>
                                    </td>
                                    <td style="padding: 1.5rem;">
                                        <% if (sub.submission_id) { %>
                                            <a href="<%= sub.submission_file %>" target="_blank"
                                                style="color: var(--primary); background: #eff6ff; padding: 8px 15px; border-radius: 8px; text-decoration: none; font-size: 0.85rem; display: inline-flex; align-items: center; gap: 8px;">
                                                <i class="fas fa-file-download"></i> View File
                                            </a>
                                            <% } else { %>
                                                -
                                                <% } %>
                                    </td>
                                    <td style="padding: 1.5rem;">
                                        <% if (sub.submission_id) { %>
                                            <input type="number" id="marks_<%= sub.submission_id %>"
                                                value="<%= sub.marks_obtained || '' %>"
                                                max="<%= homework.total_marks %>"
                                                style="width: 70px; padding: 8px; border-radius: 8px; border: 1px solid #e2e8f0; font-weight: 700; text-align: center;">
                                            <% } else { %>
                                                -
                                                <% } %>
                                    </td>
                                    <td style="padding: 1.5rem;">
                                        <% if (sub.submission_id) { %>
                                            <button onclick="saveGrade('<%= sub.submission_id %>')" class="btn"
                                                style="background: var(--primary); color: white; padding: 8px 20px; border-radius: 8px; font-weight: 700;">
                                                Save
                                            </button>
                                            <% } else { %>
                                                -
                                                <% } %>
                                    </td>
                                </tr>
                                <% }) %>
                        </tbody>
                    </table>
                </div>
            </main>
    </div>

    <script>
        async function saveGrade(submissionId) {
            const marks = document.getElementById('marks_' + submissionId).value;
            const csrf = '<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>';

            try {
                const response = await fetch('/teacher/homework/grade', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    body: JSON.stringify({
                        submission_id: submissionId,
                        marks: marks,
                        remarks: '',
                        _csrf: csrf
                    })
                });

                const data = await response.json();
                if (data.success) {
                    alert('Grade saved successfully!');
                    window.location.reload();
                }
            } catch (err) {
                console.error(err);
                alert('Failed to save grade.');
            }
        }
    </script>

    <%- include('../partials/footer') %>
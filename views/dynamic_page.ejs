<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <%
      const schoolName = (settings && (settings.site_name || settings.school_name)) || 'School Management System';
      const schoolPhone = (settings && (settings.contact_phone || settings.phone)) || '+92 300 0000000';
      const schoolEmail = (settings && (settings.contact_email || settings.email)) || 'info@school.edu.pk';
      const schoolAddress = (settings && settings.address) || 'Pakistan';
      const pc = theme && theme.colors && theme.colors.primary   ? theme.colors.primary   : '#1e40af';
      const sc = theme && theme.colors && theme.colors.secondary ? theme.colors.secondary : '#059669';
    %>
    <title><%= page.title %> — <%= schoolName %></title>
    <meta name="description" content="<%= page.meta_description || 'School Management System — Digital Excellence in Education' %>">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800;900&family=Instrument+Serif:ital@1&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    
    <!-- Lenis Smooth Scroll CSS fallback -->
    <style>
    html.lenis, html.lenis body {
      height: auto;
    }
    .lenis-smooth {
      scroll-behavior: auto !important;
    }
    .lenis-smooth [data-lenis-prevent] {
      overscroll-behavior: contain;
    }
    .lenis-stopped {
      overflow: hidden;
    }
    .lenis-scrolling iframe {
      pointer-events: none;
    }

    /* ─── TOKENS ──────────────────────────────────────────── */
    :root{
        --P: <%= pc %>;
        --S: <%= sc %>;
        --ink: #0d1117;
        --muted: #8b949e;
        --surface: #161b22;
        --white: #fff;
        --border: rgba(255,255,255,0.06);
        --sp: cubic-bezier(0.16, 1, 0.3, 1);
        --font: 'Plus Jakarta Sans', sans-serif;
    }
    
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{
        font-family:var(--font);
        color:#f0f6fc;
        background:var(--ink);
        -webkit-font-smoothing:antialiased;
        overflow-x:hidden;
    }
    a{text-decoration:none;color:inherit}
    img{display:block;max-width:100%}

    /* ─── NAV ─────────────────────────────────────────────── */
    .nav{position:fixed;top:0;left:0;right:0;z-index:999;background:rgba(13,17,23,.85);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-bottom:1px solid rgba(255,255,255,.05)}
    .nav-wrap{max-width:1280px;margin:0 auto;padding:0 32px;height:72px;display:flex;align-items:center;gap:0}
    .nav-logo{display:flex;align-items:center;gap:10px;font-weight:800;font-size:.95rem;color:#fff;letter-spacing:-.02em;flex-shrink:0}
    .nav-logo .logo-icon{width:38px;height:38px;background:var(--P);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:.95rem;color:#fff;flex-shrink:0;box-shadow:0 8px 16px rgba(0,0,0,0.25)}
    .nav-links{display:flex;gap:2px;margin:0 auto}
    .nav-links a{font-size:.82rem;font-weight:600;color:rgba(255,255,255,.6);padding:8px 14px;border-radius:100px;transition:color .2s,background .2s}
    .nav-links a:hover{color:#fff;background:rgba(255,255,255,.05)}
    .nav-actions{display:flex;gap:8px;flex-shrink:0}
    .nav-btn-ghost{font-size:.8rem;font-weight:700;color:rgba(255,255,255,.7);padding:10px 18px;border-radius:100px;border:1px solid rgba(255,255,255,.12);transition:all .2s}
    .nav-btn-ghost:hover{background:rgba(255,255,255,.08);color:#fff}
    .nav-btn-solid{font-size:.8rem;font-weight:700;color:#fff;padding:10px 20px;border-radius:100px;background:var(--P);transition:all .3s var(--sp);box-shadow:0 8px 16px rgba(30,64,175,0.25)}
    .nav-btn-solid:hover{transform:scale(1.03);filter:brightness(1.1);box-shadow:0 12px 24px rgba(30,64,175,0.4)}

    /* ─── HERO ────────────────────────────────────────────── */
    .hero{min-height:100dvh;display:grid;grid-template-columns:1.1fr 0.9fr;background:var(--ink);position:relative;overflow:hidden;padding-top:72px}
    .hero-glow-1{position:absolute;width:700px;height:700px;top:-250px;left:-150px;border-radius:50%;background:radial-gradient(circle,rgba(30,64,175,.35) 0%,transparent 70%);filter:blur(80px);pointer-events:none}
    .hero-glow-2{position:absolute;width:500px;height:500px;bottom:-150px;right:5%;border-radius:50%;background:radial-gradient(circle,rgba(5,150,105,.22) 0%,transparent 70%);filter:blur(80px);pointer-events:none}
    .hero-left{display:flex;flex-direction:column;justify-content:center;padding:80px 48px 80px 80px;position:relative;z-index:2}
    .hero-eyebrow{display:inline-flex;align-items:center;gap:8px;background:rgba(30,64,175,.15);border:1px solid rgba(30,64,175,.25);border-radius:100px;padding:6px 14px 6px 8px;font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:rgba(255,255,255,.75);margin-bottom:28px;width:fit-content}
    .hero-eyebrow .dot{width:6px;height:6px;border-radius:50%;background:#60a5fa;animation:blink 2s infinite}
    @keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}
    .hero-h1{font-size:clamp(2.8rem,5vw,4.5rem);font-weight:900;color:#fff;letter-spacing:-.05em;line-height:1.05;margin-bottom:24px}
    .hero-h1 .serif{font-family:'Instrument Serif',serif;font-weight:400;font-style:italic;color:#60a5fa}
    .hero-desc{font-size:.95rem;color:rgba(255,255,255,.5);line-height:1.75;max-width:520px;margin-bottom:40px}
    .hero-btns{display:flex;gap:12px;flex-wrap:wrap}
    
    .btn-primary{display:inline-flex;align-items:center;gap:8px;background:var(--S);color:#fff;font-weight:750;font-size:.85rem;padding:14px 24px;border-radius:100px;border:none;cursor:pointer;transition:all .3s var(--sp);box-shadow:0 8px 20px rgba(5,150,105,0.25)}
    .btn-primary:hover{transform:translateY(-2px);box-shadow:0 12px 28px rgba(5,150,105,0.4)}
    
    .btn-outline{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,.05);color:rgba(255,255,255,.75);font-weight:600;font-size:.85rem;padding:14px 24px;border-radius:100px;border:1px solid rgba(255,255,255,.1);transition:all .3s}
    .btn-outline:hover{background:rgba(255,255,255,.1);color:#fff}
    
    .hero-right{position:relative;z-index:2;display:flex;flex-direction:column;justify-content:center;padding:60px 60px 60px 20px;gap:12px}

    /* ─── 3D Hero Frame ──────────────────────────────────── */
    .hero-3d-frame{
        perspective:800px;
        border-radius:24px;
        overflow:visible;
        width:100%;
    }
    .hero-3d-inner{
        position:relative;
        border-radius:20px;
        overflow:hidden;
        aspect-ratio:16/10;
        background:#161b22;
        border:1px solid rgba(255,255,255,0.07);
        box-shadow:0 30px 70px rgba(0,0,0,0.55), 0 0 0 1px rgba(255,255,255,0.04);
        transform-style:preserve-3d;
        transition:transform 0.12s linear;
        will-change:transform;
    }
    /* Floating badges on the 3D illustration */
    .float-badge{
        position:absolute;
        padding:7px 14px;
        border-radius:100px;
        font-size:.72rem;
        font-weight:700;
        display:flex;
        align-items:center;
        gap:6px;
        background:rgba(13,17,23,.85);
        backdrop-filter:blur(12px);
        border:1px solid rgba(255,255,255,.1);
        color:#fff;
        box-shadow:0 8px 20px rgba(0,0,0,0.4);
        pointer-events:none;
        z-index:10;
    }
    .float-b1{top:12px;left:14px;border-color:rgba(96,165,250,.3);color:#93c5fd}
    .float-b2{bottom:12px;right:14px;border-color:rgba(52,211,153,.3);color:#6ee7b7}

    /* ─── Portal cards row ────────────────────────────────── */
    .hero-portal-row{display:flex;flex-direction:column;gap:10px;width:100%}
    
    /* Premium Portal cards */
    .portal-card{
        background:rgba(22, 27, 34, 0.5);
        backdrop-filter:blur(16px);
        -webkit-backdrop-filter:blur(16px);
        border:1px solid rgba(255,255,255,.06);
        border-top:1px solid rgba(255,255,255,.12);
        border-left:1px solid rgba(255,255,255,.08);
        border-radius:16px;
        padding:16px 20px;
        display:flex;
        align-items:center;
        gap:14px;
        transition:all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
        cursor:pointer;
        box-shadow: 0 12px 28px rgba(0,0,0,0.25);
        text-decoration:none;
    }
    .portal-card:hover{
        background:rgba(22, 27, 34, 0.8);
        border-color:var(--P);
        transform:translateX(8px) translateY(-2px);
        box-shadow: 
            0 20px 45px rgba(0,0,0,0.45),
            0 0 18px rgba(30,64,175,0.18);
    }
    .portal-icon{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;box-shadow:0 6px 12px rgba(0,0,0,0.2)}
    .portal-info{flex:1}
    .portal-title{font-size:.88rem;font-weight:800;color:#fff;margin-bottom:2px;letter-spacing:-.01em}
    .portal-sub{font-size:.72rem;color:rgba(255,255,255,.4);font-weight:500}
    .portal-arrow{color:rgba(255,255,255,.2);font-size:.8rem;transition:transform .3s,color .3s}
    .portal-card:hover .portal-arrow{transform:translateX(4px);color:var(--P)}
    
    /* Hero stats row */
    .hero-stats{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;width:100%}
    .hero-stat{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);border-radius:14px;padding:14px 16px;text-align:center;box-shadow:0 8px 24px rgba(0,0,0,0.15)}
    .hero-stat-n{font-size:1.5rem;font-weight:900;color:#fff;letter-spacing:-.04em;line-height:1}
    .hero-stat-l{font-size:.68rem;color:rgba(255,255,255,.4);margin-top:4px;font-weight:500}


    /* ─── SHARED UTILS ────────────────────────────────────── */
    .section{padding:140px 0}
    .section-alt{background:#161b22;border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
    .wrap{max-width:1280px;margin:0 auto;padding:0 32px}
    .section-tag{display:inline-flex;align-items:center;gap:6px;background:rgba(30,64,175,.15);border:1px solid rgba(30,64,175,.25);border-radius:100px;padding:5px 12px 5px 8px;font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:#60a5fa;margin-bottom:20px}
    .section-tag .dot{width:5px;height:5px;border-radius:50%;background:#60a5fa}
    .section-h{font-size:clamp(2rem,3.5vw,2.8rem);font-weight:900;letter-spacing:-.04em;color:#fff;line-height:1.1;margin-bottom:16px}
    .section-sub{font-size:.95rem;color:var(--muted);line-height:1.75;max-width:580px}
    .center{text-align:center}.center .section-sub{margin:0 auto}

    /* ─── STATS BAND ──────────────────────────────────────── */
    .stats-band{background:linear-gradient(135deg,var(--P) 0%,#143588 100%);padding:72px 0}
    .stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:rgba(255,255,255,.1);border-radius:24px;overflow:hidden;box-shadow:0 20px 50px rgba(0,0,0,0.25)}
    .stat-box{background:rgba(255,255,255,.05);padding:48px 28px;text-align:center;transition:background .3s}
    .stat-box:hover{background:rgba(255,255,255,.1)}
    .stat-n{font-size:clamp(2.4rem,3.8vw,3.2rem);font-weight:900;color:#fff;letter-spacing:-.05em;line-height:1}
    .stat-l{font-size:.8rem;color:rgba(255,255,255,.55);margin-top:8px;font-weight:500;letter-spacing:.03em}

    /* ─── FEATURES GRID ──────────────────────────────────── */
    .feat-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:60px}
    .feat-card{
        background:rgba(22, 27, 34, 0.45);
        border:1px solid rgba(255,255,255,0.05);
        border-top:1px solid rgba(255,255,255,0.1);
        border-left:1px solid rgba(255,255,255,0.08);
        border-radius:24px;
        padding:32px;
        transition:all .4s var(--sp);
        position:relative;
        overflow:hidden;
        box-shadow:0 15px 35px rgba(0,0,0,0.15);
    }
    .feat-card:hover{
        transform:translateY(-6px);
        box-shadow:0 24px 50px rgba(0,0,0,0.3);
        border-color:rgba(30,64,175,.3);
    }
    .feat-icon{width:52px;height:52px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:1.2rem;margin-bottom:20px;background:rgba(30,64,175,.15);color:#60a5fa;transition:all .3s}
    .feat-card:hover .feat-icon{background:var(--P);color:#fff;transform:scale(1.1) rotate(-6deg)}
    .feat-title{font-size:1rem;font-weight:800;color:#fff;margin-bottom:10px;letter-spacing:-.02em}
    .feat-desc{font-size:.85rem;color:var(--muted);line-height:1.7}

    /* ─── SPLIT / ABOUT ──────────────────────────────────── */
    .split{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center}
    .split-visual{position:relative}
    .img-frame{border-radius:28px;overflow:hidden;border:6px solid rgba(255,255,255,.05);box-shadow:0 30px 80px rgba(0,0,0,.35);aspect-ratio:4/3;background:#21262d}
    .img-frame img{width:100%;height:100%;object-fit:cover}
    .badge-float{position:absolute;bottom:-20px;right:-20px;background:rgba(22, 27, 34, 0.95);backdrop-filter:blur(12px);border-radius:16px;padding:14px 18px;box-shadow:0 12px 36px rgba(0,0,0,.3);display:flex;align-items:center;gap:12px;border:1px solid rgba(255,255,255,.08)}
    .badge-icon{width:42px;height:42px;background:rgba(5,150,105,.15);color:#34d399;border-radius:11px;display:flex;align-items:center;justify-content:center;font-size:1.1rem}
    .badge-text strong{font-size:.95rem;font-weight:800;display:block;color:#fff}
    .badge-text span{font-size:.72rem;color:var(--muted)}
    .split-body{font-size:.93rem;color:var(--muted);line-height:1.8;margin:20px 0}
    .split-body p{margin-bottom:12px}
    .check-list{list-style:none;display:flex;flex-direction:column;gap:10px;margin:20px 0 32px}
    .check-list li{display:flex;align-items:flex-start;gap:10px;font-size:.88rem;color:var(--muted)}
    .check-list li i{color:#34d399;margin-top:2px;flex-shrink:0;font-size:.85rem}
    
    .btn-solid{display:inline-flex;align-items:center;gap:8px;background:var(--P);color:#fff;font-weight:750;font-size:.88rem;padding:14px 24px;border-radius:100px;transition:all .3s var(--sp);box-shadow:0 8px 16px rgba(30,64,175,0.25)}
    .btn-solid:hover{transform:translateY(-2px);box-shadow:0 12px 30px rgba(30,64,175,.45)}

    /* ─── GALLERY ─────────────────────────────────────────── */
    .gallery-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:48px}
    .gal-item{border-radius:20px;overflow:hidden;aspect-ratio:4/3;background:#21262d;position:relative;cursor:pointer}
    .gal-item img{width:100%;height:100%;object-fit:cover;transition:transform .6s var(--sp)}
    .gal-item:hover img{transform:scale(1.05)}
    .gal-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(13,17,23,.8) 0%,transparent 60%);opacity:0;transition:opacity .3s;display:flex;align-items:flex-end;padding:16px}
    .gal-item:hover .gal-overlay{opacity:1}
    .gal-caption{font-size:.8rem;font-weight:700;color:#fff}

    /* ─── PROGRAMS SECTION ────────────────────────────────── */
    .prog-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:48px}
    .prog-card{
        background:rgba(22, 27, 34, 0.45);
        border:1px solid rgba(255,255,255,0.05);
        border-radius:24px;
        overflow:hidden;
        transition:all .4s var(--sp);
        box-shadow:0 15px 35px rgba(0,0,0,0.15);
    }
    .prog-card:hover{transform:translateY(-6px);box-shadow:0 24px 50px rgba(0,0,0,0.3);border-color:rgba(255,255,255,0.1)}
    .prog-banner{height:120px;display:flex;align-items:center;justify-content:center;font-size:2.5rem;background:rgba(255,255,255,0.02)}
    .prog-body{padding:24px}
    .prog-badge{display:inline-block;font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;padding:4px 12px;border-radius:100px;margin-bottom:10px}
    .prog-name{font-size:1rem;font-weight:800;color:#fff;margin-bottom:8px;letter-spacing:-.02em}
    .prog-desc{font-size:.82rem;color:var(--muted);line-height:1.6}

    /* ─── CTA ─────────────────────────────────────────────── */
    .cta-section{background:var(--ink);padding:120px 0;position:relative;overflow:hidden;border-top:1px solid rgba(255,255,255,0.05)}
    .cta-glow{position:absolute;width:550px;height:550px;border-radius:50%;filter:blur(80px);pointer-events:none}
    .cta-glow-1{top:-150px;left:-100px;background:radial-gradient(circle,rgba(30,64,175,.35),transparent 70%)}
    .cta-glow-2{bottom:-150px;right:-100px;background:radial-gradient(circle,rgba(5,150,105,.22),transparent 70%)}
    .cta-inner{position:relative;z-index:2;text-align:center}
    .cta-inner h2{font-size:clamp(2.2rem,4.5vw,3.2rem);font-weight:900;color:#fff;letter-spacing:-.05em;margin-bottom:16px}
    .cta-inner h2 .serif{font-family:'Instrument Serif',serif;font-weight:400;font-style:italic;color:#60a5fa}
    .cta-inner p{font-size:.95rem;color:rgba(255,255,255,.5);max-width:500px;margin:0 auto 36px;line-height:1.75}
    .cta-btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}
    .btn-white{display:inline-flex;align-items:center;gap:8px;background:#fff;color:var(--ink);font-weight:800;font-size:.88rem;padding:14px 26px;border-radius:100px;transition:all .3s var(--sp)}
    .btn-white:hover{transform:translateY(-2px);box-shadow:0 16px 40px rgba(255,255,255,0.2)}
    .btn-ghost-white{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,.06);color:rgba(255,255,255,.8);font-weight:600;font-size:.88rem;padding:14px 26px;border-radius:100px;border:1px solid rgba(255,255,255,.15);transition:all .3s}
    .btn-ghost-white:hover{background:rgba(255,255,255,.1);color:#fff}

    /* ─── CONTACT STRIP ──────────────────────────────────── */
    .contact-strip{background:#161b22;border-top:1px solid var(--border);border-bottom:1px solid var(--border)}
    .contact-row{display:grid;grid-template-columns:repeat(3,1fr);gap:0}
    .contact-item{display:flex;align-items:center;gap:16px;padding:32px;border-right:1px solid var(--border)}
    .contact-item:last-child{border-right:none}
    .contact-icon{width:44px;height:44px;background:rgba(30,64,175,.15);color:#60a5fa;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0}
    .contact-info strong{display:block;font-size:.85rem;font-weight:750;color:#fff;margin-bottom:2px}
    .contact-info span{font-size:.8rem;color:var(--muted)}

    /* ─── FOOTER ─────────────────────────────────────────── */
    .footer{background:var(--ink);padding:80px 0 40px}
    .footer-row{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:48px;margin-bottom:56px}
    .footer-logo{font-size:.95rem;font-weight:900;color:#fff;letter-spacing:-.02em;margin-bottom:12px;display:flex;align-items:center;gap:8px}
    .footer-logo .icon{width:32px;height:32px;background:var(--P);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:.85rem;box-shadow:0 4px 8px rgba(0,0,0,0.25)}
    .footer-tagline{font-size:.8rem;color:rgba(255,255,255,.4);line-height:1.7;max-width:260px;margin-bottom:20px}
    .footer-contact-list{display:flex;flex-direction:column;gap:8px}
    .footer-contact-list a,.footer-contact-list p{font-size:.78rem;color:rgba(255,255,255,.45);display:flex;align-items:center;gap:8px;transition:color .2s}
    .footer-contact-list a:hover{color:rgba(255,255,255,.85)}
    .footer-col-h{font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:rgba(255,255,255,.2);margin-bottom:18px}
    .footer-links{list-style:none;display:flex;flex-direction:column;gap:10px}
    .footer-links a{font-size:.82rem;color:rgba(255,255,255,.45);transition:color .2s}
    .footer-links a:hover{color:rgba(255,255,255,.85)}
    .footer-bottom{border-top:1px solid rgba(255,255,255,.05);padding-top:32px;display:flex;align-items:center;justify-content:space-between}
    .footer-bottom p{font-size:.77rem;color:rgba(255,255,255,.25)}

    /* ─── 3D SCROLL REVEAL ANIMATIONS ─────────────────────── */
    .r {
        opacity: 0;
        transform: translateY(60px) translateZ(-80px) rotateX(15deg);
        transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        transform-style: preserve-3d;
        perspective: 1000px;
        backface-visibility: hidden;
    }
    .r.v {
        opacity: 1;
        transform: translateY(0) translateZ(0) rotateX(0deg);
    }
    .d1{transition-delay:.08s}.d2{transition-delay:.16s}.d3{transition-delay:.24s}.d4{transition-delay:.32s}

    /* ─── RESPONSIVE ─────────────────────────────────────── */
    @media(max-width:1024px){
        .hero{grid-template-columns:1fr}.hero-right{padding:0 32px 60px;display:flex}
